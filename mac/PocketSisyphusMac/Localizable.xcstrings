          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível verificar o status da permissão (sem resposta do auxiliar)"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось проверить состояние разрешения (нет ответа от помощника)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法检查权限状态（助手无响应）"
          }
        }
      }
    },
    "정상 — 화면 기록 권한이 확인됐어요(캡처 가능)": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم — تأكيد إذن تسجيل الشاشة (الالتقاط يعمل)"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "OK — Screen Recording permission confirmed (capture works)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Correcto: permiso de Grabación de pantalla confirmado (la captura funciona)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "OK — autorisation Enregistrement de l’écran confirmée (la capture fonctionne)"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ठीक — स्क्रीन रिकॉर्डिंग अनुमति पुष्ट (कैप्चर संभव)"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "正常 — 画面収録の権限を確認しました（キャプチャ可能）"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "정상 — 화면 기록 권한이 확인됐어요(캡처 가능)"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "OK — permissão de Gravação de Tela confirmada (a captura funciona)"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Готово — разрешение на запись экрана подтверждено (захват работает)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正常 — 已确认屏幕录制权限（可捕获）"
          }
        }
      }
    },
    "화면 기록 권한이 없어요 — 시스템 설정에서 이 앱(이름 확인)을 켠 뒤 앱을 재시작하세요": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يوجد إذن تسجيل الشاشة — فعّل هذا التطبيق (تحقق من الاسم) في إعدادات النظام ثم أعد تشغيله"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No Screen Recording permission — enable this app (check the name) in System Settings, then restart the app"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sin permiso de Grabación de pantalla: activa esta app (comprueba el nombre) en Ajustes del Sistema y reiníciala"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pas d’autorisation Enregistrement de l’écran — activez cette app (vérifiez le nom) dans les Réglages Système, puis redémarrez-la"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्क्रीन रिकॉर्डिंग अनुमति नहीं है — सिस्टम सेटिंग्स में इस ऐप (नाम जांचें) को चालू करें, फिर ऐप पुनः चालू करें"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "画面収録の権限がありません — システム設定でこのアプリ（名前を確認）をオンにしてからアプリを再起動してください"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "화면 기록 권한이 없어요 — 시스템 설정에서 이 앱(이름 확인)을 켠 뒤 앱을 재시작하세요"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sem permissão de Gravação de Tela — ative este app (confira o nome) nos Ajustes do Sistema e reinicie-o"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нет разрешения на запись экрана — включите это приложение (проверьте имя) в Системных настройках и перезапустите его"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有屏幕录制权限 — 请在系统设置中开启本应用（核对名称），然后重启应用"
          }
        }
      }
    },
    "정상 — 손쉬운 사용 신뢰됨(입력 주입 가능)": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم — تسهيلات الاستخدام موثوقة (حقن الإدخال يعمل)"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "OK — Accessibility trusted (input injection works)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Correcto: Accesibilidad de confianza (la inyección de entrada funciona)"
          }
        },
        "fr": {
