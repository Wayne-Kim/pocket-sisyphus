    "전원 설정을 바꾸지 못했어요 — 관리자 인증이 취소됐을 수 있어요": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذّر تغيير إعداد الطاقة — قد يكون التحقق من هوية المسؤول قد أُلغي"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't change the power setting — administrator authentication may have been canceled"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo cambiar el ajuste de energía — es posible que se haya cancelado la autenticación de administrador"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de modifier le réglage d'alimentation — l'authentification administrateur a peut-être été annulée"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पावर सेटिंग नहीं बदल सकी — हो सकता है एडमिनिस्ट्रेटर प्रमाणीकरण रद्द हो गया हो"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "電源設定を変更できませんでした — 管理者認証がキャンセルされた可能性があります"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "전원 설정을 바꾸지 못했어요 — 관리자 인증이 취소됐을 수 있어요"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível alterar a configuração de energia — a autenticação de administrador pode ter sido cancelada"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось изменить настройку питания — возможно, проверка прав администратора была отменена"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法更改电源设置 — 管理员认证可能已取消"
          }
        }
      }
    },
