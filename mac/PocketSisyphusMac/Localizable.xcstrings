    "올바른 딥링크 페이지 주소가 아니에요 — ?·# 없는 https URL 만 가능해요": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "올바른 딥링크 페이지 주소가 아니에요 — ?·# 없는 https URL 만 가능해요"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Not a valid deep link page URL — only https URLs without ? or # are allowed"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "有効なディープリンクページURLではありません — ?・# を含まない https URL のみ使用できます"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "深层链接页面地址无效 — 仅支持不含 ? 和 # 的 https 网址"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La URL de la página de enlace profundo no es válida — solo se admiten URL https sin ? ni #"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "URL de page de lien profond non valide — seules les URL https sans ? ni # sont acceptées"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "URL da página de deep link inválida — apenas URLs https sem ? ou # são permitidas"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Недопустимый URL страницы глубокой ссылки — допускаются только https-URL без ? и #"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عنوان URL لصفحة الرابط العميق غير صالح — يُسمح فقط بعناوين https بدون ? أو #"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डीप लिंक पेज URL मान्य नहीं है — केवल ? या # रहित https URL ही मान्य हैं"
          }
        }
      }
    },
