    "출시한 앱의 스토어 리뷰를 PO 수집이 읽어 사용자 불만·요청을 브리프 근거로 가져와요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يقرأ تجميع PO مراجعات المتجر لتطبيقك المنشور ويجلب شكاوى المستخدمين وطلباتهم كأدلة في الموجزات."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "PO collection reads your released app's store reviews, bringing user complaints and requests into briefs as evidence."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La recopilación del PO lee las reseñas de tu app publicada y aporta quejas y peticiones de los usuarios como evidencia de los informes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La collecte du PO lit les avis de votre app publiée et intègre les plaintes et demandes des utilisateurs comme preuves dans les brefs."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "PO संग्रह आपके प्रकाशित ऐप की स्टोर समीक्षाएँ पढ़कर उपयोगकर्ता शिकायतों और अनुरोधों को ब्रीफ़ के साक्ष्य के रूप में लाता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "公開済みアプリのストアレビューを PO 収集が読み取り、ユーザーの不満・要望をブリーフの根拠として取り込みます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "출시한 앱의 스토어 리뷰를 PO 수집이 읽어 사용자 불만·요청을 브리프 근거로 가져와요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A coleta do PO lê as avaliações da sua app publicada, trazendo reclamações e pedidos dos usuários como evidência para os briefs."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сбор PO читает отзывы на ваше выпущенное приложение и добавляет жалобы и запросы пользователей в брифы как доказательства."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "PO 收集会读取已发布应用的商店评论，把用户的不满和需求作为简报依据。"
          }
        }
      }
    },
    "외부 서버 없이, 이 Mac 이 App Store Connect API 를 직접 호출합니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بدون خادم خارجي — يستدعي هذا الـ Mac واجهة App Store Connect API مباشرة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No external server — this Mac calls the App Store Connect API directly."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sin servidor externo: este Mac llama directamente a la API de App Store Connect."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sans serveur externe — ce Mac appelle directement l'API App Store Connect."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कोई बाहरी सर्वर नहीं — यह Mac सीधे App Store Connect API को कॉल करता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "外部サーバーなしで、この Mac が App Store Connect API を直接呼び出します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "외부 서버 없이, 이 Mac 이 App Store Connect API 를 직접 호출합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sem servidor externo — este Mac chama a API do App Store Connect diretamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Без внешнего сервера — этот Mac напрямую вызывает App Store Connect API."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无需外部服务器，由这台 Mac 直接调用 App Store Connect API。"
          }
        }
      }
    },
