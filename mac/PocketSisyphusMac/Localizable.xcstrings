    "충돌이 나도 앱이 자동으로 빈 포트를 찾아 띄우니, 잘 모르겠으면 기본값을 그대로 두세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حتى عند حدوث تعارض، يبحث التطبيق تلقائيًا عن منفذ فارغ ويستخدمه، فاترك القيمة الافتراضية إن لم تكن متأكدًا."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Even on a conflict the app automatically finds and uses a free port, so leave the default if you’re unsure."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Incluso si hay un conflicto, la app encuentra y usa un puerto libre automáticamente, así que deja el valor predeterminado si no estás seguro."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Même en cas de conflit, l’app trouve et utilise un port libre automatiquement ; laissez la valeur par défaut si vous avez un doute."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "टकराव होने पर भी ऐप अपने आप एक खाली पोर्ट ढूँढकर उपयोग करता है, इसलिए संदेह हो तो डिफ़ॉल्ट रहने दें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "競合しても、アプリが空きポートを自動で見つけて使うので、分からなければ既定値のままにしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "충돌이 나도 앱이 자동으로 빈 포트를 찾아 띄우니, 잘 모르겠으면 기본값을 그대로 두세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mesmo em caso de conflito, o app encontra e usa uma porta livre automaticamente; deixe o padrão se tiver dúvida."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Даже при конфликте приложение само найдёт и займёт свободный порт — если не уверены, оставьте значение по умолчанию."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "即使发生冲突，应用也会自动寻找并使用空闲端口，所以不确定时保留默认值即可。"
          }
        }
      }
    },
