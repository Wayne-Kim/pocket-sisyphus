    "자동 설치에 실패했어요. 위 명령을 터미널에서 직접 실행한 뒤 다시 시도하세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فشل التثبيت التلقائي. شغّل الأمر أعلاه في Terminal بنفسك ثم حاول مرة أخرى."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Automatic installation failed. Run the command above in Terminal yourself, then try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La instalación automática falló. Ejecuta el comando anterior en la Terminal y vuelve a intentarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'installation automatique a échoué. Exécutez la commande ci-dessus dans le Terminal, puis réessayez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्वचालित इंस्टॉल विफल रहा। ऊपर दिया कमांड टर्मिनल में खुद चलाएँ और फिर से कोशिश करें।"
          }
        },
        "ja": {
