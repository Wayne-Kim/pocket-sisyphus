            "value": "三个选项:"
          }
        }
      }
    },
    "승인 — 이번 호출만 허용. 같은 도구를 또 부르면 다시 묻습니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "موافقة — السماح بهذا الاستدعاء فقط. سيُسأل عند الاستدعاء التالي لنفس الأداة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Approve — allow just this call. You’ll be asked again for the next call."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aprobar — permite solo esta llamada. Te volverá a preguntar la próxima vez."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Autoriser — uniquement pour cet appel. Pour le suivant, on vous redemande."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्वीकृति — सिर्फ़ इस कॉल को अनुमति। अगली कॉल पर फिर पूछा जाएगा।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "承認 — 今回の呼び出しのみ許可。次回はまた確認します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "승인 — 이번 호출만 허용. 같은 도구를 또 부르면 다시 묻습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Aprovar — permite apenas esta chamada. Será perguntado de novo na próxima."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Одобрить — только этот вызов. При следующем вызове спросят снова."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "批准 — 仅允许本次调用。下次再调用同一工具时会再问。"
          }
        }
      }
    },
    "거부 — 이번 호출을 막습니다. 모델은 다른 방법을 모색하거나 사용자에게 다시 물어봅니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "رفض — منع هذا الاستدعاء. سيبحث النموذج عن طريق آخر أو يسألك مجددًا."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Deny — block this call. The model will try another approach or ask you again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Denegar — bloquea esta llamada. El modelo buscará otra vía o te volverá a preguntar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Refuser — bloque cet appel. Le modèle cherchera une autre voie ou vous redemandera."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अस्वीकार — इस कॉल को रोकें। मॉडल कोई और तरीका खोजेगा या फिर पूछेगा।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "拒否 — この呼び出しを阻止。モデルは別の方法を試すか、再度確認します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "거부 — 이번 호출을 막습니다. 모델은 다른 방법을 모색하거나 사용자에게 다시 물어봅니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Negar — bloqueia esta chamada. O modelo tenta outro caminho ou pergunta de novo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отказать — заблокировать вызов. Модель попробует другой путь или спросит снова."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拒绝 — 阻止本次调用。模型会尝试其他方式或再次询问你。"
          }
        }
      }
    },
    "이 세션에서 항상 승인 — 이 세션이 끝날 때까지 같은 도구는 자동 승인. 세션 범위만이라 다른 세션에는 영향이 없습니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "السماح دائمًا في هذه الجلسة — تُوافَق الاستدعاءات على نفس الأداة تلقائيًا حتى انتهاء الجلسة. ينطبق على هذه الجلسة فقط ولا يؤثر على الجلسات الأخرى."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Always allow in this session — same tool gets auto-approved until the session ends. Scoped to this session only; other sessions are unaffected."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Permitir siempre en esta sesión — se aprueba automáticamente la misma herramienta hasta que termine la sesión. Sólo afecta a esta sesión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Toujours autoriser dans cette session — le même outil est auto-autorisé jusqu’à la fin de la session. Limité à cette session uniquement."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस सत्र में हमेशा अनुमति — सत्र समाप्त होने तक उसी टूल को स्वत: स्वीकृति। केवल इसी सत्र पर लागू, अन्य सत्रों पर असर नहीं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このセッションで常に許可 — セッション終了まで同じツールを自動承認。このセッション内のみで、他のセッションには影響しません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 세션에서 항상 승인 — 이 세션이 끝날 때까지 같은 도구는 자동 승인. 세션 범위만이라 다른 세션에는 영향이 없습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sempre permitir nesta sessão — a mesma ferramenta é aprovada automaticamente até a sessão acabar. Vale só para esta sessão."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Всегда разрешать в этой сессии — тот же инструмент авто-разрешается до конца сессии. Только в рамках этой сессии."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本会话始终允许 — 直到会话结束,相同工具自动批准。仅限本会话,不影响其他会话。"
          }
        }
      }
    },
    "톱니바퀴 메뉴의 «도구 자동 승인» 을 켜면 모든 도구 호출이 묻지 않고 통과됩니다. 빠르지만 위험합니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تشغيل «السماح التلقائي بالأدوات» في قائمة الإعدادات يجعل جميع استدعاءات الأدوات تمر دون سؤال. أسرع، ولكن أكثر خطرًا."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Turning on “Auto-approve tools” in the gear menu lets every tool call pass without asking. Faster, but riskier."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activar «Autoaprobar herramientas» en el menú de la rueda dentada hace que todas las llamadas pasen sin preguntar. Más rápido, pero arriesgado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activer « Autoriser les outils auto. » dans le menu engrenage laisse passer tous les appels sans demander. Plus rapide, mais risqué."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "गियर मेनू में «टूल स्वत: स्वीकृति» चालू करने पर सभी टूल कॉल बिना पूछे पारित होते हैं। तेज़, पर जोखिमपूर्ण।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "歯車メニューの「ツールを自動承認」をオンにすると、すべてのツール呼び出しが確認なしで通過します。速い反面、リスクは高くなります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "톱니바퀴 메뉴의 «도구 자동 승인» 을 켜면 모든 도구 호출이 묻지 않고 통과됩니다. 빠르지만 위험합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ligar «Aprovar ferramentas automaticamente» no menu da engrenagem deixa todas as chamadas passarem sem perguntar. Mais rápido, mais arriscado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Включение «Авто-разрешение инструментов» в меню шестерёнки пропускает все вызовы без подтверждения. Быстрее, но рискованнее."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在齿轮菜单中开启「工具自动批准」会让所有工具调用免确认通过。更快,但更危险。"
          }
        }
      }
    },
    "«자동 승인» 은 Claude 가 의도와 다른 파일을 쓰거나 위험한 명령을 실행해도 막지 못합니다. 모르는 레포 / 큰 변경 시엔 끄세요. 익숙한 작은 작업에만 권장합니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "«السماح التلقائي» لا يمكنه إيقاف Claude إذا كتب ملفًا غير مقصود أو نفّذ أمرًا خطرًا. أوقف التشغيل عند العمل على مستودع غير مألوف أو إجراء تغييرات كبيرة. يُنصَح به فقط للمهام الصغيرة المألوفة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "“Auto-approve” can’t stop Claude if it writes the wrong file or runs a dangerous command. Turn it off on unfamiliar repos or large changes. Use it only for small, familiar tasks."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "«Autoaprobar» no detendrá a Claude si escribe el archivo equivocado o ejecuta un comando peligroso. Apágalo en repos desconocidos o cambios grandes. Recomendado solo para tareas pequeñas y conocidas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "« Autoriser auto. » n’empêchera pas Claude d’écrire le mauvais fichier ou de lancer une commande dangereuse. Désactivez sur dépôts inconnus ou gros changements. À réserver aux petites tâches familières."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "«स्वत: स्वीकृति» Claude को ग़लत फ़ाइल लिखने या ख़तरनाक कमांड चलाने से नहीं रोकती। अनजान रेपो / बड़े बदलाव पर इसे बंद रखें। केवल छोटे, परिचित कार्यों के लिए अनुशंसित।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「自動承認」は、Claude が意図しないファイルに書き込んだり危険なコマンドを実行しても止めません。不慣れなリポジトリや大きな変更ではオフにしてください。慣れた小さな作業のみ推奨。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "«자동 승인» 은 Claude 가 의도와 다른 파일을 쓰거나 위험한 명령을 실행해도 막지 못합니다. 모르는 레포 / 큰 변경 시엔 끄세요. 익숙한 작은 작업에만 권장합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "«Aprovar automaticamente» não impede o Claude de gravar o arquivo errado ou rodar um comando perigoso. Desligue em repos desconhecidos ou mudanças grandes. Use só em tarefas pequenas e familiares."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "«Авто-разрешение» не остановит Claude, если он запишет не тот файл или выполнит опасную команду. Выключайте на незнакомых репозиториях и крупных правках. Только для небольших привычных задач."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "「自动批准」无法阻止 Claude 写错文件或执行危险命令。在陌生仓库 / 大改动时请关闭。仅建议在熟悉的小任务中使用。"
          }
        }
      }
    },
    "이어 받은 뒤엔 그 세션 컨텍스트가 모바일에 묶입니다. 데스크탑에서 계속 작업할 거면 새 세션을 시작하세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بعد المتابعة يصبح سياق الجلسة مربوطًا بالهاتف. إذا أردت متابعة العمل على سطح المكتب، ابدأ جلسة جديدة هناك."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "After resuming, that session’s context is bound to the phone. If you want to keep working on desktop, start a new session there."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tras reanudar, el contexto de esa sesión queda ligado al móvil. Si quieres seguir en el escritorio, inicia una sesión nueva allí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Après reprise, le contexte est lié au téléphone. Pour continuer sur le bureau, lancez-y une nouvelle session."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जारी रखने के बाद उस सत्र का कॉन्टेक्स्ट मोबाइल से बंध जाता है। डेस्कटॉप पर काम जारी रखना हो तो वहाँ नया सत्र शुरू करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "引き継いだ後、そのセッションのコンテキストはモバイル側に結び付きます。デスクトップで作業を続けたい場合は、そちらで新しいセッションを開始してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이어 받은 뒤엔 그 세션 컨텍스트가 모바일에 묶입니다. 데스크탑에서 계속 작업할 거면 새 세션을 시작하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Após retomar, o contexto fica vinculado ao celular. Se quiser continuar no desktop, inicie uma nova sessão lá."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "После продолжения контекст сессии привязан к телефону. Если хотите работать дальше на десктопе, начните там новую сессию."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "接续后该会话上下文绑定到手机。若想在桌面继续工作,请在桌面开启新会话。"
          }
        }
      }
    },
    "외부 서비스나 클라우드 중계 없이, iPhone 의 Tor 가 Mac 의 Tor hidden service 에 3-hop 회로를 빌드해서 직접 연결합니다. 모든 요청은 onion routing 으로 암호화되어 전달됩니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بدون أي خدمة خارجية أو وسيط سحابي، تبني نسخة Tor على iPhone دائرة بثلاث قفزات إلى Tor hidden service على Mac وتتصل مباشرة. كل الطلبات تُمرَّر مشفّرة عبر onion routing."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "With no external service or cloud relay, the Tor instance on your iPhone builds a 3-hop circuit straight to the Tor hidden service on your Mac. All requests are passed through onion-routed encryption."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sin servicios externos ni relés en la nube, el Tor del iPhone construye un circuito de 3 saltos directamente al hidden service de Tor en el Mac. Todas las peticiones pasan cifradas por onion routing."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sans service externe ni relais cloud, le Tor de l’iPhone construit un circuit à 3 sauts directement vers le service caché Tor du Mac. Toutes les requêtes passent par le chiffrement onion."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बिना किसी बाहरी सेवा या क्लाउड रिले के, iPhone का Tor सीधे Mac के Tor hidden service तक 3-हॉप सर्किट बनाता है। सभी अनुरोध onion routing से एन्क्रिप्टेड पास होते हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "外部サービスやクラウド中継を一切介さず、iPhone の Tor が Mac の Tor hidden service へ 3 ホップの回路を構築して直接接続します。すべてのリクエストは onion routing による暗号化越しに送られます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "외부 서비스나 클라우드 중계 없이, iPhone 의 Tor 가 Mac 의 Tor hidden service 에 3-hop 회로를 빌드해서 직접 연결합니다. 모든 요청은 onion routing 으로 암호화되어 전달됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sem nenhum serviço externo ou retransmissor em nuvem, o Tor no iPhone monta um circuito de 3 saltos direto até o Tor hidden service no Mac. Todas as requisições passam criptografadas por onion routing."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Без внешних сервисов и облачных ретрансляторов Tor на iPhone строит 3-узловую цепь прямо к Tor hidden service на Mac. Все запросы идут через onion-шифрование."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无任何外部服务或云中继,iPhone 上的 Tor 直接建立 3 跳线路连接 Mac 上的 Tor hidden service。所有请求都经过 onion routing 加密传输。"
          }
        }
      }
    },
    "회로 빌드: 앱 첫 부팅 / 백그라운드 복귀 시 새 회로를 짜는 데 보통 5–30초 걸립니다. 이 시간 동안 «회로 빌드 중…» 또는 «회로 빌드 ~30초» 표시가 보입니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بناء الدائرة: عند أول إقلاع للتطبيق أو العودة من الخلفية، يستغرق بناء الدائرة عادةً 5–30 ثانية. خلال هذا الوقت يظهر «جارٍ بناء الدائرة…» أو «بناء الدائرة ~30 ثانية»."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Circuit build: building a new circuit on first launch / when coming back from background usually takes 5–30 s. During that, you’ll see “Building encrypted circuit…” or “Tor circuit build ~30 s”."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Construcción del circuito: levantar un circuito nuevo en el primer arranque o al volver del fondo suele tardar 5–30 s. Verás «Construyendo circuito cifrado…» o «construcción de circuito Tor ~30 s»."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Construction du circuit : créer un nouveau circuit au premier lancement / au retour du second plan prend en général 5–30 s. Vous verrez « Construction du circuit chiffré… » ou « construction du circuit Tor ~30 s »."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सर्किट निर्माण: पहली बार ऐप खोलने / बैकग्राउंड से लौटने पर नया सर्किट बनाने में आम तौर पर 5–30 सेकंड लगते हैं। इस दौरान «एन्क्रिप्टेड सर्किट बनाया जा रहा है…» या «Tor सर्किट निर्माण ~30 सेकंड» दिखेगा।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "回路構築: アプリ初回起動時やバックグラウンドからの復帰時、新しい回路の構築には通常 5〜30 秒かかります。その間「暗号化回路を構築中…」または「Tor 回路構築 約 30 秒」が表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "회로 빌드: 앱 첫 부팅 / 백그라운드 복귀 시 새 회로를 짜는 데 보통 5–30초 걸립니다. 이 시간 동안 «회로 빌드 중…» 또는 «회로 빌드 ~30초» 표시가 보입니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Construção do circuito: montar um circuito novo na primeira inicialização / ao voltar do segundo plano costuma levar 5–30 s. Nesse tempo aparece «Construindo circuito criptografado…» ou «construção do circuito Tor ~30 s»."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Построение цепи: при первом запуске / возврате из фона новая цепь обычно строится 5–30 с. В это время видно «Построение зашифрованной цепи…» или «построение цепи Tor ~30 с»."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "线路构建:首次启动 / 从后台回到前台时,构建新线路通常需要 5–30 秒。期间会显示「正在建立加密线路…」或「Tor 线路构建约 30 秒」。"
          }
        }
      }
    },
    "백그라운드 끊김: iOS 는 백그라운드에서 일정 시간이 지나면 앱의 소켓을 닫습니다. 돌아왔을 때 «연결이 끊겼어요» 가 뜨면 정상 동작이고, 한 번 회복해주면 됩니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "انقطاع الخلفية: يقوم iOS بإغلاق منافذ التطبيق بعد فترة في الخلفية. ظهور «انقطع الاتصال» عند العودة سلوك متوقّع — يكفي استعادة الاتصال مرة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Background drop: iOS closes the app’s sockets after a while in the background. Seeing “Disconnected” on return is expected — just recover once."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Caída en segundo plano: iOS cierra los sockets de la app tras un tiempo en segundo plano. Que aparezca «Conexión perdida» al volver es normal — basta con recuperar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Coupure en arrière-plan : iOS ferme les sockets de l’app après un certain temps en arrière-plan. Voir « Connexion interrompue » au retour est normal — il suffit de récupérer."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बैकग्राउंड में कटाव: iOS कुछ समय बाद ऐप के सॉकेट बंद कर देता है। लौटने पर «कनेक्शन टूट गया» दिखना सामान्य है — एक बार रिकवर कर लें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "バックグラウンド切断: iOS は一定時間バックグラウンドに入ると、アプリのソケットを閉じます。復帰時に「接続が切れました」と出るのは正常な動作で、一度復帰させればよいだけです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "백그라운드 끊김: iOS 는 백그라운드에서 일정 시간이 지나면 앱의 소켓을 닫습니다. 돌아왔을 때 «연결이 끊겼어요» 가 뜨면 정상 동작이고, 한 번 회복해주면 됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Queda em segundo plano: o iOS fecha os sockets do app após um tempo em segundo plano. Ver «Conexão perdida» ao retornar é normal — basta recuperar uma vez."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Обрыв в фоне: iOS закрывает сокеты приложения после времени в фоне. «Соединение прервано» при возврате — это нормально, нужно лишь восстановить один раз."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "后台断开:iOS 在后台一段时间后会关闭应用的套接字。返回时看到「连接已断开」是正常现象,恢复一次即可。"
          }
        }
      }
    },
    "회복 순서 (가벼운 것부터):": {
      "extractionState": "manual",
      "localizations": {
