    "두 번째 기기 허용": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "السماح بجهاز ثانٍ"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Allow a second device"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Permitir un segundo dispositivo"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Autoriser un deuxième appareil"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "दूसरा डिवाइस अनुमत करें"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "2 台目の端末を許可"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "두 번째 기기 허용"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Permitir um segundo dispositivo"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Разрешить второе устройство"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "允许第二台设备"
          }
        }
      }
    },
    "켜면 기기를 최대 %lld대까지 연결할 수 있어요. 끄려면 먼저 기기를 한 대만 남겨 두세요.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند التفعيل، يمكنك توصيل ما يصل إلى %lld أجهزة. لإيقافه، اترك جهازًا واحدًا فقط أولًا."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When on, you can connect up to %lld devices. To turn it off, first leave only one device."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Al activarlo, puedes conectar hasta %lld dispositivos. Para desactivarlo, deja primero solo un dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une fois activé, vous pouvez connecter jusqu'à %lld appareils. Pour le désactiver, ne laissez d'abord qu'un seul appareil."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चालू होने पर आप %lld डिवाइस तक कनेक्ट कर सकते हैं। बंद करने के लिए, पहले केवल एक डिवाइस छोड़ें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オンにすると、最大 %lld 台の端末を接続できます。オフにするには、まず端末を 1 台だけにしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "켜면 기기를 최대 %lld대까지 연결할 수 있어요. 끄려면 먼저 기기를 한 대만 남겨 두세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando ativado, você pode conectar até %lld dispositivos. Para desativar, deixe primeiro apenas um dispositivo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Когда включено, можно подключить до %lld устройств. Чтобы выключить, сначала оставьте только одно устройство."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启后最多可连接 %lld 台设备。要关闭，请先只保留一台设备。"
          }
        }
      }
    },
    "현재 %lld대 연결됨": {
