    "아직 기기 인증이 설정되지 않았어요": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يتم إعداد مصادقة الجهاز بعد"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Device authentication isn't set up yet"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La autenticación del dispositivo aún no está configurada"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'authentification de l'appareil n'est pas encore configurée"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डिवाइस प्रमाणीकरण अभी सेट नहीं हुआ है"
          }
        },
        "ja": {
          "stringUnit": {
