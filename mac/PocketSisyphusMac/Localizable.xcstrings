            "state": "translated",
            "value": "Error al cambiar el ajuste: %@"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec de la modification du réglage : %@"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
