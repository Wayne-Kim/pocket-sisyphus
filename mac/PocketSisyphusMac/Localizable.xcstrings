    },
    "시스템으로 되돌리기: «시스템 언어 사용» 을 고르면 앱 전용 override 가 해제되고 OS 설정의 언어 우선순위를 그대로 따라갑니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "العودة إلى النظام: عند اختيار «Use system language» يُلغى الـ override الخاص بالتطبيق ويتبع التطبيق ترتيب لغات إعدادات النظام كما هو."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reverting to system: choosing “Use system language” clears the app-specific override and falls back to the OS-level language priority order as-is."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Volver al sistema: al elegir «Usar idioma del sistema» se elimina el override específico de la app y se sigue tal cual el orden de prioridad de idiomas del sistema."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Retour au système : choisir « Utiliser la langue du système » supprime le réglage propre à l’app et l’app suit alors l’ordre de priorité des langues du système tel quel."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सिस्टम पर लौटाना: «सिस्टम भाषा का उपयोग करें» चुनने पर ऐप-विशिष्ट override हट जाता है और OS की भाषा प्राथमिकता क्रम का पालन होता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "システムに戻す: 「システム言語を使用」を選ぶとアプリ専用の override が解除され、OS 設定の言語優先順位にそのまま従います。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Voltar ao sistema: ao escolher «Usar idioma do sistema» o override específico do app é removido e ele passa a seguir a ordem de prioridade de idiomas do OS."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Возврат к системному: при выборе «Использовать язык системы» переопределение для приложения снимается, и оно следует системному порядку приоритета языков как есть."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "回到系统设置：选择「使用系统语言」后会清除应用级覆盖，按 OS 设置中的语言优先级照常生效。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시스템으로 되돌리기: «시스템 언어 사용» 을 고르면 앱 전용 override 가 해제되고 OS 설정의 언어 우선순위를 그대로 따라갑니다."
          }
        }
      }
    },
    "Tor fallback — iPhone Pocket Sisyphus → 디바이스 내 Tor → 인터넷 (onion routing 3-hop) → 이 Mac 의 Tor hidden service → 임베디드 sshd → 데스크탑 앱 → 코드 에이전트 CLI → 각 에이전트의 모델 제공자 API.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor fallback — iPhone Pocket Sisyphus → Tor داخل الجهاز → الإنترنت (onion routing بثلاث قفزات) → Tor hidden service على هذا الـ Mac → sshd المضمّن → تطبيق سطح المكتب → CLI وكيل الكود → واجهة مزود نموذج كل وكيل."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor fallback — iPhone Pocket Sisyphus → on-device Tor → Internet (3-hop onion routing) → this Mac’s Tor hidden service → embedded sshd → desktop app → code-agent CLI → each agent’s model-provider API."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Fallback Tor — iPhone Pocket Sisyphus → Tor en el dispositivo → Internet (onion routing de 3 saltos) → Tor hidden service de este Mac → sshd embebido → app de escritorio → CLI del agente de código → API del proveedor de modelo de cada agente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Fallback Tor — iPhone Pocket Sisyphus → Tor sur l’appareil → Internet (onion routing à 3 sauts) → Tor hidden service de ce Mac → sshd embarqué → app de bureau → CLI d’agent de code → API du fournisseur de modèle de chaque agent."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor fallback — iPhone Pocket Sisyphus → डिवाइस का Tor → इंटरनेट (3-hop onion routing) → इस Mac का Tor hidden service → एम्बेडेड sshd → डेस्कटॉप ऐप → कोड-एजेंट CLI → हर एजेंट के मॉडल प्रदाता का API।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor fallback — iPhone Pocket Sisyphus → デバイス内 Tor → インターネット (onion routing 3-hop) → この Mac の Tor hidden service → 組み込み sshd → デスクトップアプリ → コードエージェント CLI → 各エージェントのモデルプロバイダ API。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Fallback Tor — iPhone Pocket Sisyphus → Tor no dispositivo → Internet (onion routing de 3 hops) → Tor hidden service deste Mac → sshd embutido → app de desktop → CLI de agente de código → API do provedor de modelo de cada agente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor fallback — iPhone Pocket Sisyphus → Tor на устройстве → Интернет (onion routing 3-hop) → Tor hidden service этого Mac → встроенный sshd → десктоп-приложение → CLI код-агента → API провайдера модели каждого агента."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor fallback — iPhone Pocket Sisyphus → 设备内 Tor → 互联网（3 跳 onion routing）→ 本 Mac 的 Tor hidden service → 内嵌 sshd → 桌面应用 → 代码代理 CLI → 各代理对应的模型提供方 API。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor fallback — iPhone Pocket Sisyphus → 디바이스 내 Tor → 인터넷 (onion routing 3-hop) → 이 Mac 의 Tor hidden service → 임베디드 sshd → 데스크탑 앱 → 코드 에이전트 CLI → 각 에이전트의 모델 제공자 API."
          }
        }
      }
    },
    "직접 SSH (1차) — iPhone Pocket Sisyphus → 디바이스 → 공유기 → 이 Mac 의 임베디드 sshd (포트 22022) → 데스크탑 앱 → 코드 에이전트 CLI → 각 에이전트의 모델 제공자 API.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "SSH المباشر (الأساسي) — iPhone Pocket Sisyphus → الجهاز → الموجّه → sshd المضمّن في هذا الـ Mac (المنفذ 22022) → تطبيق سطح المكتب → CLI وكيل الكود → واجهة مزود نموذج كل وكيل."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Direct SSH (primary) — iPhone Pocket Sisyphus → device → router → this Mac’s embedded sshd (port 22022) → desktop app → code-agent CLI → each agent’s model-provider API."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "SSH directo (primario) — iPhone Pocket Sisyphus → dispositivo → router → sshd embebido de este Mac (puerto 22022) → app de escritorio → CLI del agente de código → API del proveedor de modelo de cada agente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "SSH direct (principal) — iPhone Pocket Sisyphus → appareil → routeur → sshd embarqué de ce Mac (port 22022) → app de bureau → CLI d’agent de code → API du fournisseur de modèle de chaque agent."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सीधा SSH (प्राथमिक) — iPhone Pocket Sisyphus → डिवाइस → राउटर → इस Mac का एम्बेडेड sshd (पोर्ट 22022) → डेस्कटॉप ऐप → कोड-एजेंट CLI → हर एजेंट के मॉडल प्रदाता का API।"
          }
        },
        "ja": {
          "stringUnit": {
