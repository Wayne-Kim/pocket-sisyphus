    "1024–65535 사이의 숫자를 입력하세요 (데몬·SSH 둘 다)": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أدخل رقمًا بين 1024 و65535 (للخادم وSSH معًا)"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enter a number between 1024 and 65535 (for both daemon and SSH)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Introduce un número entre 1024 y 65535 (tanto daemon como SSH)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Saisissez un nombre entre 1024 et 65535 (pour le daemon et le SSH)"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "1024 से 65535 के बीच की संख्या दर्ज करें (डेमन और SSH दोनों के लिए)"
          }
        },
        "ja": {
          "stringUnit": {
