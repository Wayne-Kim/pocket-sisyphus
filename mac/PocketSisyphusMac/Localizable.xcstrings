    "‘%@’ 의 실행 기록이 함께 삭제됩니다. 되돌릴 수 없습니다.": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "‘%@’ 의 실행 기록이 함께 삭제됩니다. 되돌릴 수 없습니다."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The run history of ‘%@’ will also be deleted. This cannot be undone."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "‘%@’ 的运行记录将一并删除。此操作无法撤销。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "‘%@’ का रन इतिहास भी हटा दिया जाएगा। इसे पूर्ववत नहीं किया जा सकता।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "También se eliminará el historial de ejecución de ‘%@’. No se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’historique d’exécution de ‘%@’ sera également supprimé. Cette action est irréversible."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيتم أيضًا حذف سجل تنفيذ ‘%@’. لا يمكن التراجع عن ذلك."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O histórico de execução de ‘%@’ também será excluído. Isto não pode ser desfeito."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "История выполнения «%@» также будет удалена. Это действие необратимо."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "‘%@’ の実行履歴も一緒に削除されます。元に戻せません。"
          }
        }
      }
    },
