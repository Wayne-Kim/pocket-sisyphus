          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Введите число от 1024 до 65535 (и для демона, и для SSH)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请输入 1024–65535 之间的数字（守护进程和 SSH 都要）"
          }
        }
      }
    },
    "데몬 포트와 SSH 포트는 서로 달라야 해요": {
