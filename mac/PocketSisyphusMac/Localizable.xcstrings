          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Стартовый шаблон, последовательно связывающий специализированных по ролям агентов. После создания его можно отредактировать на холсте."
          }
        },
        "zh-Hans": {
