    "폰에서 연 세션이 아직 없습니다": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "폰에서 연 세션이 아직 없습니다"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No sessions opened from your phone yet"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "尚未从手机打开任何会话"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फ़ोन से खोला गया कोई सत्र अभी तक नहीं"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no hay sesiones abiertas desde el teléfono"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucune session ouverte depuis le téléphone pour l’instant"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا توجد جلسات مفتوحة من هاتفك بعد"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhuma sessão aberta pelo telefone ainda"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пока нет сессий, открытых с телефона"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スマホで開いたセッションはまだありません"
          }
        }
      }
    },
    "폰(iOS)에서 세션을 열면 여기 목록에 나타납니다.": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "폰(iOS)에서 세션을 열면 여기 목록에 나타납니다."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sessions you open on your phone (iOS) appear in this list."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在手机 (iOS) 上打开的会话会显示在此列表中。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपके फ़ोन (iOS) पर खोले गए सत्र इस सूची में दिखाई देते हैं।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las sesiones que abras en tu teléfono (iOS) aparecen en esta lista."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les sessions que vous ouvrez sur votre téléphone (iOS) apparaissent dans cette liste."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تظهر الجلسات التي تفتحها على هاتفك (iOS) في هذه القائمة."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As sessões que você abre no telefone (iOS) aparecem nesta lista."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сессии, открытые на телефоне (iOS), появляются в этом списке."
