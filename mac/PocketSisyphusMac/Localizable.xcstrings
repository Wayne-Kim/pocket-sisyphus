    "허용된 것으로 보여요": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "허용된 것으로 보여요"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Looks granted"
          }
        },
        "es": {
