    "맥에서 작업이 끝나거나 입력이 필요할 때 Discord 로 알려드려요.": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "맥에서 작업이 끝나거나 입력이 필요할 때 Discord 로 알려드려요."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Get a Discord ping when work finishes on your Mac or needs your input."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac で作業が終わったり入力が必要になったら Discord でお知らせします。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当 Mac 上的任务完成或需要你输入时，通过 Discord 通知你。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Recibe un aviso en Discord cuando el trabajo en tu Mac termine o necesite tu intervención."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Recevez une alerte Discord quand une tâche se termine sur votre Mac ou attend votre réponse."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Receba um aviso no Discord quando o trabalho no seu Mac terminar ou precisar de você."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Получайте уведомление в Discord, когда работа на Mac завершится или потребуется ваш ввод."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "احصل على تنبيه في Discord عند انتهاء العمل على Mac أو عند الحاجة إلى إدخالك."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जब आपके Mac पर काम पूरा हो या आपके इनपुट की ज़रूरत हो, तो Discord पर सूचना पाएं।"
          }
        }
      }
    },
    "외부 서버 없이, 당신의 Discord 웹후크로 직접 보냅니다.": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "외부 서버 없이, 당신의 Discord 웹후크로 직접 보냅니다."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No external server — sent straight to your own Discord webhook."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "外部サーバーなし — あなた自身の Discord ウェブフックに直接送ります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无需外部服务器 — 直接发送到你自己的 Discord webhook。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sin servidor externo: se envía directamente a tu propio webhook de Discord."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun serveur externe — envoyé directement vers votre propre webhook Discord."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sem servidor externo — enviado direto para o seu próprio webhook do Discord."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Без внешнего сервера — отправляется прямо в ваш собственный вебхук Discord."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
