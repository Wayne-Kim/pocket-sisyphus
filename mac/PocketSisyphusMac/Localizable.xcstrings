    "QR이 안 갱신되면 daemon 재시작 (메뉴바 → 재시작)": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إذا لم يتم تحديث رمز QR، أعد تشغيل daemon (شريط القوائم → إعادة التشغيل)"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If the QR doesn’t refresh, restart the daemon (menu bar → Restart)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si el QR no se actualiza, reinicia el daemon (barra de menús → Reiniciar)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si le QR ne se met pas à jour, redémarrez le daemon (barre de menus → Redémarrer)"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अगर QR रिफ़्रेश न हो तो daemon पुनः आरंभ करें (मेनू बार → पुनः आरंभ)"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "QR が更新されないときは daemon を再起動してください（メニューバー → 再起動）"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
