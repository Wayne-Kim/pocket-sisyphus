    "저장된 키 사용 중 — 바꿀 때만 선택하세요": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يُستخدم المفتاح المحفوظ — اختر ملفًا فقط عند الاستبدال"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Using the saved key — choose a file only to replace it"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usando la clave guardada: elige un archivo solo para reemplazarla"
          }
        },
        "fr": {
