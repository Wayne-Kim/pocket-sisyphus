    "모두 해제": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إلغاء الكل"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Release all"
          }
        },
        "es": {
