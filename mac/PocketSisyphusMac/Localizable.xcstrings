    "시스템 설정에서 권한 열기": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시스템 설정에서 권한 열기"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open in System Settings"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abrir en Ajustes del Sistema"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouvrir dans Réglages Système"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सिस्टम सेटिंग्स में खोलें"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "システム設定で開く"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Abrir nos Ajustes do Sistema"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Открыть в Системных настройках"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在系统设置中打开"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "افتح في إعدادات النظام"
          }
        }
      }
    },
    "시스템 설정 › 개인정보 보호 및 보안 › 전체 디스크 접근에서 Pocket Sisyphus 를 켜고 앱으로 돌아오면 적용됩니다.": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시스템 설정 › 개인정보 보호 및 보안 › 전체 디스크 접근에서 Pocket Sisyphus 를 켜고 앱으로 돌아오면 적용됩니다."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "In System Settings › Privacy & Security › Full Disk Access, turn on Pocket Sisyphus, then return to the app to apply."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "En Ajustes del Sistema › Privacidad y seguridad › Acceso completo al disco, activa Pocket Sisyphus y vuelve a la app para aplicarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dans Réglages Système › Confidentialité et sécurité › Accès complet au disque, activez Pocket Sisyphus, puis revenez à l'app pour appliquer."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सिस्टम सेटिंग्स › प्राइवेसी और सुरक्षा › पूर्ण डिस्क एक्सेस में Pocket Sisyphus चालू करें, फिर लागू करने के लिए ऐप पर लौटें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "システム設定 › プライバシーとセキュリティ › フルディスクアクセスで Pocket Sisyphus をオンにし、アプリに戻ると適用されます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Em Ajustes do Sistema › Privacidade e Segurança › Acesso total ao disco, ative o Pocket Sisyphus e volte ao app para aplicar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "В Системных настройках › Конфиденциальность и безопасность › Полный доступ к диску включите Pocket Sisyphus и вернитесь в приложение, чтобы применить."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在系统设置 › 隐私与安全性 › 完全磁盘访问权限中开启 Pocket Sisyphus，然后返回应用即可生效。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "في إعدادات النظام › الخصوصية والأمان › الوصول الكامل إلى القرص، فعّل Pocket Sisyphus ثم عُد إلى التطبيق ليُطبَّق."
          }
        }
      }
    },
    "앱 화면 언어를 고릅니다. 선택하면 앱을 재시작해 적용해요.": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "앱 화면 언어를 고릅니다. 선택하면 앱을 재시작해 적용해요."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose the app's display language. Selecting one restarts the app to apply."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige el idioma de la app. Al seleccionarlo, la app se reinicia para aplicarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez la langue de l'app. La sélection redémarre l'app pour l'appliquer."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ऐप की भाषा चुनें। चुनने पर लागू करने के लिए ऐप पुनः आरंभ होगा।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アプリの表示言語を選びます。選択するとアプリを再起動して適用します。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha o idioma do app. Ao selecionar, o app reinicia para aplicar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите язык приложения. После выбора приложение перезапустится для применения."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择应用显示语言。选择后将重启应用以生效。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر لغة عرض التطبيق. عند الاختيار سيُعاد تشغيل التطبيق للتطبيق."
          }
        }
      }
    },
    "로컬에서 도는 코드 에이전트 모델을 받아 관리해요.": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로컬에서 도는 코드 에이전트 모델을 받아 관리해요."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Download and manage the code-agent models that run locally."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Descarga y gestiona los modelos de agente de código que se ejecutan localmente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Téléchargez et gérez les modèles d'agent de code qui s'exécutent en local."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्थानीय रूप से चलने वाले कोड-एजेंट मॉडल डाउनलोड और प्रबंधित करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ローカルで動くコードエージェントのモデルをダウンロードして管理します。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Baixe e gerencie os modelos de agente de código que rodam localmente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Загружайте и управляйте моделями код-агента, работающими локально."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "下载并管理在本地运行的代码智能体模型。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "نزّل وأدِر نماذج وكيل البرمجة التي تعمل محليًا."
          }
        }
      }
    },
