    "적어두면 「검증」 이 이 앱의 리뷰 읽기 권한까지 확인해요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إذا أدخلته، يتحقق «تحقق» أيضًا من إذن قراءة مراجعات هذا التطبيق."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If set, Verify also checks permission to read this app's reviews."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si lo indicas, «Verificar» también comprueba el permiso para leer las reseñas de esta app."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si renseigné, « Vérifier » contrôle aussi l'autorisation de lire les avis de cette app."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "लिखने पर «सत्यापित करें» इस ऐप की समीक्षाएँ पढ़ने की अनुमति भी जाँचता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "入力しておくと「検証」がこのアプリのレビュー読み取り権限まで確認します。"
