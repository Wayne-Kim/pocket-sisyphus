          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Готово — Универсальный доступ разрешён (ввод работает)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正常 — 辅助功能已受信任（可注入输入）"
          }
        }
      }
    },
    "신뢰되지 않음 — 손쉬운 사용에서 켜 주세요": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "غير موثوق — فعّله من تسهيلات الاستخدام"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Not trusted — please enable it under Accessibility"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sin confianza: actívalo en Accesibilidad"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
