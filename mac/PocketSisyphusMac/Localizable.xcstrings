    "폰이 맥에 붙을 때 쓰는 포트. 잘 모르겠으면 그대로 두세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "المنفذ الذي يستخدمه هاتفك للوصول إلى الـ Mac. اتركه كما هو إذا لم تكن متأكدًا."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The port your phone uses to reach the Mac. Leave it as-is if unsure."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El puerto que usa tu teléfono para conectar con el Mac. Si no estás seguro, déjalo igual."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le port que votre téléphone utilise pour atteindre le Mac. Dans le doute, laissez-le tel quel."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वह पोर्ट जिससे आपका फ़ोन Mac तक पहुँचता है। संदेह हो तो वैसा ही रहने दें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スマホが Mac に接続するときに使うポート。よく分からなければそのままにしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "폰이 맥에 붙을 때 쓰는 포트. 잘 모르겠으면 그대로 두세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A porta que seu telefone usa para acessar o Mac. Na dúvida, deixe como está."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Порт, через который телефон подключается к Mac. Если не уверены, оставьте как есть."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "手机连接 Mac 时使用的端口。不确定就保持不变。"
          }
        }
      }
    },
