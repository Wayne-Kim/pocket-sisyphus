            "state": "translated",
            "value": "Screen mirroring"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Duplicación de pantalla"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Recopie de l’écran"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्क्रीन मिररिंग"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "画面ミラーリング"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모니터 미러링"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Espelhamento de tela"
          }
        },
