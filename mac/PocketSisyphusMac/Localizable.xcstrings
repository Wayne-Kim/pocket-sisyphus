    "모든 기기 해제 + 새 QR": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إلغاء جميع الأجهزة + رمز QR جديد"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Release all devices + new QR"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Revocar todos + nuevo QR"
          }
        },
        "fr": {
