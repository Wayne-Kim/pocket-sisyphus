    "터미널 도구는 이 내용을 그대로 실행해요. 스크립트 파일을 고르거나 명령을 직접 작성하세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تقوم أداة Terminal بتشغيل هذا كما هو. اختر ملف برنامج نصي أو اكتب الأمر بنفسك."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Terminal tool runs this as-is. Choose a script file or write the command yourself."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La herramienta Terminal ejecuta esto tal cual. Elige un archivo de script o escribe el comando."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'outil Terminal exécute ceci tel quel. Choisissez un fichier de script ou écrivez la commande."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "टर्मिनल टूल इसे ज्यों-का-त्यों चलाता है। स्क्रिप्ट फ़ाइल चुनें या कमांड स्वयं लिखें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ターミナルツールはこの内容をそのまま実行します。スクリプトファイルを選ぶか、コマンドを直接記述してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "터미널 도구는 이 내용을 그대로 실행해요. 스크립트 파일을 고르거나 명령을 직접 작성하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A ferramenta Terminal executa isto como está. Escolha um arquivo de script ou escreva o comando."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Инструмент «Терминал» выполняет это как есть. Выберите файл скрипта или напишите команду."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "终端工具会原样运行此内容。请选择脚本文件，或直接编写命令。"
          }
        }
      }
    },
