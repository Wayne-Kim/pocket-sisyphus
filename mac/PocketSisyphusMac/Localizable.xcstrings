            "value": "डिज़ाइन नियम घोषित करें"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デザインルールの宣言"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "디자인 규칙 선언"
          }
        },
