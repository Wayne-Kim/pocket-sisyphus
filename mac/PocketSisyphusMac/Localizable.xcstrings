    "Bearer 토큰 — iPhone 의 UserDefaults (단일 디바이스 사용 가정).": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "رمز Bearer — في UserDefaults على iPhone (افتراض الاستخدام من جهاز واحد)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bearer token — in iPhone UserDefaults (assumes single-device use)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Token Bearer — en UserDefaults del iPhone (asumiendo uso en un solo dispositivo)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeton Bearer — dans UserDefaults sur iPhone (utilisation sur un seul appareil supposée)."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bearer टोकन — iPhone के UserDefaults में (एकल डिवाइस उपयोग मानते हुए)।"
          }
        },
        "ja": {
          "stringUnit": {
