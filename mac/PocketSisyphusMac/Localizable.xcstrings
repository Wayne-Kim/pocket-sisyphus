    "맥 안에서만 쓰는 포트. 충돌하면 자동으로 빈 포트를 찾아 써요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "منفذ يُستخدم داخل الـ Mac فقط. إذا تعارض، يُبحث عن منفذ متاح تلقائيًا."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Used only inside the Mac. If it clashes, a free port is found automatically."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puerto usado solo dentro del Mac. Si choca, se busca un puerto libre automáticamente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Port utilisé uniquement à l'intérieur du Mac. En cas de conflit, un port libre est trouvé automatiquement."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "केवल Mac के भीतर उपयोग होने वाला पोर्ट। टकराव होने पर अपने आप खाली पोर्ट ढूँढ़ लिया जाता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac 内部だけで使うポート。競合すると空きポートを自動で探します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "맥 안에서만 쓰는 포트. 충돌하면 자동으로 빈 포트를 찾아 써요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Porta usada apenas dentro do Mac. Se houver conflito, uma porta livre é encontrada automaticamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Порт используется только внутри Mac. При конфликте свободный порт находится автоматически."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅在 Mac 内部使用的端口。冲突时会自动寻找空闲端口。"
          }
        }
      }
    },
