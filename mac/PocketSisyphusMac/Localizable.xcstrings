    "검토하고 필요하면 고친 뒤 «승인» 하면 수집·리서치가 이 규칙을 강한 신호로 따라요. 승인 전엔 적용되지 않아요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "راجعها، وعدّلها إذا لزم الأمر، ثم اضغط «اعتماد» — ستتبع عمليات الجمع والبحث هذه القواعد كإشارة قوية. لا يُطبَّق أي شيء قبل اعتمادك."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Review it, edit if needed, then Approve — collection and research will follow these rules as a strong signal. Nothing is applied before you approve."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Revísalo, edítalo si hace falta y pulsa «Aprobar»: la recopilación y la investigación seguirán estas reglas como señal fuerte. No se aplica nada antes de que apruebes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Relisez-le, modifiez-le si nécessaire, puis appuyez sur « Approuver » : la collecte et la recherche suivront ces règles comme un signal fort. Rien n'est appliqué avant votre approbation."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इसकी समीक्षा करें, ज़रूरत हो तो संपादित करें, फिर «स्वीकृत करें» — संग्रह और शोध इन नियमों को एक मज़बूत संकेत के रूप में मानेंगे। स्वीकृति से पहले कुछ भी लागू नहीं होता।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "確認し、必要なら修正してから「承認」すると、収集・リサーチがこのルールを強いシグナルとして従います。承認前は適用されません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "검토하고 필요하면 고친 뒤 «승인» 하면 수집·리서치가 이 규칙을 강한 신호로 따라요. 승인 전엔 적용되지 않아요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Revise, edite se necessário e clique em «Aprovar» — a coleta e a pesquisa seguirão essas regras como sinal forte. Nada é aplicado antes de você aprovar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Просмотрите его, при необходимости отредактируйте и нажмите «Утвердить» — сбор и исследование будут следовать этим правилам как сильному сигналу. До утверждения ничего не применяется."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请审阅，必要时修改后点击“批准”——收集和调研会将这些规则作为强信号遵循。批准前不会应用。"
          }
        }
      }
    },
    "승인하고 켜기": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
