    "해제하면 현재 폰의 인증이 무효화되고 새 페어링 QR 이 생성돼요. 다시 쓰려면 폰에서 새 QR 을 스캔해야 합니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يؤدي الإلغاء إلى إبطال مصادقة الهاتف الحالي وإنشاء رمز QR جديد للإقران. لاستخدامه مجددًا، امسح رمز QR الجديد على هاتفك."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Releasing invalidates the current phone's authentication and generates a new pairing QR. To use it again, scan the new QR on your phone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Revocar invalida la autenticación del teléfono actual y genera un nuevo QR de emparejamiento. Para volver a usarlo, escanea el nuevo QR en tu teléfono."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La révocation invalide l'authentification du téléphone actuel et génère un nouveau QR d'association. Pour le réutiliser, scannez le nouveau QR sur votre téléphone."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हटाने से मौजूदा फ़ोन का प्रमाणीकरण अमान्य हो जाता है और एक नया पेयरिंग QR बनता है। दोबारा उपयोग के लिए, अपने फ़ोन पर नया QR स्कैन करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "解除すると現在の端末の認証が無効になり、新しいペアリング QR が生成されます。再び使うには、端末で新しい QR をスキャンしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "해제하면 현재 폰의 인증이 무효화되고 새 페어링 QR 이 생성돼요. 다시 쓰려면 폰에서 새 QR 을 스캔해야 합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Revogar invalida a autenticação do telefone atual e gera um novo QR de emparelhamento. Para usar novamente, escaneie o novo QR no seu telefone."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отзыв аннулирует аутентификацию текущего телефона и создаёт новый QR-код сопряжения. Чтобы снова им пользоваться, отсканируйте новый QR-код на телефоне."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "解除会使当前手机的认证失效并生成新的配对二维码。如需再次使用，请在手机上扫描新的二维码。"
          }
        }
      }
    },
    "기기 정보를 불러오지 못했어요 — daemon 이 실행 중인지 확인하세요": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذّر تحميل معلومات الجهاز — تأكد من أن daemon قيد التشغيل"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't load device info — make sure the daemon is running"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo cargar la información del dispositivo: comprueba que el daemon esté en ejecución"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de charger les informations de l'appareil — vérifiez que le daemon est en cours d'exécution"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डिवाइस जानकारी लोड नहीं हो सकी — सुनिश्चित करें कि daemon चल रहा है"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバイス情報を読み込めませんでした — daemon が動作しているか確認してください"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기기 정보를 불러오지 못했어요 — daemon 이 실행 중인지 확인하세요"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível carregar as informações do dispositivo — verifique se o daemon está em execução"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось загрузить сведения об устройстве — убедитесь, что daemon запущен"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法加载设备信息 — 请确认 daemon 正在运行"
          }
        }
      }
    },
    "해제됐어요 — 메뉴 › 페어링 QR 보기 의 새 QR 을 폰에서 다시 스캔하세요": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم الإلغاء — امسح رمز QR الجديد من القائمة › إظهار رمز QR للإقران على هاتفك"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Released — scan the new QR from Menu › Show Pairing QR on your phone"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Revocado: escanea el nuevo QR desde Menú › Mostrar QR de emparejamiento en tu teléfono"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Révoqué — scannez le nouveau QR depuis Menu › Afficher le QR d'association sur votre téléphone"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हटा दिया गया — मेनू › पेयरिंग QR दिखाएँ से नया QR अपने फ़ोन पर स्कैन करें"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "解除しました — メニュー › ペアリング QR を表示 の新しい QR を端末でスキャンしてください"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "해제됐어요 — 메뉴 › 페어링 QR 보기 의 새 QR 을 폰에서 다시 스캔하세요"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Revogado — escaneie o novo QR em Menu › Mostrar QR de emparelhamento no seu telefone"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отозвано — отсканируйте новый QR-код из Меню › Показать QR сопряжения на телефоне"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已解除 — 请在手机上扫描 菜单 › 显示配对二维码 中的新二维码"
          }
        }
