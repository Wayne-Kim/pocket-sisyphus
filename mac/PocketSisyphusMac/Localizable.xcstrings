    "포트가 뭔지 잘 모르겠다면": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا تعرف ما هو المنفذ؟"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Not sure what a port is?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿No sabes qué es un puerto?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous ne savez pas ce qu’est un port ?"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पोर्ट क्या है, यह नहीं पता?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ポートがよく分からない場合"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "포트가 뭔지 잘 모르겠다면"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não sabe o que é uma porta?"
          }
        },
