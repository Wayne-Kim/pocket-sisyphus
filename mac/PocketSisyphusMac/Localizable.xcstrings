    "모델 목록을 불러오지 못했어요 — daemon 이 실행 중인지 확인하세요": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모델 목록을 불러오지 못했어요 — daemon 이 실행 중인지 확인하세요"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't load the model list — check that the daemon is running."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo cargar la lista de modelos — comprueba que el daemon esté en ejecución."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de charger la liste des modèles — vérifiez que le daemon est en cours d'exécution."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मॉडल सूची लोड नहीं हो सकी — जाँचें कि daemon चल रहा है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "モデル一覧を読み込めませんでした — daemon が実行中か確認してください。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível carregar a lista de modelos — verifique se o daemon está em execução."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось загрузить список моделей — проверьте, запущен ли демон."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法加载模型列表 — 请确认 daemon 正在运行。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذّر تحميل قائمة النماذج — تأكد من أن الـ daemon قيد التشغيل."
          }
        }
      }
    },
    "디스크 공간이 부족해요 — 모델 크기 + 여유 10GB 가 필요해요": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "디스크 공간이 부족해요 — 모델 크기 + 여유 10GB 가 필요해요"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Not enough disk space — you need the model size plus 10 GB free."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay suficiente espacio en disco — necesitas el tamaño del modelo más 10 GB libres."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Espace disque insuffisant — il faut la taille du modèle plus 10 Go libres."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पर्याप्त डिस्क स्थान नहीं — मॉडल आकार के साथ 10 GB खाली चाहिए।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ディスク容量が足りません — モデルサイズ + 空き 10GB が必要です。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Espaço em disco insuficiente — você precisa do tamanho do modelo mais 10 GB livres."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Недостаточно места на диске — нужен размер модели плюс 10 ГБ свободно."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "磁盘空间不足 — 需要模型大小外加 10 GB 可用空间。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مساحة القرص غير كافية — تحتاج حجم النموذج بالإضافة إلى 10 غيغابايت متاحة."
          }
        }
      }
    },
    "이미 다른 모델을 받는 중이에요 — 끝난 뒤 다시 시도하세요": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이미 다른 모델을 받는 중이에요 — 끝난 뒤 다시 시도하세요"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Already downloading another model — try again when it finishes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ya se está descargando otro modelo — inténtalo de nuevo cuando termine."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un autre modèle est déjà en cours de téléchargement — réessayez une fois terminé."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पहले से ही दूसरा मॉडल डाउनलोड हो रहा है — समाप्त होने पर पुनः प्रयास करें।"
          }
        },
        "ja": {
