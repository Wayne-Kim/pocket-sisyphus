          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "更改设置失败：%@"
          }
        }
      }
    },
    "기기를 해제했어요.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم إلغاء الجهاز."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Device released."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dispositivo revocado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appareil révoqué."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डिवाइस रिलीज़ कर दिया गया।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "端末を解除しました。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기기를 해제했어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Dispositivo revogado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Устройство отозвано."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已解除该设备。"
          }
        }
      }
    },
    "모두 해제됐어요 — 메뉴 › 페어링 QR 보기 의 새 QR 을 폰에서 다시 스캔하세요": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم إلغاء الكل — امسح رمز QR الجديد من القائمة › عرض رمز QR للإقران على هاتفك"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All released — scan the new QR from Menu › Show Pairing QR on your phone"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todos revocados — escanea el nuevo QR en Menú › Mostrar QR de vinculación desde el teléfono"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tout révoqué — scannez le nouveau QR depuis Menu › Afficher le QR de jumelage sur votre téléphone"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सभी रिलीज़ — मेन्यू › पेयरिंग QR दिखाएँ का नया QR फ़ोन से स्कैन करें"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべて解除しました — メニュー › ペアリング QR を表示 の新しい QR をスマホで再スキャンしてください"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모두 해제됐어요 — 메뉴 › 페어링 QR 보기 의 새 QR 을 폰에서 다시 스캔하세요"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Todos revogados — escaneie o novo QR em Menu › Mostrar QR de pareamento pelo telefone"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Все отозваны — отсканируйте новый QR-код из Меню › Показать QR сопряжения на телефоне"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已全部解除 — 请在手机上扫描 菜单 › 显示配对二维码 中的新二维码"
          }
        }
      }
    },
    "기본은 한 대만 연결돼요. 두 번째 기기를 연결하려면 설정 → 「기기」 탭에서 «두 번째 기기 허용» 을 먼저 켜세요. (기기는 최대 두 대까지.)": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "افتراضيًا يتصل جهاز واحد فقط. لتوصيل جهاز ثانٍ، فعّل أولًا «السماح بجهاز ثانٍ» من الإعدادات ← الأجهزة. (حتى جهازين.)"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "By default only one device connects. To connect a second device, first turn on “Allow a second device” in Settings → Devices. (Up to two devices.)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "De forma predeterminada solo se conecta un dispositivo. Para conectar un segundo, activa primero «Permitir un segundo dispositivo» en Ajustes → Dispositivos. (Hasta dos dispositivos.)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Par défaut, un seul appareil se connecte. Pour connecter un deuxième appareil, activez d'abord « Autoriser un deuxième appareil » dans Réglages → Appareils. (Jusqu'à deux appareils.)"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डिफ़ॉल्ट रूप से केवल एक डिवाइस कनेक्ट होता है। दूसरा डिवाइस जोड़ने के लिए, पहले सेटिंग्स → डिवाइस में «दूसरा डिवाइस अनुमत करें» चालू करें। (अधिकतम दो डिवाइस।)"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "既定では 1 台のみ接続できます。2 台目の端末を接続するには、設定 →「端末」タブで «2 台目の端末を許可» を先にオンにしてください。（端末は最大 2 台まで。）"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기본은 한 대만 연결돼요. 두 번째 기기를 연결하려면 설정 → 「기기」 탭에서 «두 번째 기기 허용» 을 먼저 켜세요. (기기는 최대 두 대까지.)"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Por padrão, apenas um dispositivo se conecta. Para conectar um segundo, ative primeiro «Permitir um segundo dispositivo» em Configurações → Dispositivos. (Até dois dispositivos.)"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "По умолчанию подключается только одно устройство. Чтобы подключить второе, сначала включите «Разрешить второе устройство» в Настройках → Устройства. (До двух устройств.)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "默认仅连接一台设备。要连接第二台设备，请先在 设置 →「设备」选项卡中开启«允许第二台设备»。（最多两台设备。）"
          }
        }
      }
    },
    "캡처 헬퍼를 찾을 수 없어요(앱 번들 확인 필요)": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذّر العثور على مساعد الالتقاط (تحقق من حزمة التطبيق)"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Capture helper not found (check the app bundle)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se encontró el ayudante de captura (revisa el paquete de la app)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Assistant de capture introuvable (vérifiez le bundle de l’app)"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कैप्चर हेल्पर नहीं मिला (ऐप बंडल जांचें)"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キャプチャヘルパーが見つかりません（アプリバンドルを確認してください）"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "캡처 헬퍼를 찾을 수 없어요(앱 번들 확인 필요)"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Auxiliar de captura não encontrado (verifique o pacote do app)"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Помощник захвата не найден (проверьте бандл приложения)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "找不到捕获助手（请检查应用包）"
          }
        }
      }
    },
    "권한 상태를 확인하지 못했어요(헬퍼 응답 없음)": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذّر التحقق من حالة الإذن (لا استجابة من المساعد)"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn’t check permission status (no response from helper)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo comprobar el estado del permiso (sin respuesta del ayudante)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de vérifier l’état de l’autorisation (aucune réponse de l’assistant)"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अनुमति स्थिति जांची नहीं जा सकी (हेल्पर से कोई जवाब नहीं)"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "権限の状態を確認できませんでした（ヘルパーの応答なし）"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
