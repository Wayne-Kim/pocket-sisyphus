            "value": "Saved the ports and restarted the daemon (daemon %lld · SSH %lld)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se guardaron los puertos y se reinició el daemon (daemon %lld · SSH %lld)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ports enregistrés et daemon redémarré (daemon %lld · SSH %lld)"
