            "value": "1024〜65535 の数値を入力してください（デーモン・SSH 両方）"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "1024–65535 사이의 숫자를 입력하세요 (데몬·SSH 둘 다)"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
