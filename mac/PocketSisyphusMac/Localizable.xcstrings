          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Passos de recuperação (do mais leve):"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Шаги восстановления (от лёгких):"
          }
