    "디자인 상태를 불러오지 못했어요 — daemon 이 실행 중인지 확인하세요": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذّر تحميل حالة التصميم — تأكّد من أن daemon قيد التشغيل"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't load the design status — make sure the daemon is running"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo cargar el estado de diseño: comprueba que el daemon esté en ejecución"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de charger l'état du design — vérifiez que le daemon est en cours d'exécution"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डिज़ाइन स्थिति लोड नहीं हो सकी — सुनिश्चित करें कि daemon चल रहा है"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デザインの状態を読み込めませんでした — daemon が実行中か確認してください"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "디자인 상태를 불러오지 못했어요 — daemon 이 실행 중인지 확인하세요"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível carregar o status de design — verifique se o daemon está em execução"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось загрузить состояние дизайна — убедитесь, что daemon запущен"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法加载设计状态——请确认 daemon 正在运行"
          }
        }
      }
    },
    "승인했어요 — 이제 수집·리서치가 이 규칙을 강한 신호로 따라요": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم الاعتماد — أصبحت عمليات الجمع والبحث تتبع هذه القواعد كإشارة قوية"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Approved — collection and research now follow these rules as a strong signal"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aprobado: la recopilación y la investigación ahora siguen estas reglas como señal fuerte"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Approuvé — la collecte et la recherche suivent désormais ces règles comme un signal fort"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्वीकृत — अब संग्रह और शोध इन नियमों को एक मज़बूत संकेत के रूप में मानते हैं"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "承認しました — 収集・リサーチがこのルールを強いシグナルとして従います"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "승인했어요 — 이제 수집·리서치가 이 규칙을 강한 신호로 따라요"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Aprovado — a coleta e a pesquisa agora seguem essas regras como sinal forte"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Утверждено — теперь сбор и исследование следуют этим правилам как сильному сигналу"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已批准——收集和调研现在会将这些规则作为强信号遵循"
          }
        }
      }
    },
