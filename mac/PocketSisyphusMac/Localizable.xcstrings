          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "설정 변경 실패: %@"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Falha ao alterar a configuração: %@"
          }
        },
        "ru": {
