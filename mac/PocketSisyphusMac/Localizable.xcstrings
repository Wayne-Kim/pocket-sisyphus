            "value": "Trois choix :"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "तीन विकल्प:"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択肢は 3 つ:"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택지 세 가지:"
          }
        },
        "pt-BR": {
          "stringUnit": {
