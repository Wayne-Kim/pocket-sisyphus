    "클램쉘 모드 (덮개 닫고 실행)": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "وضع الصَّدفة (التشغيل والغطاء مغلق)"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clamshell mode (run with lid closed)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Modo concha (funcionar con la tapa cerrada)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mode capot fermé (fonctionner capot fermé)"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "क्लैमशेल मोड (ढक्कन बंद करके चलाएँ)"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クラムシェルモード（ふたを閉じても実行）"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "클램쉘 모드 (덮개 닫고 실행)"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Modo concha (funcionar com a tampa fechada)"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Режим закрытой крышки (работа с закрытой крышкой)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "合盖模式（合上盖子也运行）"
          }
        }
      }
    },
    "유휴 상태나 화면 잠금 중에도 Mac이 잠자기로 들어가지 않아요. 화면은 꺼질 수 있지만 터미널 작업은 계속됩니다. Mac mini 같은 데스크톱에도 적용돼요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يمنع جهاز Mac من الدخول في وضع السكون أثناء الخمول أو عند قفل الشاشة. قد تنطفئ الشاشة، لكن يستمر عمل الطرفية. ينطبق أيضًا على أجهزة سطح المكتب مثل Mac mini."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keeps your Mac from going to sleep while idle or when the screen is locked. The display may turn off, but terminal work keeps running. Also applies to desktops like the Mac mini."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Evita que el Mac entre en reposo mientras está inactivo o con la pantalla bloqueada. La pantalla puede apagarse, pero el trabajo del terminal sigue en marcha. También se aplica a equipos de escritorio como el Mac mini."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Empêche le Mac de se mettre en veille lorsqu'il est inactif ou que l'écran est verrouillé. L'écran peut s'éteindre, mais le travail du terminal continue. S'applique aussi aux ordinateurs de bureau comme le Mac mini."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "निष्क्रिय रहने या स्क्रीन लॉक होने पर भी Mac को स्लीप में नहीं जाने देता। डिस्प्ले बंद हो सकता है, पर टर्मिनल का काम चलता रहता है। Mac mini जैसे डेस्कटॉप पर भी लागू होता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アイドル中や画面ロック中でも Mac がスリープに入らないようにします。ディスプレイは消えてもターミナルの作業は続きます。Mac mini などのデスクトップにも適用されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "유휴 상태나 화면 잠금 중에도 Mac이 잠자기로 들어가지 않아요. 화면은 꺼질 수 있지만 터미널 작업은 계속됩니다. Mac mini 같은 데스크톱에도 적용돼요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Impede que o Mac entre em repouso enquanto está ocioso ou com a tela bloqueada. A tela pode desligar, mas o trabalho do terminal continua. Também se aplica a desktops como o Mac mini."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не даёт Mac уснуть при простое или заблокированном экране. Дисплей может выключиться, но работа в терминале продолжается. Также применяется к настольным компьютерам, таким как Mac mini."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在闲置或锁屏期间也不让 Mac 进入睡眠。屏幕可能关闭，但终端任务会继续运行。同样适用于 Mac mini 等台式机。"
          }
        }
      }
    },
    "MacBook 덮개를 닫아도 잠들지 않게 합니다. 외장 디스플레이가 없어도 동작하지만, macOS 전체 잠자기를 끄는 시스템 설정이라 켜는 동안 Mac이 전혀 잠들지 않아요. 켜고 끌 때 관리자 암호를 한 번 묻습니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يُبقي جهاز MacBook مستيقظًا حتى مع إغلاق الغطاء. يعمل دون شاشة خارجية، لكنه يوقف سكون macOS على مستوى النظام بأكمله، لذا لن يدخل Mac في السكون إطلاقًا أثناء تشغيله. سيُطلب منك كلمة مرور المسؤول مرة واحدة عند التشغيل أو الإيقاف."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keeps your MacBook awake even with the lid closed. It works without an external display, but because it turns off macOS sleep system-wide, your Mac won't sleep at all while it's on. You'll be asked for your administrator password once when turning it on or off."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantiene el MacBook activo incluso con la tapa cerrada. Funciona sin una pantalla externa, pero como desactiva el reposo de macOS en todo el sistema, el Mac no entrará en reposo mientras esté activado. Se te pedirá la contraseña de administrador una vez al activarlo o desactivarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Maintient le MacBook éveillé même capot fermé. Fonctionne sans écran externe, mais comme cela désactive la veille de macOS au niveau du système, le Mac ne se met plus du tout en veille tant que c'est activé. Le mot de passe administrateur est demandé une fois à l'activation ou la désactivation."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ढक्कन बंद होने पर भी MacBook को जगाए रखता है। बाहरी डिस्प्ले के बिना भी काम करता है, पर यह पूरे सिस्टम में macOS स्लीप बंद कर देता है, इसलिए चालू रहने तक Mac बिल्कुल स्लीप नहीं होगा। चालू या बंद करते समय एक बार एडमिनिस्ट्रेटर पासवर्ड पूछा जाएगा।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "MacBook のふたを閉じてもスリープしないようにします。外部ディスプレイがなくても動作しますが、macOS 全体のスリープを無効にするシステム設定のため、オンの間は Mac がまったくスリープしません。オン／オフの切り替え時に管理者パスワードを一度入力します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "MacBook 덮개를 닫아도 잠들지 않게 합니다. 외장 디스플레이가 없어도 동작하지만, macOS 전체 잠자기를 끄는 시스템 설정이라 켜는 동안 Mac이 전혀 잠들지 않아요. 켜고 끌 때 관리자 암호를 한 번 묻습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantém o MacBook ativo mesmo com a tampa fechada. Funciona sem um monitor externo, mas como desativa o repouso do macOS em todo o sistema, o Mac não entrará em repouso enquanto estiver ativado. A senha de administrador será solicitada uma vez ao ativar ou desativar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не даёт MacBook уснуть даже с закрытой крышкой. Работает без внешнего дисплея, но поскольку отключает сон macOS на уровне всей системы, пока режим включён, Mac вообще не будет засыпать. При включении или выключении один раз потребуется пароль администратора."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "即使合上 MacBook 盖子也不会睡眠。无需外接显示器即可使用，但它会在系统范围内关闭 macOS 睡眠，因此开启期间 Mac 完全不会睡眠。开启或关闭时会要求输入一次管理员密码。"
          }
        }
      }
    },
    "지금 Mac이 잠들지 않도록 설정돼 있어요. 다 쓰면 꺼 주세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "جهاز Mac مضبوط حاليًا على عدم الدخول في السكون أبدًا. أوقفه عند الانتهاء."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your Mac is currently set to never sleep. Turn this off when you're done."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu Mac está configurado para no entrar nunca en reposo. Desactívalo cuando termines."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre Mac est actuellement réglé pour ne jamais se mettre en veille. Désactivez cette option lorsque vous avez terminé."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अभी आपका Mac कभी स्लीप न होने के लिए सेट है। काम पूरा होने पर इसे बंद कर दें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在、Mac がスリープしない設定になっています。使い終わったらオフにしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "지금 Mac이 잠들지 않도록 설정돼 있어요. 다 쓰면 꺼 주세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Seu Mac está configurado para nunca entrar em repouso. Desative quando terminar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сейчас ваш Mac настроен никогда не засыпать. Выключите это, когда закончите."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前 Mac 已设置为不会睡眠。用完后请关闭。"
          }
        }
      }
    },
    "Mac이 잠들면 폰에서 돌리던 터미널 세션이 끊겨요. 아래를 켜면 잠자기·덮개 닫힘에도 계속 돌아갑니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عندما يدخل Mac في السكون، تنقطع جلسة الطرفية التي بدأتها من هاتفك. فعّل الخيارات أدناه لإبقائها تعمل أثناء السكون وعند إغلاق الغطاء."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When your Mac sleeps, the terminal session you started from your phone is cut off. Turn on the options below to keep it running through sleep and a closed lid."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando el Mac entra en reposo, se corta la sesión de terminal que iniciaste desde el teléfono. Activa las opciones de abajo para que siga funcionando durante el reposo y con la tapa cerrada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorsque le Mac se met en veille, la session de terminal lancée depuis votre téléphone est interrompue. Activez les options ci-dessous pour qu'elle continue pendant la veille et capot fermé."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac के स्लीप होने पर फ़ोन से शुरू किया गया टर्मिनल सत्र कट जाता है। नीचे के विकल्प चालू करें ताकि स्लीप और ढक्कन बंद होने पर भी वह चलता रहे।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac がスリープすると、スマホから動かしていたターミナルセッションが切断されます。下をオンにすると、スリープやふたを閉じてもセッションが続きます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac이 잠들면 폰에서 돌리던 터미널 세션이 끊겨요. 아래를 켜면 잠자기·덮개 닫힘에도 계속 돌아갑니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando o Mac entra em repouso, a sessão de terminal que você iniciou pelo telefone é interrompida. Ative as opções abaixo para que ela continue durante o repouso e com a tampa fechada."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Когда Mac засыпает, сеанс терминала, запущенный с телефона, обрывается. Включите параметры ниже, чтобы он продолжал работать во сне и с закрытой крышкой."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac 睡眠后，你从手机启动的终端会话会断开。开启下面的选项，即可在睡眠和合盖时继续运行。"
          }
        }
      }
    },
    "유휴·화면 잠금 중에도 Mac이 잠자기로 안 들어가 터미널 세션이 끊기지 않아요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يمنع Mac من السكون أثناء الخمول أو القفل، حتى لا تنقطع جلسة الطرفية."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keeps your Mac from sleeping while idle or locked, so your terminal session isn't cut off."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Evita que el Mac entre en reposo mientras está inactivo o bloqueado, para que no se corte la sesión de terminal."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Empêche le Mac de se mettre en veille lorsqu'il est inactif ou verrouillé, afin que la session de terminal ne soit pas interrompue."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "निष्क्रिय या लॉक होने पर भी Mac को स्लीप नहीं होने देता, ताकि टर्मिनल सत्र न कटे।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アイドル中や画面ロック中でも Mac がスリープしないので、ターミナルセッションが切断されません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "유휴·화면 잠금 중에도 Mac이 잠자기로 안 들어가 터미널 세션이 끊기지 않아요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Impede que o Mac entre em repouso enquanto ocioso ou bloqueado, para que a sessão de terminal não seja interrompida."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не даёт Mac уснуть при простое или блокировке, чтобы сеанс терминала не обрывался."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "闲置或锁屏时也不让 Mac 睡眠，避免终端会话断开。"
          }
        }
      }
    },
    "MacBook 덮개를 닫아도 안 잠들게 합니다. 켜고 끌 때 관리자 암호를 한 번 물어요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يُبقي MacBook مستيقظًا حتى مع إغلاق الغطاء. يطلب كلمة مرور المسؤول مرة واحدة عند التشغيل أو الإيقاف."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keeps your MacBook awake even with the lid closed. Asks for your administrator password once when turning it on or off."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantiene el MacBook activo incluso con la tapa cerrada. Pide la contraseña de administrador una vez al activarlo o desactivarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Maintient le MacBook éveillé même capot fermé. Demande le mot de passe administrateur une fois à l'activation ou la désactivation."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ढक्कन बंद होने पर भी MacBook को जगाए रखता है। चालू या बंद करते समय एक बार एडमिनिस्ट्रेटर पासवर्ड पूछता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "MacBook のふたを閉じてもスリープしないようにします。オン／オフの切り替え時に管理者パスワードを一度入力します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "MacBook 덮개를 닫아도 안 잠들게 합니다. 켜고 끌 때 관리자 암호를 한 번 물어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantém o MacBook ativo mesmo com a tampa fechada. Pede a senha de administrador uma vez ao ativar ou desativar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не даёт MacBook уснуть даже с закрытой крышкой. При включении или выключении один раз запрашивает пароль администратора."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "即使合上 MacBook 盖子也不睡眠。开启或关闭时会要求输入一次管理员密码。"
          }
        }
      }
    },
