    "webhook URL 은 비밀이에요 — config.json(0600)에만 저장되고, 화면엔 가려서 보여줍니다.": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "webhook URL 은 비밀이에요 — config.json(0600)에만 저장되고, 화면엔 가려서 보여줍니다."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your webhook URL is a secret — stored only in config.json (0600) and shown masked here."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ウェブフック URL は秘密です — config.json(0600)にのみ保存され、画面では伏せて表示します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "webhook URL 是机密 — 仅保存在 config.json（0600）中，界面上以掩码显示。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La URL del webhook es secreta: se guarda solo en config.json (0600) y aquí se muestra oculta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’URL du webhook est secrète : stockée uniquement dans config.json (0600) et masquée ici."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A URL do webhook é secreta — salva apenas em config.json (0600) e exibida oculta aqui."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "URL веб-хука — секрет: хранится только в config.json (0600) и здесь показан скрытым."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "رابط webhook سري — يُحفظ فقط في config.json (0600) ويُعرض هنا مُخفىً."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
