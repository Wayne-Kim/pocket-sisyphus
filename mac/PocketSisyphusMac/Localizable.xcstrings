    "디자인 규칙이 선언됐어요": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم إعلان قواعد التصميم"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Design rules are declared"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las reglas de diseño están declaradas"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les règles de design sont déclarées"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डिज़ाइन नियम घोषित हैं"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デザインルールが宣言されています"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "디자인 규칙이 선언됐어요"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As regras de design estão declaradas"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Правила дизайна объявлены"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已声明设计规则"
          }
        }
      }
    },
    "승인된 규칙을 강한 신호로 쓰고 있어요. 규칙이 바뀌었으면 초안을 다시 만들어 갱신하세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تُستخدم القواعد المعتمدة كإشارة قوية. إذا تغيّرت القواعد، فأنشئ مسودة جديدة لتحديثها."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The approved rules are being used as a strong signal. If the rules have changed, regenerate a draft to update them."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las reglas aprobadas se usan como señal fuerte. Si las reglas han cambiado, genera un nuevo borrador para actualizarlas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les règles approuvées sont utilisées comme signal fort. Si les règles ont changé, régénérez un brouillon pour les mettre à jour."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्वीकृत नियमों को एक मज़बूत संकेत के रूप में उपयोग किया जा रहा है। यदि नियम बदल गए हों, तो उन्हें अपडेट करने के लिए ड्राफ़्ट फिर से बनाएँ।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "承認済みのルールを強いシグナルとして使用しています。ルールが変わった場合は下書きを作り直して更新してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "승인된 규칙을 강한 신호로 쓰고 있어요. 규칙이 바뀌었으면 초안을 다시 만들어 갱신하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As regras aprovadas estão sendo usadas como sinal forte. Se as regras mudaram, gere um novo rascunho para atualizá-las."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Утверждённые правила используются как сильный сигнал. Если правила изменились, создайте черновик заново, чтобы обновить их."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正在将已批准的规则用作强信号。如果规则有变化，请重新生成草稿以更新。"
          }
        }
      }
    },
    "초안 다시 만들기": {
      "extractionState": "manual",
