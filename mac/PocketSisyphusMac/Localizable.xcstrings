    "노드 하단 포트를 끌어 다른 노드에 놓으면 연결돼요": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "노드 하단 포트를 끌어 다른 노드에 놓으면 연결돼요"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag a node’s bottom port onto another node to connect them."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拖动节点底部的端口到另一个节点即可连接。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ノード下部のポートを別のノードにドラッグすると接続されます。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrastra el puerto inferior de un nodo sobre otro nodo para conectarlos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Faites glisser le port inférieur d’un nœud sur un autre nœud pour les relier."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اسحب المنفذ السفلي للعقدة إلى عقدة أخرى لربطهما."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Arraste a porta inferior de um nó até outro nó para conectá-los."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перетащите нижний порт узла на другой узел, чтобы соединить их."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नोड के निचले पोर्ट को दूसरे नोड पर खींचें ताकि वे जुड़ जाएँ।"
          }
        }
      }
    },
    "순환이 생겨요 — 루프는 테스트 노드의 «실패» 연결로만 만들 수 있어요": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "순환이 생겨요 — 루프는 테스트 노드의 «실패» 연결로만 만들 수 있어요"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "That would create a cycle — loops are only allowed via a test node’s “fail” connection."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这会形成循环 — 只能通过测试节点的“失败”连线来创建循环。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "循環ができてしまいます — ループはテストノードの「失敗」接続でのみ作れます。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Eso crearía un ciclo: los bucles solo se permiten mediante la conexión «fallo» de un nodo de prueba."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela créerait un cycle — les boucles ne sont possibles que via la connexion « échec » d’un nœud de test."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذا سيُنشئ حلقة — الحلقات مسموحة فقط عبر وصلة «الفشل» في عقدة اختبار."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso criaria um ciclo — laços só são permitidos pela conexão de «falha» de um nó de teste."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это создаст цикл — петли возможны только через связь «неудача» тестового узла."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इससे चक्र बन जाएगा — लूप केवल टेस्ट नोड के «विफल» कनेक्शन से ही बनाए जा सकते हैं।"
          }
        }
      }
