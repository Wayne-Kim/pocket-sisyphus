            "value": "Bucle autocorrectivo"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Boucle auto-correctrice"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्व-सुधार लूप"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自己修正ループ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "자기교정 루프"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Loop autocorretivo"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Самокорректирующийся цикл"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自我修正循环"
          }
        }
      }
    },
    "생성 → 점검 순서로 만들고, 점검이 실패를 판정하면 생성으로 되돌아가 고치는 루프형 출발 템플릿이에요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قالب بداية يُنشئ ← يفحص، وعند حكم الفحص بالفشل يعود إلى الإنشاء لإصلاحه."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A starter template that generates → checks, and when the check judges a failure, loops back to generation to fix it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una plantilla inicial que genera → revisa y, cuando la revisión determina un fallo, vuelve a la generación para corregirlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un modèle de départ qui génère → vérifie et, quand la vérification conclut à un échec, revient à la génération pour corriger."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक स्टार्टर टेम्पलेट जो सृजन → जाँच करता है, और जब जाँच विफलता का निर्णय देती है तो ठीक करने के लिए सृजन पर लौट आता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "生成 → 点検の順で作り、点検が失敗と判定したら生成へ戻って直すループ型の出発テンプレートです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "생성 → 점검 순서로 만들고, 점검이 실패를 판정하면 생성으로 되돌아가 고치는 루프형 출발 템플릿이에요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Um modelo inicial que gera → verifica e, quando a verificação julga uma falha, volta à geração para corrigir."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Стартовый шаблон, который создаёт → проверяет, и когда проверка выносит вердикт «неудача», возвращается к созданию для исправления."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一个起始模板:按生成 → 检查的顺序进行,当检查判定为失败时,回到生成进行修正。"
          }
        }
      }
    },
