<?xml version="1.0" encoding="utf-8"?>
<!--
  DEBUG-ONLY overlay of the main network security config (src/main/.../network_security_config.xml).
  Same strict loopback-only policy, plus `10.0.2.2` — the emulator's alias for the host Mac's
  loopback — so the debug-only direct dev pairing (DevBootstrap, mirroring iOS DevPairing) can talk
  plaintext HTTP/WS straight to the host daemon without an SSH tunnel. The release build keeps the
  loopback-only policy and never sees this file.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
        <!-- Android emulator → host Mac loopback. Dev direct daemon pairing only. -->
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
