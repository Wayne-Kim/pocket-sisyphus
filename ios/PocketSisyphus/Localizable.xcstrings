            "value": "No se puede acceder al servidor"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Serveur injoignable"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सर्वर तक नहीं पहुँचा जा सका"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サーバーに到達できません"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "서버에 도달할 수 없음"
          }
        },
