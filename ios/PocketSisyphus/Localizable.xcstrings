    "순환이 생겨요 — 루프는 작업의 «실패» 연결로만 만들 수 있어요": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيؤدي ذلك إلى إنشاء حلقة — لا يمكن إنشاء الحلقات إلا عبر اتصال «الفشل» الخاص بالمهمة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "That would create a cycle — loops can only be made with a task's “fail” connection."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Eso crearía un ciclo: los bucles solo se pueden crear con la conexión «fallo» de una tarea."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela créerait un cycle — les boucles ne peuvent être créées qu'avec la connexion « échec » d'une tâche."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इससे चक्र बन जाएगा — लूप केवल किसी कार्य के «विफल» कनेक्शन से ही बनाए जा सकते हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "循環ができてしまいます — ループはタスクの「失敗」接続でのみ作れます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "순환이 생겨요 — 루프는 작업의 «실패» 연결로만 만들 수 있어요"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso criaria um ciclo — laços só podem ser feitos com a conexão de “falha” de uma tarefa."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это создаст цикл — циклы можно создавать только через связь «сбой» задачи."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这会形成循环 — 循环只能用任务的“失败”连接来创建。"
          }
        }
      }
    },
    "순환이 생겨요 — 루프는 테스트 노드의 «실패» 연결로만 만들 수 있어요": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "순환이 생겨요 — 루프는 테스트 노드의 «실패» 연결로만 만들 수 있어요"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "That would create a cycle — loops are only allowed via a test node’s “fail” connection."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这会形成循环 — 只能通过测试节点的“失败”连线来创建循环。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "循環ができてしまいます — ループはテストノードの「失敗」接続でのみ作れます。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Eso crearía un ciclo: los bucles solo se permiten mediante la conexión «fallo» de un nodo de prueba."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela créerait un cycle — les boucles ne sont possibles que via la connexion « échec » d’un nœud de test."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذا سيُنشئ حلقة — الحلقات مسموحة فقط عبر وصلة «الفشل» في عقدة اختبار."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso criaria um ciclo — laços só são permitidos pela conexão de «falha» de um nó de teste."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это создаст цикл — петли возможны только через связь «неудача» тестового узла."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इससे चक्र बन जाएगा — लूप केवल टेस्ट नोड के «विफल» कनेक्शन से ही बनाए जा सकते हैं।"
          }
        }
      }
    },
