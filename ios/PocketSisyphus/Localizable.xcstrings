    },
    "에이전트 응답 읽어주기": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قراءة ردود الوكيل بصوت عالٍ"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Read agent responses aloud"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Leer en voz alta las respuestas del agente"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lire à voix haute les réponses de l'agent"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एजेंट के जवाब ज़ोर से पढ़ें"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "エージェントの応答を読み上げる"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "에이전트 응답 읽어주기"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ler respostas do agente em voz alta"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Зачитывать ответы агента вслух"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "朗读智能体回复"
          }
        }
      }
    },
    "에이전트가 레포 신호를 모아 «기회 브리프» 를 올리고, 당신은 폰에서 승인·보류·기각만 하면 됩니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يجمع الوكيل إشارات المستودع ويقدّم «موجزات الفرص»، وما عليك سوى الموافقة أو التأجيل أو الرفض من هاتفك."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The agent gathers repo signals and posts «opportunity briefs» — you just approve, hold, or reject them from your phone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El agente reúne señales del repo y publica «informes de oportunidad»; tú solo apruebas, aplazas o rechazas desde el móvil."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’agent rassemble les signaux du dépôt et publie des «briefs d’opportunité» — vous n’avez qu’à approuver, suspendre ou rejeter depuis le mobile."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एजेंट रेपो के संकेत इकट्ठा करके «अवसर ब्रीफ़» पेश करता है — आपको बस फ़ोन से स्वीकृत, स्थगित या अस्वीकृत करना है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "エージェントがリポジトリのシグナルを集めて «機会ブリーフ» を出し、あなたはスマホで承認・保留・却下するだけです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "에이전트가 레포 신호를 모아 «기회 브리프» 를 올리고, 당신은 폰에서 승인·보류·기각만 하면 됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O agente reúne sinais do repo e publica «briefs de oportunidade» — você só aprova, adia ou rejeita pelo celular."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Агент собирает сигналы репозитория и предлагает «брифы возможностей» — вам остаётся только одобрить, отложить или отклонить их с телефона."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "智能体收集仓库信号并提出«机会简报»，你只需在手机上批准、暂缓或驳回。"
          }
        }
      }
    },
    "에이전트가 만든 초안이에요. 검토하고 필요하면 고친 뒤 «승인» 하면, 이후 수집·리서치·워크플로우가 이 규칙을 강한 신호로 따라요. 승인 전엔 적용되지 않아요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذه مسودة أنشأها الوكيل. راجعها، وعدّلها إذا لزم الأمر، ثم اضغط «اعتماد» — بعدها ستتبع عمليات الجمع والبحث وسير العمل هذه القواعد كإشارة قوية. لا يُطبَّق أي شيء قبل اعتمادك."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This is a draft made by the agent. Review it, edit if needed, then Approve — after that, collection, research, and workflows follow these rules as a strong signal. Nothing is applied before you approve."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este es un borrador creado por el agente. Revísalo, edítalo si hace falta y pulsa «Aprobar»: después, la recopilación, la investigación y los flujos de trabajo seguirán estas reglas como señal fuerte. No se aplica nada antes de que apruebes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ceci est un brouillon créé par l'agent. Relisez-le, modifiez-le si nécessaire, puis appuyez sur « Approuver » : ensuite, la collecte, la recherche et les workflows suivront ces règles comme un signal fort. Rien n'est appliqué avant votre approbation."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह एजेंट द्वारा बनाया गया ड्राफ़्ट है। इसकी समीक्षा करें, ज़रूरत हो तो संपादित करें, फिर «स्वीकृत करें» — उसके बाद संग्रह, शोध और वर्कफ़्लो इन नियमों को एक मज़बूत संकेत के रूप में मानेंगे। स्वीकृति से पहले कुछ भी लागू नहीं होता।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "エージェントが作成した下書きです。確認し、必要なら修正してから「承認」すると、以降の収集・リサーチ・ワークフローがこのルールを強いシグナルとして従います。承認前は適用されません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "에이전트가 만든 초안이에요. 검토하고 필요하면 고친 뒤 «승인» 하면, 이후 수집·리서치·워크플로우가 이 규칙을 강한 신호로 따라요. 승인 전엔 적용되지 않아요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este é um rascunho criado pelo agente. Revise, edite se necessário e toque em «Aprovar» — depois, a coleta, a pesquisa e os fluxos de trabalho seguirão essas regras como sinal forte. Nada é aplicado antes de você aprovar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это черновик, созданный агентом. Просмотрите его, при необходимости отредактируйте и нажмите «Утвердить» — после этого сбор, исследование и рабочие процессы будут следовать этим правилам как сильному сигналу. До утверждения ничего не применяется."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这是代理生成的草稿。请审阅，必要时修改后点击“批准”——之后收集、调研和工作流会将这些规则作为强信号遵循。批准前不会应用。"
          }
        }
      }
    },
    "에이전트가 실행 중이에요. 끝난 뒤에 되돌릴 수 있어요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "العميل قيد التشغيل. يمكنك التراجع بعد انتهائه."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The agent is running. You can revert once it finishes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El agente se está ejecutando. Podrás revertir cuando termine."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’agent est en cours d’exécution. Vous pourrez revenir une fois qu’il aura terminé."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एजेंट चल रहा है। समाप्त होने पर आप वापस ला सकते हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "エージェントが実行中です。終了後に戻せます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "에이전트가 실행 중이에요. 끝난 뒤에 되돌릴 수 있어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O agente está em execução. Você poderá reverter quando ele terminar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Агент выполняется. Откатиться можно будет после завершения."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "代理正在运行。完成后即可还原。"
          }
        }
      }
    },
    "에이전트가 웹과 레포를 조사해 보고서와 백로그 제안을 만들어요. 수 분 걸려요 — 진행은 리서치 섹션에서 볼 수 있어요.": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "에이전트가 웹과 레포를 조사해 보고서와 백로그 제안을 만들어요. 수 분 걸려요 — 진행은 리서치 섹션에서 볼 수 있어요."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The agent researches the web and your repo to produce a report and backlog proposals. Takes a few minutes — track progress in the Research section."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "エージェントがウェブとリポジトリを調査し、報告書とバックログ提案を作ります。数分かかります — 進捗はリサーチ欄で確認できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "智能体调研网络和你的仓库，生成报告与待办提案。需要几分钟 — 可在调研区查看进度。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El agente investiga la web y tu repositorio para generar un informe y propuestas de backlog. Tarda unos minutos; sigue el progreso en la sección Investigación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'agent analyse le web et votre dépôt pour produire un rapport et des propositions de backlog. Quelques minutes — suivez la progression dans la section Recherche."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O agente pesquisa a web e seu repositório para gerar um relatório e propostas de backlog. Leva alguns minutos — acompanhe na seção Pesquisa."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Агент исследует веб и ваш репозиторий, создавая отчёт и предложения для бэклога. Займёт несколько минут — следите в разделе «Исследование»."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يبحث الوكيل في الويب ومستودعك لإنتاج تقرير ومقترحات لقائمة المهام. يستغرق بضع دقائق — تابع التقدم في قسم البحث."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एजेंट वेब और आपके रिपो की जाँच कर रिपोर्ट और बैकलॉग प्रस्ताव बनाता है। कुछ मिनट लगते हैं — प्रगति शोध अनुभाग में देखें।"
          }
        }
      }
    },
    "에이전트가 이 레포의 색·간격·금지 패턴·지원 언어를 읽어 초안을 만들고 있어요. 세션 탭에서 과정을 볼 수 있어요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يقرأ الوكيل ألوان هذا المستودع والتباعد والأنماط الممنوعة واللغات المدعومة لإنشاء مسودة. يمكنك متابعة التقدّم في تبويب الجلسات."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The agent is reading this repo's colors, spacing, forbidden patterns, and supported languages to build a draft. You can watch the progress in the Sessions tab."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El agente está leyendo los colores, el espaciado, los patrones prohibidos y los idiomas admitidos de este repositorio para crear un borrador. Puedes ver el progreso en la pestaña Sesiones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'agent lit les couleurs, les espacements, les motifs interdits et les langues prises en charge de ce dépôt pour créer un brouillon. Vous pouvez suivre la progression dans l'onglet Sessions."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एजेंट इस रिपॉज़िटरी के रंग, स्पेसिंग, वर्जित पैटर्न और समर्थित भाषाओं को पढ़कर ड्राफ़्ट बना रहा है। आप प्रगति को सेशन टैब में देख सकते हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "エージェントがこのリポジトリの色・余白・禁止パターン・対応言語を読み取って下書きを作成しています。進行状況はセッションタブで確認できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "에이전트가 이 레포의 색·간격·금지 패턴·지원 언어를 읽어 초안을 만들고 있어요. 세션 탭에서 과정을 볼 수 있어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O agente está lendo as cores, o espaçamento, os padrões proibidos e os idiomas suportados deste repositório para criar um rascunho. Você pode acompanhar o progresso na aba Sessões."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Агент читает цвета, отступы, запрещённые паттерны и поддерживаемые языки этого репозитория, чтобы создать черновик. Прогресс можно увидеть во вкладке «Сессии»."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "代理正在读取此仓库的颜色、间距、禁用模式和支持的语言来生成草稿。你可以在“会话”标签页查看进度。"
          }
        }
      }
    },
    "에이전트가 이 아이디어와 관련된 TODO 주석·죽은 코드를 찾아 지워요. 변경은 커밋하지 않아요 — 세션에서 검토할 수 있어요.": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "에이전트가 이 아이디어와 관련된 TODO 주석·죽은 코드를 찾아 지워요. 변경은 커밋하지 않아요 — 세션에서 검토할 수 있어요."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The agent finds and removes TODO comments and dead code related to this idea. Changes aren't committed — you can review them in the session."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "エージェントがこのアイデアに関連する TODO コメントやデッドコードを見つけて削除します。変更はコミットされません — セッションで確認できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "智能体会找到并删除与这个想法相关的 TODO 注释和死代码。更改不会提交 — 你可以在会话中检查。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El agente encuentra y elimina los comentarios TODO y el código muerto relacionados con esta idea. Los cambios no se confirman — puedes revisarlos en la sesión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'agent trouve et supprime les commentaires TODO et le code mort liés à cette idée. Les modifications ne sont pas commitées — vous pouvez les vérifier dans la session."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O agente encontra e remove comentários TODO e código morto relacionados a essa ideia. As mudanças não são commitadas — você pode revisá-las na sessão."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Агент найдёт и удалит комментарии TODO и мёртвый код, связанные с этой идеей. Изменения не коммитятся — их можно проверить в сессии."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يعثر الوكيل على تعليقات TODO والكود الميت المرتبط بهذه الفكرة ويحذفها. لا يتم إيداع التغييرات — يمكنك مراجعتها في الجلسة."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एजेंट इस आइडिया से जुड़े TODO कमेंट और डेड कोड ढूँढकर हटाता है। बदलाव कमिट नहीं होते — आप उन्हें सेशन में जाँच सकते हैं।"
          }
        }
      }
    },
    "에이전트가 입력을 기다리고 있어요": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الوكيل بانتظار إدخالك"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The agent is waiting for your input"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
