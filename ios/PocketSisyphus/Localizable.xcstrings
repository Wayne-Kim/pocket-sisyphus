    "되돌리면 지금 작업 중인 변경은 자동 체크포인트로 먼저 저장돼요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند التراجع، يتم حفظ تغييراتك الحالية أولاً كنقطة تحقق تلقائية."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When you roll back, your current changes are saved as an automatic checkpoint first."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Al revertir, tus cambios actuales se guardan primero como un punto de control automático."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lors d’une restauration, vos modifications en cours sont d’abord enregistrées comme point de contrôle automatique."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वापस लाने पर, आपके मौजूदा बदलाव पहले एक स्वचालित चेकपॉइंट के रूप में सहेजे जाते हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "戻すと、現在の変更はまず自動チェックポイントとして保存されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "되돌리면 지금 작업 중인 변경은 자동 체크포인트로 먼저 저장돼요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ao reverter, suas alterações atuais são salvas primeiro como um ponto de verificação automático."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "При откате ваши текущие изменения сначала сохраняются как автоматическая контрольная точка."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "回退时，你当前的更改会先保存为自动检查点。"
          }
        }
      }
    },
