    "분 시 일 월 요일 — 5필드 cron 식. 예: `0 9 * * 1-5` (평일 09:00)": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الدقيقة الساعة اليوم الشهر يوم الأسبوع — صيغة cron من 5 حقول. مثال: `0 9 * * 1-5` (أيام الأسبوع 09:00)"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Minute hour day month weekday — a 5-field cron expression. e.g. `0 9 * * 1-5` (weekdays 09:00)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Minuto hora día mes día de la semana — expresión cron de 5 campos. Ej.: `0 9 * * 1-5` (días laborables 09:00)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Minute heure jour mois jour de semaine — expression cron à 5 champs. Ex. : `0 9 * * 1-5` (jours ouvrés 09:00)"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मिनट घंटा दिन महीना सप्ताह-दिन — 5-फ़ील्ड cron एक्सप्रेशन। उदा. `0 9 * * 1-5` (कार्यदिवस 09:00)"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "分 時 日 月 曜日 — 5フィールドの cron 式。例: `0 9 * * 1-5`（平日 09:00）"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "분 시 일 월 요일 — 5필드 cron 식. 예: `0 9 * * 1-5` (평일 09:00)"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Minuto hora dia mês dia da semana — expressão cron de 5 campos. Ex.: `0 9 * * 1-5` (dias úteis 09:00)"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Минута час день месяц день недели — cron-выражение из 5 полей. Напр.: `0 9 * * 1-5` (будни 09:00)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "分 时 日 月 周几 — 5 字段 cron 表达式。例如 `0 9 * * 1-5`（工作日 09:00）"
          }
        }
      }
    },
