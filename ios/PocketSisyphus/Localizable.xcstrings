        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 폴더에서 에이전트를 실행해요. 없는 폴더는 자동으로 만들어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O agente é executado nesta pasta. Uma pasta inexistente é criada automaticamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Агент запускается в этой папке. Отсутствующая папка создаётся автоматически."
