        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This agent cleans up the leftover code traces."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este agente limpia los rastros de código que quedaron."
          }
        },
        "fr": {
          "stringUnit": {
