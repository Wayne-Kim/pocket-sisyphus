    "세션이 이미지·PDF·문서 같은 파일을 만들면 여기에 모여요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عندما تنشئ الجلسة ملفات مثل الصور أو ملفات PDF أو المستندات، ستظهر هنا."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When the session creates files like images, PDFs, or documents, they appear here."
          }
        },
