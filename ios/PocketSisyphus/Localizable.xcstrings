    "해제 실패: %@": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فشل الإلغاء: %@"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
