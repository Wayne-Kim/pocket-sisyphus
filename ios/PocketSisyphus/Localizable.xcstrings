    "이 폴더에서 에이전트를 실행해요. 없는 폴더는 자동으로 만들어요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يعمل الوكيل في هذا المجلد، وإذا لم يكن موجودًا فسيُنشأ تلقائيًا."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The agent runs in this folder. A missing folder is created automatically."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El agente se ejecuta en esta carpeta. Si no existe, se crea automáticamente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’agent s’exécute dans ce dossier. Un dossier absent est créé automatiquement."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एजेंट इसी फ़ोल्डर में चलता है। न होने पर फ़ोल्डर अपने-आप बन जाता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このフォルダでエージェントを実行します。存在しないフォルダは自動的に作成されます。"
