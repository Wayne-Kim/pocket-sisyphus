    "보안 검증 실패 — 서버 host key 가 일치하지 않아 직접 연결을 거부했습니다 (서버 위장 가능성)": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فشل التحقق الأمني — مفتاح مضيف الخادم غير متطابق، فتم رفض الاتصال المباشر (احتمال انتحال الخادم)"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Security check failed — the server’s host key didn’t match, so the direct connection was refused (possible server impersonation)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Error en la verificación de seguridad: la clave de host del servidor no coincide, por lo que se rechazó la conexión directa (posible suplantación del servidor)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec de la vérification de sécurité — la clé d’hôte du serveur ne correspond pas, la connexion directe a été refusée (usurpation de serveur possible)"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सुरक्षा जाँच विफल — सर्वर की होस्ट कुंजी मेल नहीं खाई, इसलिए सीधा कनेक्शन अस्वीकार किया गया (संभावित सर्वर प्रतिरूपण)"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "セキュリティ検証に失敗 — サーバーのホストキーが一致しないため直接接続を拒否しました (サーバーなりすましの可能性)"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "보안 검증 실패 — 서버 host key 가 일치하지 않아 직접 연결을 거부했습니다 (서버 위장 가능성)"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Falha na verificação de segurança — a chave de host do servidor não corresponde; a conexão direta foi recusada (possível falsificação de servidor)"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Проверка безопасности не пройдена — ключ хоста сервера не совпадает, прямое подключение отклонено (возможна подмена сервера)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "安全验证失败 — 服务器主机密钥不匹配，已拒绝直接连接（可能存在服务器仿冒）"
          }
        }
      }
    },
