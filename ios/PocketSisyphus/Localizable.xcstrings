    "앱이 종료된 뒤 홈 화면에서 아이콘을 다시 탭해 주세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بعد الإغلاق، اضغط على أيقونة التطبيق من الشاشة الرئيسية مرة أخرى."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "After it quits, tap the icon on the Home Screen to launch again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Después de cerrar, toca el icono en la pantalla de inicio para abrirla de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une fois fermée, appuyez à nouveau sur l’icône depuis l’écran d’accueil."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बंद होने के बाद, होम स्क्रीन पर आइकन को फिर से टैप करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "終了後、ホーム画面のアイコンをもう一度タップしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "앱이 종료된 뒤 홈 화면에서 아이콘을 다시 탭해 주세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Após fechar, toque no ícone na tela inicial novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "После выхода нажмите значок на главном экране ещё раз."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "退出后,请在主屏幕上再次轻触图标。"
          }
        }
      }
    },
    "어떤 노력·관점의 출시 기능이 더 자주 빗나가는지 보여줘요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يوضح أي الميزات المطلقة تخطئ في كثير من الأحيان حسب الجهد والمنظور."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shows which launched features miss more often by effort and perspective."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Muestra qué funciones lanzadas fallan más a menudo según esfuerzo y perspectiva."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Montre quelles fonctionnalités lancées échouent le plus souvent selon l'effort et la perspective."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "दिखाता है कि कौन सी लॉन्च की गई सुविधाएं प्रयास और दृष्टिकोण के अनुसार अधिक बार चूकती हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "どの労力・視点のリリース機能がより頻繁に外れるかを示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "어떤 노력·관점의 출시 기능이 더 자주 빗나가는지 보여줘요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mostra quais recursos lançados erram com mais frequência por esforço e perspectiva."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Показывает, какие запущенные функции чаще промахиваются по усилиям и перспективе."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "显示哪些已发布功能按努力和视角更常失误。"
          }
        }
      }
    },
    "어떤 노력·관점·근거의 출시 기능이 더 자주 빗나가는지 보여줘요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يوضح أي الميزات المطلقة تخطئ في كثير من الأحيان حسب الجهد والمنظور ونوع الدليل."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shows which launched features miss more often by effort, perspective, and evidence type."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Muestra qué funciones lanzadas fallan más a menudo según esfuerzo, perspectiva y tipo de evidencia."
          }
