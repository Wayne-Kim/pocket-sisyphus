    },
    "이미 다른 모델을 받는 중이에요. 끝나거나 취소한 뒤 다시 시도하세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يجري بالفعل تنزيل نموذج آخر. انتظر حتى ينتهي أو ألغِه ثم أعد المحاولة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Another model is already downloading. Wait for it to finish or cancel it, then try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ya se está descargando otro modelo. Espera a que termine o cancélalo y vuelve a intentarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un autre modèle est déjà en cours de téléchargement. Attendez la fin ou annulez-le, puis réessayez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पहले से ही दूसरा मॉडल डाउनलोड हो रहा है। उसके पूरा होने या रद्द होने के बाद फिर कोशिश करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すでに別のモデルをダウンロード中です。完了するか取り消してから再試行してください。"
          }
        },
        "ko": {
