    "스크립트는 신뢰하는 것만 등록하세요. Mac 이 깨어 있어야 실행돼요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سجّل فقط السكربتات التي تثق بها. يجب أن يكون الـ Mac مستيقظًا للتشغيل."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Only register scripts you trust. The Mac must be awake to run."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Registra solo scripts en los que confíes. El Mac debe estar activo para ejecutarse."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "N’enregistrez que des scripts de confiance. Le Mac doit être actif pour l’exécution."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "केवल उन्हीं स्क्रिप्ट को जोड़ें जिन पर आप भरोसा करते हैं। चलने के लिए Mac जागृत होना चाहिए।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "信頼できるスクリプトだけを登録してください。実行には Mac が起動している必要があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "스크립트는 신뢰하는 것만 등록하세요. Mac 이 깨어 있어야 실행돼요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Registre apenas scripts em que você confia. O Mac precisa estar ativo para executar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавляйте только доверенные скрипты. Для запуска Mac должен быть включён."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "只注册你信任的脚本。Mac 必须处于唤醒状态才能运行。"
          }
        }
      }
    },
    "스크립트를 로그인 셸로 한 번 실행해, PATH·환경이 평소처럼 잡혀요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يشغّل السكربت مرة واحدة في صدفة تسجيل الدخول، فيُحمّل PATH والبيئة كالمعتاد."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Runs the script once in a login shell, so PATH and environment load as usual."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ejecuta el script una vez en un shell de inicio de sesión, así el PATH y el entorno se cargan como siempre."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Exécute le script une fois dans un shell de connexion, donc le PATH et l’environnement se chargent normalement."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्क्रिप्ट को लॉगिन शेल में एक बार चलाता है, ताकि PATH और एनवायरनमेंट सामान्य रूप से लोड हों।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ログインシェルでスクリプトを一度実行するので、PATH や環境が通常どおり読み込まれます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "스크립트를 로그인 셸로 한 번 실행해, PATH·환경이 평소처럼 잡혀요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Executa o script uma vez em um shell de login, então o PATH e o ambiente carregam normalmente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Запускает скрипт один раз в login-оболочке, поэтому PATH и окружение загружаются как обычно."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在登录 shell 中运行脚本一次，因此会照常加载 PATH 和环境。"
          }
        }
      }
    },
