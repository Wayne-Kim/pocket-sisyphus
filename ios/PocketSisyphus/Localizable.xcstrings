    "수정 지시": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "수정 지시"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Revise"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "修正指示"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "修改指示"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pedir revisión"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Demander une révision"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pedir revisão"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Доработка"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "طلب تعديل"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "संशोधन निर्देश"
          }
        }
      }
    },
    "수정 지시 — 티켓에 코멘트 달듯 한 줄로 방향을 일러 주면, 에이전트가 그 의견을 반영해 브리프를 다시 다듬어요. 승인 전에 끼어드는 통로예요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "توجيه التعديل — اترك توجيهًا من سطر واحد كأنك تعلّق على تذكرة، فيعيد الوكيل صياغة الموجز ليعكسه. إنها وسيلتك للتدخّل قبل الموافقة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Revise — leave a one-line steer, like a comment on a ticket, and the agent reworks the brief to reflect it. It’s your way to step in before approving."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Indicar cambios — deja una orientación de una línea, como un comentario en un tíquet, y el agente reelabora el informe para reflejarla. Es tu vía para intervenir antes de aprobar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Demander une révision — laissez une orientation d’une ligne, comme un commentaire sur un ticket, et l’agent retravaille le brief pour la prendre en compte. C’est votre moyen d’intervenir avant d’approuver."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "संशोधन निर्देश — टिकट पर टिप्पणी की तरह एक पंक्ति में दिशा बताएँ, और एजेंट उस राय को शामिल करके ब्रीफ़ को फिर से निखारता है। यह स्वीकृति से पहले हस्तक्षेप का रास्ता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "修正指示 — チケットにコメントするように一行で方向を伝えると、エージェントがその意見を反映してブリーフを練り直します。承認前に介入できる通り道です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "수정 지시 — 티켓에 코멘트 달듯 한 줄로 방향을 일러 주면, 에이전트가 그 의견을 반영해 브리프를 다시 다듬어요. 승인 전에 끼어드는 통로예요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pedir revisão — deixe uma orientação de uma linha, como um comentário num tíquete, e o agente refaz o brief para refleti-la. É sua via para intervir antes de aprovar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Доработать — оставьте однострочное указание, как комментарий к тикету, и агент переработает бриф с его учётом. Это ваш способ вмешаться до одобрения."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "修改指示——像在工单上留言那样用一行给出方向，智能体便会据此重新打磨简报。这是你在批准前介入的通道。"
          }
        }
      }
    },
    "수정 지시로 방향을 알려주면 다음 제안이 좋아져요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أخبر الوكيل بالاتجاه عبر تعليمات التعديل وستتحسن المقترحات القادمة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Give direction with revision requests and the next proposals will improve."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Indica la dirección con instrucciones de revisión y las próximas propuestas mejorarán."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Donnez la direction via des demandes de révision et les prochaines propositions s’amélioreront."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "संशोधन निर्देश से दिशा बताएँ — अगले प्रस्ताव बेहतर होंगे।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "修正指示で方向を伝えると、次の提案が良くなります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "수정 지시로 방향을 알려주면 다음 제안이 좋아져요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Dê a direção com instruções de revisão e as próximas propostas vão melhorar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Укажите направление через правки — следующие предложения станут лучше."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通过修改指示给出方向，下次的提案会更好。"
          }
        }
      }
    },
