          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ver ayuda para evitar el bloqueo de Tor"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Voir l'aide pour contourner le blocage de Tor"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor ब्लॉक को बायपास करने में मदद देखें"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor ブロックの回避ヘルプを見る"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor 차단 우회 도움말 보기"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ver ajuda para contornar o bloqueio do Tor"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Помощь по обходу блокировки Tor"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "查看绕过 Tor 屏蔽的帮助"
          }
        }
      }
    },
    "Tor 회로 빌드를 미리 데우기 위해 백그라운드에서 health 한 번 호출해 둡니다. 그래서 직접 SSH 가 안 잡히는 환경에서도 세션 화면 첫 진입이 빠르게 느껴집니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "نُجري استدعاء health مرة واحدة في الخلفية لتسخين بناء دائرة Tor مسبقاً. لذا حتى في البيئات التي لا يتوفر فيها SSH المباشر، يبدو الدخول الأول إلى شاشة الجلسة سريعاً."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We make a single health call in the background to pre-warm the Tor circuit build. That way, even in environments without direct SSH, the first entry to the session screen still feels fast."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hacemos una llamada de health en segundo plano para precalentar la construcción del circuito Tor. Así, incluso en entornos sin SSH directo, la primera entrada a la pantalla de sesión se siente rápida."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous faisons un appel health en arrière-plan pour préchauffer la construction du circuit Tor. Ainsi, même sans SSH direct, la première entrée dans l’écran de session reste rapide."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor सर्किट बिल्ड को पहले से गर्म रखने के लिए हम बैकग्राउंड में एक बार health कॉल कर देते हैं। इसलिए जिन वातावरणों में सीधा SSH उपलब्ध नहीं है, वहाँ भी सत्र स्क्रीन में पहली बार प्रवेश तेज़ महसूस होता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor 回路ビルドを事前に温めるためにバックグラウンドで health を 1 回呼び出しておきます。これにより、直接 SSH が掴めない環境でもセッション画面への初回遷移が速く感じられます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Fazemos uma chamada de health em background para pré-aquecer o build do circuito Tor. Assim, mesmo em ambientes sem SSH direto, a primeira entrada na tela de sessão parece rápida."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "В фоне мы делаем один вызов health, чтобы заранее «разогреть» сборку Tor-цепочки. Поэтому даже в средах без прямого SSH первый переход на экран сессии ощущается быстрым."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为了预热 Tor 电路构建，我们会在后台调用一次 health。这样即使在直连 SSH 不可达的环境下，首次进入会话界面也会感觉很快。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor 회로 빌드를 미리 데우기 위해 백그라운드에서 health 한 번 호출해 둡니다. 그래서 직접 SSH 가 안 잡히는 환경에서도 세션 화면 첫 진입이 빠르게 느껴집니다."
          }
        }
      }
    },
    "Tor 회로 재빌드": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
