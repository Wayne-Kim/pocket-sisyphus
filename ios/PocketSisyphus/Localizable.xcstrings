        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Estes são os dispositivos autorizados neste Mac e o horário da última conexão. Para revogar um dispositivo ou permitir dispositivos adicionais, vá em «Gerenciar dispositivos»."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это устройства, авторизованные на этом Mac, и время их последнего подключения. Чтобы отозвать устройство или разрешить дополнительные устройства, перейдите в «Управление устройствами»."
          }
