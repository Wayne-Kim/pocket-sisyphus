    "커밋되지 않은 변경사항이 사라질 수 있어요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قد تُفقد التغييرات غير المُلتزَمة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Uncommitted changes may be lost."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los cambios sin confirmar pueden perderse."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les modifications non validées peuvent être perdues."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बिना कमिट किए बदलाव खो सकते हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コミットしていない変更が失われる可能性があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "커밋되지 않은 변경사항이 사라질 수 있어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Alterações não commitadas podem ser perdidas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Незакоммиченные изменения могут быть потеряны."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未提交的更改可能会丢失。"
          }
        }
      }
    },
