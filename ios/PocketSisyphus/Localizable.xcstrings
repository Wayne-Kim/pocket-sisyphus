    "기기에 저장된 송신 이력만 지웁니다. 서버에 도달한 메시지는 그대로 남아요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحذف فقط سجل الإرسال المخزَّن على الجهاز. تظل الرسائل التي وصلت إلى الخادم كما هي."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Only the send history stored on this device is cleared. Messages that reached the server stay as they are."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo se borra el historial de envíos guardado en este dispositivo. Los mensajes que llegaron al servidor se mantienen tal cual."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Seul l’historique d’envoi stocké sur cet appareil est effacé. Les messages déjà arrivés sur le serveur restent intacts."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "केवल इस डिवाइस पर सहेजा गया भेजने का इतिहास मिटता है। सर्वर तक पहुँचे संदेश वैसे ही रहते हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "端末に保存された送信履歴のみを削除します。サーバーに届いたメッセージはそのまま残ります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기기에 저장된 송신 이력만 지웁니다. 서버에 도달한 메시지는 그대로 남아요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Apaga apenas o histórico de envio guardado neste dispositivo. As mensagens que chegaram ao servidor continuam lá."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удаляется только история отправки, сохранённая на устройстве. Сообщения, дошедшие до сервера, остаются."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "只会清除本机保存的发送历史,已抵达服务器的消息保持不变。"
          }
        }
      }
    },
