    "커서 이동 — 천천히 움직이면 정밀, 빠르게 밀면 멀리": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حرِّك المؤشر — ببطء للدقة، وبسرعة للوصول بعيدًا"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Move the cursor — slow for precision, flick fast to go far"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mueve el cursor: despacio para precisión, rápido para llegar lejos"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Déplacez le curseur — lentement pour la précision, rapidement pour aller loin"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कर्सर हिलाएँ — धीरे चलाने पर सटीक, तेज़ी से करने पर दूर तक"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カーソルを移動 — ゆっくりで正確に、素早く動かすと遠くへ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "커서 이동 — 천천히 움직이면 정밀, 빠르게 밀면 멀리"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mova o cursor — devagar para precisão, rápido para ir longe"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перемещайте курсор — медленно для точности, резко — чтобы уйти далеко"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "移动光标 —— 慢移更精准，快滑则移动更远"
          }
        }
      }
    },
