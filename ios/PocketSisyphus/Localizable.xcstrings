            "state": "translated",
            "value": "موافقة"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Approve"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aprobar"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Autoriser"
          }
        },
        "hi": {
          "stringUnit": {
