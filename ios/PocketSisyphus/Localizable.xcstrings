    "이미지 없이 코멘트만 첨부할 수 있어요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يمكنك إرفاق التعليق فقط دون الصورة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can attach just the comment without the image."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes adjuntar solo el comentario, sin la imagen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous pouvez joindre seulement le commentaire, sans l'image."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आप छवि के बिना केवल टिप्पणी संलग्न कर सकते हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "画像なしでコメントだけを添付できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이미지 없이 코멘트만 첨부할 수 있어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você pode anexar apenas o comentário, sem a imagem."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Можно прикрепить только комментарий без изображения."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你可以只附上评论，而不附图片。"
          }
        }
      }
    },
    "이미지 없이 코멘트와 프리뷰 주소만 첨부할 수 있어요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يمكنك إرفاق التعليق وعنوان المعاينة فقط دون الصورة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can attach just the comment and preview address without the image."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes adjuntar solo el comentario y la dirección de la vista previa, sin la imagen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous pouvez joindre seulement le commentaire et l'adresse de l'aperçu, sans l'image."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आप छवि के बिना केवल टिप्पणी और प्रीव्यू पता संलग्न कर सकते हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "画像なしでコメントとプレビューのアドレスだけを添付できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이미지 없이 코멘트와 프리뷰 주소만 첨부할 수 있어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você pode anexar apenas o comentário e o endereço da prévia, sem a imagem."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Можно прикрепить только комментарий и адрес превью без изображения."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你可以只附上评论和预览地址，而不附图片。"
          }
        }
      }
    },
