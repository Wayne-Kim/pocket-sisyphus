    "client-auth 키 — Tor v3 클라이언트 인증 키. 이 키 없이는 onion 주소가 있어도 접근 불가.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مفتاح client-auth — مفتاح مصادقة عميل Tor v3. بدونه لا يمكن الوصول حتى مع معرفة عنوان Onion."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "client-auth key — Tor v3 client authorization key. Without it the onion address alone can’t reach the service."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Clave client-auth — clave de autorización de cliente Tor v3. Sin ella, ni siquiera conociendo la dirección Onion se puede llegar al servicio."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Clé client-auth — clé d’autorisation client Tor v3. Sans elle, connaître l’adresse Onion ne suffit pas à atteindre le service."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "client-auth कुंजी — Tor v3 क्लाइंट ऑथराइज़ेशन कुंजी। इसके बिना Onion पता जानने पर भी पहुँचा नहीं जा सकता।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "client-auth キー — Tor v3 クライアント認可キー。これがないと onion アドレスを知っていてもサービスに到達できません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "client-auth 키 — Tor v3 클라이언트 인증 키. 이 키 없이는 onion 주소가 있어도 접근 불가."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Chave client-auth — chave de autorização de cliente Tor v3. Sem ela, mesmo conhecendo o endereço Onion não se acessa."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ключ client-auth — ключ авторизации клиента Tor v3. Без него даже зная onion-адрес, к сервису не подключиться."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "client-auth 密钥 — Tor v3 客户端授权密钥。没有它,即使知道 onion 地址也无法访问服务。"
          }
        }
      }
    },
    "client-auth 키 — Tor 의 ClientOnionAuthDir 안 .auth_private 파일.": {
