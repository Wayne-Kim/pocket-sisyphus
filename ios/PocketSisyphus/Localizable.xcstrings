    "검증됨 — 다음 수집이 가설이 맞았다고 확인했어요 (초록 배지, 성공 신호).": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم التحقّق — أكّدت عملية الجمع التالية أن الفرضية كانت صحيحة (شارة خضراء، إشارة نجاح)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Validated — the next collection confirmed the hypothesis was right (green badge, a success signal)."
          }
        },
        "es": {
          "stringUnit": {
