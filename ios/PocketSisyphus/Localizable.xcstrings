    "7일 무료로 시작하고 마음에 들면 계속 — 언제든 해지할 수 있어요.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ابدأ بـ 7 أيام مجانية وتابع إذا أعجبك — يمكنك الإلغاء في أي وقت."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start with 7 days free and keep it if you like it — cancel anytime."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Empieza con 7 días gratis y continúa si te gusta: cancela cuando quieras."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Commencez avec 7 jours gratuits et continuez si ça vous plaît — annulez à tout moment."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "7 दिन मुफ़्त शुरू करें और पसंद आए तो जारी रखें — कभी भी रद्द करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まず7日間無料でお試し、気に入ったら継続 — いつでも解約できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "7일 무료로 시작하고 마음에 들면 계속 — 언제든 해지할 수 있어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Comece com 7 dias grátis e continue se gostar — cancele quando quiser."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Начните с 7 дней бесплатно и продолжайте, если понравится — отмена в любой момент."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "先免费试用 7 天，喜欢就继续——随时可取消。"
          }
        }
      }
    },
