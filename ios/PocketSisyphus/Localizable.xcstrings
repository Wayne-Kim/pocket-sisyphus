    "지금 승인을 기다리는 요청이 없어요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا توجد طلبات تنتظر الموافقة في الوقت الحالي."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No requests are waiting for approval right now."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay solicitudes esperando aprobación ahora mismo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucune demande n’attend d’approbation pour le moment."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अभी कोई अनुरोध स्वीकृति की प्रतीक्षा में नहीं है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在、承認待ちのリクエストはありません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "지금 승인을 기다리는 요청이 없어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhuma solicitação aguardando aprovação no momento."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сейчас нет запросов, ожидающих одобрения."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "目前没有等待批准的请求。"
          }
        }
      }
    },
    "각 요청이 무엇을 바꾸려는지 확인하고, 골라서 승인하거나 모두 한 번에 승인하세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تحقق مما سيغيّره كل طلب، ثم وافق على المحدد منها أو على الكل دفعة واحدة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Check what each request will change, then approve selected ones or all at once."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comprueba qué cambiará cada solicitud y aprueba las seleccionadas o todas a la vez."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vérifiez ce que chaque demande va modifier, puis approuvez celles sélectionnées ou toutes en une fois."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "देखें कि प्रत्येक अनुरोध क्या बदलेगा, फिर चुने हुए या सभी को एक साथ स्वीकृत करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "各リクエストが何を変更するかを確認し、選んで承認するか、一度にすべて承認します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "각 요청이 무엇을 바꾸려는지 확인하고, 골라서 승인하거나 모두 한 번에 승인하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Verifique o que cada solicitação vai alterar e aprove as selecionadas ou todas de uma vez."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Проверьте, что изменит каждый запрос, затем одобрите выбранные или все сразу."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "查看每个请求将更改的内容，然后批准所选项或一次性全部批准。"
          }
        }
      }
    },
