      }
    },
    "무인 실행이라 기본 켜짐 — 끄면 권한 확인에서 멈출 수 있어요.": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "무인 실행이라 기본 켜짐 — 끄면 권한 확인에서 멈출 수 있어요."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "On by default for unattended runs — if off, it may pause for permission prompts."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无人值守运行默认开启 — 关闭后可能会在权限确认处暂停。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "無人実行のため既定でオン — オフにすると権限確認で止まることがあります。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activado por defecto para ejecuciones desatendidas; si lo desactivas, puede detenerse pidiendo permisos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activé par défaut pour les exécutions sans surveillance — désactivé, il peut s’arrêter pour demander des autorisations."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مُفعَّل افتراضيًا للتشغيل دون إشراف — عند إيقافه قد يتوقّف لطلب الأذونات."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ativado por padrão para execuções autônomas — se desativado, pode parar pedindo permissões."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Включено по умолчанию для автономных запусков — если выключить, может останавливаться на запросах разрешений."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बिना निगरानी वाले रन के लिए डिफ़ॉल्ट रूप से चालू — बंद करने पर अनुमति के लिए रुक सकता है।"
          }
        }
      }
    },
