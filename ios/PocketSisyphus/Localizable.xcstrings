          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Réessayer"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إعادة المحاولة"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tentar novamente"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Повторить"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पुनः प्रयास"
          }
        }
      }
    },
    "재시작이 필요한 이유: iOS 의 다국어 시스템은 앱이 부팅할 때 한 번 결정되고 그 뒤로는 바뀌지 않습니다. 그래서 언어를 새로 고르면 앱을 닫았다 다시 열어야 적용됩니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لماذا تلزم إعادة التشغيل: نظام i18n في iOS يحدّد اللغة عند إقلاع التطبيق ولا يغيّرها بعد ذلك. لذلك يلزم إغلاق التطبيق وإعادة فتحه لتطبيق اختيار اللغة الجديد."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Why a restart is needed: iOS resolves the app’s language once at launch and doesn’t change it afterward. So you need to quit and reopen the app for the new language to take effect."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Por qué se necesita reiniciar: iOS decide el idioma de la app al iniciarla y luego no lo cambia. Así que hace falta cerrar y volver a abrir la app para aplicar el nuevo idioma."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pourquoi un redémarrage : iOS résout la langue de l’app au lancement et ne la change plus ensuite. Il faut donc quitter et rouvrir l’app pour appliquer la nouvelle langue."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पुनः आरंभ क्यों ज़रूरी: iOS ऐप की भाषा बूट होते समय ही तय करता है और बाद में नहीं बदलता। इसलिए नई भाषा लागू करने के लिए ऐप बंद करके दोबारा खोलना पड़ता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "再起動が必要な理由: iOS の多言語システムはアプリ起動時に一度言語を決定し、その後は変更しません。そのため新しい言語の選択を反映するにはアプリを一度終了して開き直す必要があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "재시작이 필요한 이유: iOS 의 다국어 시스템은 앱이 부팅할 때 한 번 결정되고 그 뒤로는 바뀌지 않습니다. 그래서 언어를 새로 고르면 앱을 닫았다 다시 열어야 적용됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Por que reiniciar: o iOS resolve o idioma do app uma vez na inicialização e não muda depois. Por isso é preciso fechar e abrir o app para aplicar o novo idioma."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Зачем перезапуск: iOS определяет язык приложения один раз при запуске и потом не меняет. Поэтому для нового языка нужно закрыть и снова открыть приложение."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为何需要重启:iOS 在应用启动时决定一次语言,之后不会再变。所以要让新语言生效,必须关闭并重新打开应用。"
          }
        }
      }
    },
    "재실행": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إعادة التشغيل"
          }
        },
        "en": {
          "stringUnit": {
