    "스크롤 / 드래그 — 좌측 모드 버튼으로 한 손가락 제스처를 스크롤 또는 드래그로 바꿉니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "التمرير / السحب — استخدم أزرار الوضع على اليسار لتبديل إيماءة الإصبع الواحد بين التمرير والسحب."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Scroll / Drag — use the mode buttons on the left to switch the one-finger gesture to scrolling or dragging."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desplazar / Arrastrar: usa los botones de modo de la izquierda para cambiar el gesto de un dedo a desplazamiento o arrastre."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Défiler / Glisser — utilisez les boutons de mode à gauche pour basculer le geste à un doigt en défilement ou en glissement."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्क्रॉल / ड्रैग — बाईं ओर के मोड बटनों से एक-उँगली के जेस्चर को स्क्रॉल या ड्रैग में बदलें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スクロール / ドラッグ — 左側のモードボタンで、1本指ジェスチャをスクロールまたはドラッグに切り替えます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "스크롤 / 드래그 — 좌측 모드 버튼으로 한 손가락 제스처를 스크롤 또는 드래그로 바꿉니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Rolar / Arrastar — use os botões de modo à esquerda para alternar o gesto de um dedo entre rolagem e arrasto."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Прокрутка / Перетаскивание — кнопками режима слева переключите жест одним пальцем на прокрутку или перетаскивание."
          }
        },
