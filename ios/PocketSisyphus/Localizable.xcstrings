      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذّر فك تشفير محتوى الاستجابة بكلٍّ من base64 و UTF-8."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Response body could not be decoded as base64 or UTF-8."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El cuerpo de la respuesta no pudo decodificarse ni en base64 ni en UTF-8."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le corps de la réponse n’a pu être décodé ni en base64 ni en UTF-8."
          }
