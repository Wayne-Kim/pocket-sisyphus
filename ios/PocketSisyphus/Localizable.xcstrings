    "창을 고르면 그 창만 보내요 — 더 선명하고, 다른 앱·알림은 보이지 않아요.": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "창을 고르면 그 창만 보내요 — 더 선명하고, 다른 앱·알림은 보이지 않아요."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pick a window to send only that window — sharper, and other apps and notifications stay hidden."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر نافذة لإرسال تلك النافذة فقط — أوضح، وتبقى التطبيقات والإشعارات الأخرى مخفية."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige una ventana para enviar solo esa ventana: más nítida y otras apps y notificaciones quedan ocultas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez une fenêtre pour n’envoyer que celle-ci — plus nette, et les autres apps et notifications restent masquées."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "केवल वही विंडो भेजने के लिए एक विंडो चुनें — अधिक स्पष्ट, और अन्य ऐप्स व सूचनाएँ छिपी रहती हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ウインドウを選ぶとそのウインドウだけを送ります — より鮮明で、他のアプリや通知は表示されません。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha uma janela para enviar apenas ela — mais nítida, e outros apps e notificações ficam ocultos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите окно, чтобы отправлять только его — чётче, а другие приложения и уведомления остаются скрытыми."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择一个窗口只发送该窗口——更清晰，其他应用和通知都不会显示。"
          }
        }
      }
    },
    "창이 닫혀 전체 화면으로 돌아왔어요": {
