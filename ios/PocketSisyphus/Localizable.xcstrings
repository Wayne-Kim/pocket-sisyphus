    "매번 도구 사용을 물어보지 않습니다. 신뢰하는 레포에서만 켜세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لن يُطلب منك إذن استخدام الأدوات في كل مرة. فعّل هذا فقط في المستودعات الموثوقة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Won’t ask before each tool use. Only enable on trusted repos."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No te preguntará antes de cada uso de herramienta. Actívalo solo en repositorios de confianza."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ne demandera pas avant chaque utilisation d’outil. À n’activer que sur des dépôts de confiance."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हर बार टूल उपयोग के लिए नहीं पूछेगा। केवल विश्वसनीय रिपॉजिटरी पर सक्षम करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ツール使用のたびに確認しません。信頼できるリポジトリでのみ有効化してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "매번 도구 사용을 물어보지 않습니다. 신뢰하는 레포에서만 켜세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não vai perguntar antes de cada uso de ferramenta. Ative apenas em repositórios confiáveis."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не будет спрашивать перед каждым использованием инструмента. Включайте только в доверенных репозиториях."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "不会在每次使用工具前询问。仅在受信任的仓库中启用。"
          }
        }
      }
    },
