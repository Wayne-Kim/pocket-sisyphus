          }
        }
      }
    },
    "SSH host key 불일치 — 신뢰할 수 없는 서버 (중간자 공격 가능성)": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عدم تطابق مفتاح مضيف SSH — خادم غير موثوق (احتمال هجوم الوسيط)"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "SSH host key mismatch — untrusted server (possible man-in-the-middle attack)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Discrepancia en la clave de host SSH: servidor no confiable (posible ataque de intermediario)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Clé d’hôte SSH non concordante — serveur non fiable (attaque de l’intercepteur possible)"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "SSH होस्ट कुंजी बेमेल — अविश्वसनीय सर्वर (संभावित मैन-इन-द-मिडल हमला)"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "SSH ホストキーの不一致 — 信頼できないサーバー (中間者攻撃の可能性)"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "SSH host key 불일치 — 신뢰할 수 없는 서버 (중간자 공격 가능성)"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Incompatibilidade da chave de host SSH — servidor não confiável (possível ataque man-in-the-middle)"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Несовпадение ключа хоста SSH — недоверенный сервер (возможна атака «человек посередине»)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
