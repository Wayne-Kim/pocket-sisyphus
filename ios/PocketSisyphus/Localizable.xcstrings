    "고정 와이드로 둡니다. 화면보다 넓으면 가로로 스크롤해서 봅니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اعرض بعرض عريض ثابت. إذا تجاوز عرض الشاشة، يمكنك التمرير أفقيًا."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep a fixed wide width. If it's wider than the screen, scroll horizontally to view."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén un ancho fijo y amplio. Si supera el ancho de la pantalla, desplázate horizontalmente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Conserve une largeur fixe et large. Si c'est plus large que l'écran, faites défiler horizontalement."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक निश्चित चौड़ी चौड़ाई रखें. यदि स्क्रीन से चौड़ा हो, तो क्षैतिज रूप से स्क्रॉल करके देखें."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "固定のワイド幅にします。画面より広い場合は横スクロールで表示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "고정 와이드로 둡니다. 화면보다 넓으면 가로로 스크롤해서 봅니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantém uma largura fixa e ampla. Se for mais largo que a tela, role horizontalmente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используется фиксированная широкая ширина. Если шире экрана — прокручивайте по горизонтали."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保持固定的宽屏宽度。若超出屏幕宽度，可横向滚动查看。"
          }
        }
      }
    },
