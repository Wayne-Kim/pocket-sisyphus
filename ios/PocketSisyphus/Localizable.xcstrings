    "대기 중인 세션의 기본 선택지를 그대로 승인합니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الموافقة على الخيار الافتراضي لكل جلسة منتظرة كما هو."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Approves each waiting session's default choice as-is."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aprueba la opción predeterminada de cada sesión en espera tal cual."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Approuve le choix par défaut de chaque session en attente tel quel."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हर प्रतीक्षारत सत्र का डिफ़ॉल्ट विकल्प जैसा है वैसा स्वीकृत करता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "待機中の各セッションの既定の選択肢をそのまま承認します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "대기 중인 세션의 기본 선택지를 그대로 승인합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Aprova a opção padrão de cada sessão em espera como está."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Одобряет вариант по умолчанию для каждой ожидающей сессии."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按原样批准每个等待中会话的默认选项。"
          }
        }
      }
    },
    "대화 기록 — Mac 측 daemon 의 sqlite. 모바일은 매번 fetch 만 하고 영구 저장은 안 합니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سجل المحادثة — في sqlite الخاص بـ daemon على Mac. الهاتف يجلبه فقط في كل مرة ولا يخزّنه بشكل دائم."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Chat history — in the Mac daemon’s sqlite. Mobile only fetches each time and doesn’t persist it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Historial — en sqlite del daemon del Mac. El móvil solo lo descarga cada vez y no lo persiste."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Historique — dans sqlite du daemon Mac. Le mobile ne fait que le récupérer à chaque fois, sans le conserver."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चैट इतिहास — Mac के daemon के sqlite में। मोबाइल हर बार सिर्फ़ fetch करता है, स्थायी रूप से नहीं रखता।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "会話履歴 — Mac 側 daemon の sqlite。モバイルは毎回フェッチするだけで、永続保存しません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "대화 기록 — Mac 측 daemon 의 sqlite. 모바일은 매번 fetch 만 하고 영구 저장은 안 합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Histórico — no sqlite do daemon do Mac. O celular apenas faz fetch cada vez e não persiste."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "История чата — в sqlite демона на Mac. Мобильный только подгружает её каждый раз, не сохраняя."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "聊天记录 — 存于 Mac 端 daemon 的 sqlite。手机每次只 fetch,不做持久化。"
          }
        }
      }
    },
    "대화 기록 — Mac 측 데스크탑 앱의 sqlite. 모바일은 매번 fetch 만 하고 영구 저장은 안 합니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سجل المحادثات — في sqlite الخاص بتطبيق سطح المكتب على Mac. الجوال يجلبها فقط في كل مرة ولا يحفظها بشكل دائم."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Conversation history — in the Mac desktop app’s sqlite. Mobile only fetches each time and never stores it persistently."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Historial de conversaciones — en el sqlite de la app de escritorio del Mac. El móvil solo hace fetch cada vez y no lo guarda de forma persistente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Historique des conversations — dans le sqlite de l’app de bureau du Mac. Le mobile ne fait que le récupérer à chaque fois et ne le stocke jamais durablement."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बातचीत का इतिहास — Mac के डेस्कटॉप ऐप के sqlite में। मोबाइल हर बार सिर्फ fetch करता है, स्थायी रूप से कुछ नहीं संग्रहीत करता।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "会話履歴 — Mac 側デスクトップアプリの sqlite。モバイルは毎回 fetch するだけで永続保存はしません。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Histórico de conversas — no sqlite do app de desktop do Mac. O mobile só faz fetch a cada vez e nunca armazena de forma persistente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "История разговоров — в sqlite десктоп-приложения на Mac. Мобильное приложение только получает её при каждом запросе и нигде не сохраняет постоянно."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "对话历史 — 存于 Mac 桌面应用的 sqlite。手机端每次仅 fetch，不做持久化存储。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "대화 기록 — Mac 측 데스크탑 앱의 sqlite. 모바일은 매번 fetch 만 하고 영구 저장은 안 합니다."
          }
        }
      }
    },
    "대화 기록, 도구 승인, 질문, 그리고 모델 컨텍스트가 모두 초기화됩니다. 세션 자체는 유지됩니다. 되돌릴 수 없어요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ستتم إعادة تعيين سجل المحادثة وموافقات الأدوات والأسئلة وسياق النموذج بالكامل. ستبقى الجلسة نفسها. لا يمكن التراجع."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Chat history, tool approvals, questions, and the model context all reset. The session itself remains. This can’t be undone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se reinician el historial de chat, las aprobaciones de herramientas, las preguntas y el contexto del modelo. La sesión se mantiene. No se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’historique de chat, les autorisations d’outils, les questions et le contexte du modèle sont tous réinitialisés. La session reste. Action irréversible."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चैट इतिहास, टूल अनुमोदन, प्रश्न और मॉडल कॉन्टेक्स्ट सभी रीसेट हो जाएँगे। सत्र बना रहेगा। यह क्रिया वापस नहीं ली जा सकती।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "会話履歴・ツール承認・質問・モデル コンテキストがすべてリセットされます。セッション自体は残ります。元には戻せません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "대화 기록, 도구 승인, 질문, 그리고 모델 컨텍스트가 모두 초기화됩니다. 세션 자체는 유지됩니다. 되돌릴 수 없어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Histórico do chat, aprovações de ferramentas, perguntas e contexto do modelo serão todos zerados. A sessão em si permanece. Ação irreversível."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "История чата, разрешения инструментов, вопросы и контекст модели будут сброшены. Сама сессия сохранится. Отменить нельзя."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "聊天记录、工具批准、提问及模型上下文都将重置。会话本身将保留。此操作无法撤销。"
          }
        }
      }
    },
