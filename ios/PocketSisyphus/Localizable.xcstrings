            "state": "translated",
            "value": "Démarrer une nouvelle session"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नया सत्र शुरू करें"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "新しいセッションを開始"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
