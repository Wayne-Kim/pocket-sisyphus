    "제약 조건에 걸려 건너뛰었어요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم التخطّي بسبب بلوغ أحد القيود."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Skipped because a constraint was hit."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se omitió porque se alcanzó una restricción."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ignoré car une contrainte a été atteinte."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक प्रतिबंध लगने के कारण इसे छोड़ दिया गया।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "制約に達したためスキップしました。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "제약 조건에 걸려 건너뛰었어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ignorado porque uma restrição foi atingida."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пропущено из-за достигнутого ограничения."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "因触及限制而跳过。"
          }
        }
      }
    },
