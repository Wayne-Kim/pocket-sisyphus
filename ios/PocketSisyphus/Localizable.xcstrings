    "보관 세션 %lld건을 삭제할까요? 되돌릴 수 없습니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هل تريد حذف %lld جلسة مؤرشفة؟ لا يمكن التراجع عن هذا."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Delete %lld archived sessions? This cannot be undone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Eliminar %lld sesiones archivadas? Esta acción no se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprimer %lld sessions archivées ? Cette action est irréversible."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld संग्रहित सत्र हटाएँ? इसे पूर्ववत नहीं किया जा सकता।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アーカイブ済みセッション%lld件を削除しますか？元に戻せません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "보관 세션 %lld건을 삭제할까요? 되돌릴 수 없습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Excluir %lld sessões arquivadas? Isso não pode ser desfeito."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удалить %lld архивных сессий? Это действие нельзя отменить."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "删除 %lld 个已归档会话？此操作无法撤销。"
