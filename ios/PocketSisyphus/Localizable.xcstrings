            "state": "translated",
            "value": "يُسجَّل لكي يمكن استخدام الأداة في جلسات هذا الوكيل."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Registered so the tool can be used in this agent’s sessions."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
