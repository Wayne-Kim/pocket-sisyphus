    "세션을 만들어 에이전트를 실행 중이에요. 끝나면 알림이 와요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم إنشاء جلسة والوكيل قيد التشغيل. وسيصلك إشعار عند الانتهاء."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A session was created and the agent is running. You’ll get a notification when it finishes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se creó una sesión y el agente se está ejecutando. Recibirás una notificación al terminar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une session a été créée et l’agent s’exécute. Vous recevrez une notification à la fin."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक सत्र बनाया गया और एजेंट चल रहा है। पूरा होने पर सूचना मिलेगी।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "セッションを作成し、エージェントを実行中です。終了すると通知が届きます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "세션을 만들어 에이전트를 실행 중이에요. 끝나면 알림이 와요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Uma sessão foi criada e o agente está em execução. Você receberá uma notificação ao concluir."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
