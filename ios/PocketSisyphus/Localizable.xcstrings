    "저장공간이 부족해 음성 모델을 받을 수 없어요. 공간을 확보한 뒤 다시 시도해 주세요.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا توجد مساحة تخزين كافية لتنزيل نموذج الصوت. حرّر بعض المساحة وأعد المحاولة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Not enough storage to download the speech model. Free up space and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay espacio suficiente para descargar el modelo de voz. Libera espacio e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Espace de stockage insuffisant pour télécharger le modèle vocal. Libérez de l'espace et réessayez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वाक् मॉडल डाउनलोड करने के लिए पर्याप्त संग्रहण नहीं है। स्थान खाली करें और पुनः प्रयास करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ストレージ容量が足りないため音声モデルをダウンロードできません。空き容量を確保してからもう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "저장공간이 부족해 음성 모델을 받을 수 없어요. 공간을 확보한 뒤 다시 시도해 주세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Espaço de armazenamento insuficiente para baixar o modelo de voz. Libere espaço e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Недостаточно места для загрузки модели распознавания речи. Освободите место и повторите попытку."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "存储空间不足，无法下载语音模型。请释放空间后重试。"
          }
        }
      }
    },
    "저장된 스니펫이 없어요. 위 칸에 적어 추가해요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا توجد مقتطفات محفوظة بعد. اكتب واحدًا في الأعلى لإضافته."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No saved snippets yet. Type one above to add it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no hay fragmentos guardados. Escribe uno arriba para añadirlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun extrait enregistré. Saisissez-en un ci-dessus pour l'ajouter."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अभी कोई सहेजा हुआ स्निपेट नहीं है। ऊपर लिखकर जोड़ें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保存されたスニペットはありません。上の欄に入力して追加できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "저장된 스니펫이 없어요. 위 칸에 적어 추가해요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ainda não há trechos salvos. Digite um acima para adicionar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сохранённых сниппетов пока нет. Введите текст выше, чтобы добавить."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "还没有保存的片段。在上方输入即可添加。"
          }
        }
      }
    },
    "저장된 페어링을 지우고 Mac 의 새 QR 을 다시 스캔합니다. 계속 연결되지 않을 때, Mac 에서 앱을 새로 설치했거나 페어링 값이 바뀐 경우 도움이 됩니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يؤدي هذا إلى مسح الاقتران المحفوظ ومسح رمز QR جديد من جهاز Mac. يفيد عندما يستمر فشل الاتصال — مثل بعد إعادة تثبيت تطبيق Mac أو عند تغيّر بيانات الاقتران."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This clears the saved pairing and scans a new QR code from your Mac. Helpful when the connection keeps failing — for example, after reinstalling the Mac app or when the pairing changed."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto borra el emparejamiento guardado y escanea un nuevo código QR de tu Mac. Útil cuando la conexión sigue fallando, por ejemplo tras reinstalar la app de Mac o cuando el emparejamiento cambió."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela efface l’appairage enregistré et scanne un nouveau QR code depuis votre Mac. Utile lorsque la connexion échoue sans cesse — par exemple après une réinstallation de l’app Mac ou lorsque l’appairage a changé."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इससे सहेजी गई पेयरिंग मिट जाती है और आपके Mac से नया QR कोड स्कैन होता है। जब कनेक्शन बार-बार विफल होता रहे — जैसे Mac ऐप दोबारा इंस्टॉल करने के बाद या पेयरिंग बदल जाने पर — तब यह मदद करता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保存済みのペアリングを消去し、Macの新しいQRを再スキャンします。接続に失敗し続けるとき（Macアプリを再インストールした、ペアリング値が変わったときなど）に役立ちます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "저장된 페어링을 지우고 Mac 의 새 QR 을 다시 스캔합니다. 계속 연결되지 않을 때, Mac 에서 앱을 새로 설치했거나 페어링 값이 바뀐 경우 도움이 됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso apaga o pareamento salvo e escaneia um novo QR code do seu Mac. Útil quando a conexão continua falhando — por exemplo, após reinstalar o app do Mac ou quando o pareamento mudou."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это удалит сохранённое сопряжение и отсканирует новый QR-код с вашего Mac. Помогает, когда подключение постоянно не удаётся — например, после переустановки приложения на Mac или при изменении данных сопряжения."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这会清除已保存的配对，并重新扫描 Mac 上的新二维码。当连接持续失败时（例如重新安装了 Mac 应用，或配对信息已更改）会有帮助。"
          }
        }
      }
    },
