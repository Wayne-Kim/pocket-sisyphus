    "이 브리프는 목록에서 사라졌어요. 삭제됐을 수 있어요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يعد هذا الموجز موجودًا في القائمة. ربما تم حذفه."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This brief is no longer in the list. It may have been deleted."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este resumen ya no está en la lista. Es posible que se haya eliminado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce brief n’est plus dans la liste. Il a peut-être été supprimé."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह ब्रीफ़ अब सूची में नहीं है. हो सकता है इसे हटा दिया गया हो."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このブリーフはリストにありません。削除された可能性があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 브리프는 목록에서 사라졌어요. 삭제됐을 수 있어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este resumo não está mais na lista. Pode ter sido excluído."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Этого брифа больше нет в списке. Возможно, он был удалён."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此简报已不在列表中，可能已被删除。"
          }
        }
      }
    },
    "디자인 대비": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تباين التصميم"
