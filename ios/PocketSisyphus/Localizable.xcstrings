    "실행 중인 세션의 진행 중 작업을 중단합니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إيقاف العمل الجاري في الجلسات قيد التشغيل."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Interrupts the in-progress work of running sessions."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Interrumpe el trabajo en curso de las sesiones en ejecución."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Interrompt le travail en cours des sessions actives."
          }
        },
        "hi": {
