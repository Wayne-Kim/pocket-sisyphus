    "내용 비우기": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مسح المحتوى"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clear contents"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaciar contenido"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vider le contenu"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सामग्री साफ़ करें"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "内容を消去"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "내용 비우기"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Limpar conteúdo"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Очистить содержимое"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "清空内容"
          }
        }
      }
    },
    "내용 비우기: 채팅 화면 우상단 점 메뉴 → «내용 비우기». 대화 기록·도구 승인·질문·모델 컨텍스트가 모두 초기화되지만 세션 자체는 유지됩니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مسح المحتوى: من قائمة النقاط أعلى يمين شاشة الدردشة → «مسح المحتوى». تتم إعادة تعيين سجل المحادثة وموافقات الأدوات والأسئلة وسياق النموذج، ولكن تبقى الجلسة نفسها."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clear: ellipsis menu at the top right of the chat → “Clear contents”. Chat history, tool approvals, questions and model context all reset; the session itself stays."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaciar: menú de puntos arriba a la derecha del chat → «Vaciar contenido». Se reinician historial, aprobaciones, preguntas y contexto del modelo; la sesión se mantiene."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vider : menu en haut à droite du chat → « Vider le contenu ». L’historique, les autorisations, les questions et le contexte du modèle sont réinitialisés, la session reste."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "साफ़ करें: चैट के दाईं ओर ऊपर बिंदु मेनू → «सामग्री साफ़ करें»। चैट इतिहास, टूल अनुमोदन, प्रश्न और मॉडल कॉन्टेक्स्ट रीसेट हो जाते हैं, सत्र बना रहता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "内容を消去: チャット画面右上のメニュー → 「内容を消去」。会話履歴・ツール承認・質問・モデルコンテキストはすべてリセットされますが、セッション自体は残ります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "내용 비우기: 채팅 화면 우상단 점 메뉴 → «내용 비우기». 대화 기록·도구 승인·질문·모델 컨텍스트가 모두 초기화되지만 세션 자체는 유지됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Limpar: menu de pontos no canto superior direito do chat → «Limpar conteúdo». Histórico, aprovações, perguntas e contexto do modelo são zerados; a sessão permanece."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Очистка: меню «⋯» в правом верхнем углу чата → «Очистить содержимое». История, разрешения, вопросы и контекст модели сбрасываются, сама сессия сохраняется."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "清空内容:聊天页右上角的菜单 → 「清空内容」。聊天记录、工具批准、提问与模型上下文都将重置,但会话本身保留。"
          }
        }
      }
    },
