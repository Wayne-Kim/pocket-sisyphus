        }
      }
    },
    "이름·레포로 검색": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ابحث بالاسم أو المستودع"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Search by name or repo"
          }
        },
        "es": {
          "stringUnit": {
