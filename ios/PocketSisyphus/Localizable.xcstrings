    "연결할 MCP 서버의 주소를 입력해 주세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أدخل عنوان خادم MCP المراد الاتصال به."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enter the address of the MCP server to connect to."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Introduce la dirección del servidor MCP al que conectar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Saisissez l’adresse du serveur MCP auquel se connecter."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कनेक्ट करने के लिए MCP सर्वर का पता दर्ज करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "接続する MCP サーバーのアドレスを入力してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "연결할 MCP 서버의 주소를 입력해 주세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Insira o endereço do servidor MCP a conectar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Введите адрес MCP-сервера для подключения."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请输入要连接的 MCP 服务器地址。"
          }
        }
      }
    },
    "내 MCP 서버 주소예요. 기본값을 그대로 두거나 직접 운영하는 주소로 바꿀 수 있어요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذا عنوان خادم MCP الخاص بك. اترك القيمة الافتراضية أو غيّرها إلى عنوان تديره بنفسك."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This is your own MCP server address. Keep the default or change it to a server you run yourself."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Es la dirección de tu propio servidor MCP. Mantén el valor por defecto o cámbialo por uno que tú gestiones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "C’est l’adresse de votre propre serveur MCP. Conservez la valeur par défaut ou indiquez un serveur que vous gérez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह आपके अपने MCP सर्वर का पता है। डिफ़ॉल्ट रखें या स्वयं चलाए जा रहे पते में बदलें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "あなた自身の MCP サーバーのアドレスです。デフォルトのままにするか、自分で運用するアドレスに変更できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "내 MCP 서버 주소예요. 기본값을 그대로 두거나 직접 운영하는 주소로 바꿀 수 있어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "É o endereço do seu próprio servidor MCP. Mantenha o padrão ou troque por um servidor que você mesmo opera."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это адрес вашего собственного MCP-сервера. Оставьте значение по умолчанию или укажите сервер, который вы поддерживаете сами."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这是你自己的 MCP 服务器地址。可保留默认值，或改为你自己运行的地址。"
          }
        }
      }
    },
    "기본은 읽기 전용이에요. 켜면 일정·메일을 만들거나 수정·삭제하는 권한까지 요청해요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الوضع الافتراضي للقراءة فقط. عند التفعيل، يُطلب أيضًا إذن إنشاء المواعيد والبريد أو تعديلها أو حذفها."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Read-only by default. When on, it also requests permission to create, edit, or delete your schedule and email."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo lectura por defecto. Al activarlo, también solicita permiso para crear, editar o eliminar tu agenda y correo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lecture seule par défaut. Activé, il demande aussi l’autorisation de créer, modifier ou supprimer votre agenda et vos e-mails."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डिफ़ॉल्ट रूप से केवल पढ़ने के लिए। चालू करने पर, यह आपके शेड्यूल और ईमेल बनाने, संपादित करने या हटाने की अनुमति भी मांगता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デフォルトは読み取り専用です。オンにすると、予定やメールの作成・編集・削除の権限も要求します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기본은 읽기 전용이에요. 켜면 일정·메일을 만들거나 수정·삭제하는 권한까지 요청해요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Somente leitura por padrão. Quando ativado, também solicita permissão para criar, editar ou excluir sua agenda e e-mails."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "По умолчанию только чтение. При включении также запрашивается разрешение создавать, изменять и удалять ваше расписание и почту."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "默认仅读取。开启后，还会请求创建、修改或删除你的日程和邮件的权限。"
          }
        }
      }
    },
    "캘린더·Gmail 같은 도구를 연결하면, 에이전트가 내 일정·메일을 읽고 도와줄 수 있어요. 토큰은 Mac 에만 안전하게 보관돼요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بتوصيل أدوات مثل التقويم أو Gmail، يمكن للوكيل قراءة مواعيدك وبريدك ومساعدتك. تُحفظ الرموز بأمان على الـ Mac فقط."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Connect tools like Calendar or Gmail, and the agent can read your schedule and email to help you. Tokens are kept securely on the Mac only."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Conecta herramientas como Calendar o Gmail y el agente podrá leer tu agenda y correo para ayudarte. Los tokens se guardan de forma segura solo en el Mac."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Connectez des outils comme Agenda ou Gmail : l’agent pourra lire votre agenda et vos e-mails pour vous aider. Les jetons sont conservés en sécurité sur le Mac uniquement."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कैलेंडर या Gmail जैसे टूल कनेक्ट करें, और एजेंट आपकी मदद के लिए आपका शेड्यूल और ईमेल पढ़ सकता है। टोकन केवल Mac पर सुरक्षित रहते हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カレンダーや Gmail などのツールを接続すると、エージェントが予定やメールを読んで手伝えます。トークンは Mac にのみ安全に保管されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "캘린더·Gmail 같은 도구를 연결하면, 에이전트가 내 일정·메일을 읽고 도와줄 수 있어요. 토큰은 Mac 에만 안전하게 보관돼요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Conecte ferramentas como Agenda ou Gmail e o agente poderá ler sua agenda e e-mails para ajudar você. Os tokens ficam seguros apenas no Mac."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подключите инструменты, например Календарь или Gmail, и агент сможет читать ваше расписание и почту, чтобы помогать. Токены надёжно хранятся только на Mac."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "连接日历或 Gmail 等工具后，智能体就能读取你的日程和邮件来帮你。令牌仅安全保存在 Mac 上。"
          }
        }
      }
    },
