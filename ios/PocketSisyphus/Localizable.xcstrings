    "점수 = 영향 ÷ 노력. 높을수록 먼저 봐요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "النتيجة = التأثير ÷ الجهد. كلما زادت راجِعها أولًا."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Score = impact ÷ effort. Higher means look first."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puntuación = impacto ÷ esfuerzo. Cuanto mayor, revísalo antes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Score = impact ÷ effort. Plus c’est élevé, plus c’est prioritaire."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्कोर = प्रभाव ÷ प्रयास. जितना अधिक, उतना पहले देखें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スコア = 影響 ÷ 労力。高いほど先に確認します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "점수 = 영향 ÷ 노력. 높을수록 먼저 봐요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pontuação = impacto ÷ esforço. Quanto maior, veja primeiro."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Оценка = влияние ÷ усилия. Выше — смотрите первым."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "评分 = 影响 ÷ 投入。越高越优先查看。"
          }
        }
      }
    },
