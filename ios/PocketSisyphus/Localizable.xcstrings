    "%@ 인증을 취소했어요. 다시 시도해 주세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم إلغاء مصادقة %@. يُرجى المحاولة مرة أخرى."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ authentication was canceled. Please try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se canceló la autenticación con %@. Inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’authentification %@ a été annulée. Veuillez réessayer."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ प्रमाणीकरण रद्द कर दिया गया. कृपया फिर से प्रयास करें."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@認証がキャンセルされました。もう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 인증을 취소했어요. 다시 시도해 주세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A autenticação com %@ foi cancelada. Tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Аутентификация %@ отменена. Повторите попытку."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已取消 %@ 验证。请重试。"
          }
        }
      }
    },
    "%@가 여러 번 막혀 잠시 잠겼어요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم قفل %@ مؤقتًا بعد محاولات كثيرة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ is temporarily locked after too many attempts."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ se bloqueó temporalmente tras demasiados intentos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ est temporairement verrouillé après trop de tentatives."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बहुत अधिक प्रयासों के बाद %@ अस्थायी रूप से लॉक हो गया है."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "試行回数が多いため、%@は一時的にロックされています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@가 여러 번 막혀 잠시 잠겼어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O %@ foi bloqueado temporariamente após muitas tentativas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ временно заблокирован после нескольких неудачных попыток."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "尝试次数过多，%@ 已暂时锁定。"
          }
        }
      }
    },
    "%@를 사용할 수 없어요. 기기 설정에서 생체 인증이나 암호를 켠 뒤 다시 시도해 주세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ غير متاح. فعّل المصادقة البيومترية أو رمز الدخول من الإعدادات ثم حاول مرة أخرى."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ isn’t available. Turn on biometrics or a passcode in Settings, then try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ no está disponible. Activa la biometría o un código en Ajustes y vuelve a intentarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ n’est pas disponible. Activez la biométrie ou un code dans Réglages, puis réessayez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ उपलब्ध नहीं है. सेटिंग्स में बायोमेट्रिक्स या पासकोड चालू करें, फिर पुनः प्रयास करें."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@を利用できません。設定で生体認証またはパスコードをオンにしてから、もう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@를 사용할 수 없어요. 기기 설정에서 생체 인증이나 암호를 켠 뒤 다시 시도해 주세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O %@ não está disponível. Ative a biometria ou um código nos Ajustes e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ недоступен. Включите биометрию или код-пароль в настройках и повторите попытку."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 不可用。请在“设置”中开启生物识别或密码后重试。"
          }
        }
      }
    },
