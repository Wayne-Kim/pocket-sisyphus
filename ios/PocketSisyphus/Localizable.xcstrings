        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld aguardando entrada — trate primeiro"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld ожидают ввода — сначала разберитесь с ними"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 个等待输入 — 请先处理"
          }
        }
      }
    },
    "입력 대기 세션 %lld건. 탭하면 대기 세션만 봅니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld جلسة بانتظار الإدخال. اضغط لعرض الجلسات المنتظِرة فقط."
          }
        },
        "en": {
          "stringUnit": {
