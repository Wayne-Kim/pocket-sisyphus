    "이 실행은 아직 격리 브랜치를 main 에 머지 요청하지 않았어요.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يطلب هذا التشغيل بعد دمج فرع العزل الخاص به في main."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This run hasn't requested a merge of its isolation branch into main yet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta ejecución aún no ha solicitado fusionar su rama de aislamiento en main."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette exécution n'a pas encore demandé la fusion de sa branche d'isolation dans main."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस रन ने अभी तक अपनी आइसोलेशन ब्रांच को main में मर्ज करने का अनुरोध नहीं किया है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この実行はまだ隔離ブランチを main へマージ依頼していません。"
