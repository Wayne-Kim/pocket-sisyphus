    "읽기 전용 모드 — 데스크탑이 작업 중인 동안은 모바일 입력이 막혀 있습니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "وضع القراءة فقط — لا يمكن الإدخال من الهاتف أثناء عمل سطح المكتب."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Read-only — mobile input is locked while the desktop is working."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo lectura — la entrada móvil está bloqueada mientras el escritorio trabaja."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lecture seule — la saisie mobile est verrouillée pendant que le bureau travaille."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "केवल पठनीय — डेस्कटॉप के काम करते समय मोबाइल इनपुट लॉक है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "読み取り専用モード — デスクトップ作業中はモバイル入力が無効です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "읽기 전용 모드 — 데스크탑이 작업 중인 동안은 모바일 입력이 막혀 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Somente leitura — a entrada no celular fica bloqueada enquanto o desktop trabalha."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Только чтение — ввод с мобильного заблокирован, пока работает десктоп."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "只读模式 — 桌面工作期间手机输入被禁用。"
          }
        }
      }
    },
