    "보기는 되지만, 조작하려면 Mac 의 손쉬운 사용 권한을 켜야 해요": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يمكن العرض، لكن للتحكم في جهاز Mac يجب تفعيل تسهيلات الاستخدام عليه"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Viewing works, but to control your Mac you must enable Accessibility on it"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes ver la pantalla, pero para controlar tu Mac debes activar Accesibilidad en él"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’affichage fonctionne, mais pour contrôler votre Mac, activez Accessibilité dessus"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "देखना काम करता है, पर Mac को नियंत्रित करने के लिए उस पर एक्सेसिबिलिटी चालू करें"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "表示はできますが、操作するには Mac のアクセシビリティ権限をオンにしてください"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "보기는 되지만, 조작하려면 Mac 의 손쉬운 사용 권한을 켜야 해요"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A visualização funciona, mas para controlar o Mac é preciso ativar Acessibilidade nele"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Просмотр работает, но для управления Mac включите на нём Универсальный доступ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可以查看，但要操控 Mac 需在其上开启“辅助功能”权限"
          }
        }
      }
    },
