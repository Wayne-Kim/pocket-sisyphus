    },
    "세션에서 dev 서버를 띄우면(예: npm run dev) 자동으로 화면이 나타납니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند تشغيل خادم dev في الجلسة (مثل npm run dev)، سيظهر هنا تلقائيًا."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When you start a dev server in the session (e.g. npm run dev), it appears here automatically."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando inicies un servidor dev en la sesión (p. ej. npm run dev), aparecerá aquí automáticamente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorsque vous démarrez un serveur dev dans la session (par ex. npm run dev), il apparaît ici automatiquement."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जब आप सेशन में dev सर्वर शुरू करते हैं (जैसे npm run dev), यह यहाँ अपने आप दिखाई देगा।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "セッションで dev サーバーを起動すると（例: npm run dev）、自動的にここに表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "세션에서 dev 서버를 띄우면(예: npm run dev) 자동으로 화면이 나타납니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando você iniciar um servidor dev na sessão (ex.: npm run dev), ele aparece aqui automaticamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Когда вы запустите dev-сервер в сессии (например, npm run dev), он автоматически появится здесь."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当你在会话中启动 dev 服务器（例如 npm run dev）后，这里会自动显示。"
          }
        }
      }
    },
    "세션은 Mac 의 코드 에이전트와 나누는 대화예요. 새 세션을 만들어 레포를 고르면 모바일에서 바로 명령을 보낼 수 있어요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الجلسة هي محادثة مع وكيل البرمجة على جهاز Mac. أنشئ جلسة، اختر مستودعًا، وابدأ بإرسال الأوامر من هاتفك فورًا."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A session is a conversation with the code agent on your Mac. Create one, pick a repo, and start sending commands from your phone right away."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una sesión es una conversación con el agente de código de tu Mac. Crea una, elige un repositorio y empieza a enviar comandos desde el móvil."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une session est une conversation avec l'agent de code sur votre Mac. Créez-en une, choisissez un dépôt et envoyez des commandes depuis votre téléphone."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सेशन आपके Mac पर कोड एजेंट के साथ बातचीत है। एक सेशन बनाएं, रेपो चुनें और फ़ोन से तुरंत कमांड भेजना शुरू करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "セッションは Mac 上のコードエージェントとの会話です。新しいセッションを作成してリポジトリを選べば、すぐにモバイルからコマンドを送れます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "세션은 Mac 의 코드 에이전트와 나누는 대화예요. 새 세션을 만들어 레포를 고르면 모바일에서 바로 명령을 보낼 수 있어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Uma sessão é uma conversa com o agente de código no seu Mac. Crie uma, escolha um repositório e comece a enviar comandos pelo celular."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сессия — это диалог с агентом кода на вашем Mac. Создайте сессию, выберите репозиторий и сразу отправляйте команды с телефона."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "会话是与 Mac 上代码代理的对话。新建会话并选择仓库，就能立即从手机发送命令。"
          }
        }
      }
    },
    "세션은 코드 에이전트 CLI 와의 대화 단위입니다. 만들기 / 이름 변경 / 비우기 / 삭제.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الجلسة هي وحدة المحادثة مع وكيل البرمجة عبر سطر الأوامر. الإنشاء / إعادة التسمية / المسح / الحذف."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A session is one conversation with the coding-agent CLI. Create / rename / clear / delete."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una sesión es una conversación con la CLI del agente de programación. Crear / renombrar / vaciar / eliminar."
          }
        },
        "fr": {
