    "한 번 구매로 평생 — 오래 쓸 계획이라면": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "شراء واحد، ملكك للأبد — إذا كنت تنوي استخدامه طويلاً."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "One purchase, yours forever — if you're here for the long haul."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una compra, para siempre: si vas a usarlo a largo plazo."
          }
        },
        "fr": {
