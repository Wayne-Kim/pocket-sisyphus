    "LAN 전용 모드 — 같은 LAN 에서 Mac 에 연결하지 못했어요. 외부 경로로 폴백하지 않습니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "وضع الشبكة المحلية فقط — تعذّر الاتصال بالـMac على نفس الشبكة المحلية. لا رجوع إلى مسارات خارجية."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "LAN-only mode — couldn't connect to the Mac on the same LAN. No fallback to external paths."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Modo solo LAN: no se pudo conectar al Mac en la misma LAN. Sin recurso a rutas externas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mode LAN uniquement — impossible de se connecter au Mac sur le même LAN. Aucun repli vers des chemins externes."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "केवल-LAN मोड — उसी LAN पर Mac से कनेक्ट नहीं हो सका। बाहरी मार्गों पर कोई फ़ॉलबैक नहीं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "LAN専用モード — 同じLAN上のMacに接続できませんでした。外部経路へはフォールバックしません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "LAN 전용 모드 — 같은 LAN 에서 Mac 에 연결하지 못했어요. 외부 경로로 폴백하지 않습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Modo somente LAN — não foi possível conectar ao Mac na mesma LAN. Sem fallback para caminhos externos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Режим только по LAN — не удалось подключиться к Mac в той же локальной сети. Без перехода на внешние пути."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅局域网模式 — 无法连接同一局域网中的 Mac。不会回退到外部路径。"
          }
        }
      }
    },
    "LAN 전용 모드 — 같은 Wi‑Fi 의 Mac 을 찾지 못해 연결을 차단했어요. 외부 네트워크에선 연결되지 않습니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "وضع الشبكة المحلية فقط — تعذّر العثور على الـMac على نفس شبكة Wi-Fi، لذا حُظر الاتصال. لن يتصل على الشبكات الخارجية."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "LAN-only mode — couldn't find the Mac on the same Wi-Fi, so the connection was blocked. It won't connect on external networks."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Modo solo LAN: no se encontró el Mac en la misma Wi-Fi, así que se bloqueó la conexión. No se conecta en redes externas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mode LAN uniquement — le Mac est introuvable sur le même Wi-Fi, la connexion a donc été bloquée. Pas de connexion sur les réseaux externes."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "केवल-LAN मोड — उसी Wi-Fi पर Mac नहीं मिला, इसलिए कनेक्शन अवरुद्ध किया गया। बाहरी नेटवर्क पर कनेक्ट नहीं होगा।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "LAN専用モード — 同じWi-Fi上にMacが見つからず接続をブロックしました。外部ネットワークでは接続しません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "LAN 전용 모드 — 같은 Wi‑Fi 의 Mac 을 찾지 못해 연결을 차단했어요. 외부 네트워크에선 연결되지 않습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Modo somente LAN — não foi possível encontrar o Mac na mesma Wi-Fi, então a conexão foi bloqueada. Não conecta em redes externas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Режим только по LAN — Mac не найден в той же сети Wi-Fi, поэтому подключение заблокировано. Во внешних сетях подключения не будет."
          }
        },
        "zh-Hans": {
          "stringUnit": {
