    "페어링 값이 바뀌었다면 새 QR 로 다시 페어링하세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إذا تغيّرت بيانات الاقتران، فأعد الاقتران باستخدام رمز QR جديد."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If the pairing changed, re-pair with a new QR code."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si el emparejamiento cambió, vuelve a emparejar con un nuevo código QR."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si l’appairage a changé, ré-appairez avec un nouveau QR code."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अगर पेयरिंग बदल गई है, तो नए QR कोड से दोबारा पेयर करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ペアリング値が変わった場合は、新しいQRで再ペアリングしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "페어링 값이 바뀌었다면 새 QR 로 다시 페어링하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Se o pareamento mudou, refaça o pareamento com um novo QR code."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если данные сопряжения изменились, выполните сопряжение заново с новым QR-кодом."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果配对信息已更改，请使用新二维码重新配对。"
          }
        }
      }
    },
