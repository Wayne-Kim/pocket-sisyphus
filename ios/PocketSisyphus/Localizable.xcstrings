    "같은 네트워크 안 직접 연결이에요. 서버 신원은 아래 호스트 키 검증으로 확인합니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذا اتصال مباشر داخل الشبكة نفسها. يتم التحقق من هوية الخادم عبر فحص مفتاح المضيف أدناه."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This is a direct connection within the same network. The server's identity is verified by the host key check below."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Es una conexión directa dentro de la misma red. La identidad del servidor se verifica mediante la comprobación de la clave de host de abajo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Il s'agit d'une connexion directe au sein du même réseau. L'identité du serveur est vérifiée par le contrôle de la clé d'hôte ci-dessous."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह उसी नेटवर्क के भीतर एक सीधा कनेक्शन है। सर्वर की पहचान नीचे दिए गए होस्ट कुंजी सत्यापन से जाँची जाती है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "同じネットワーク内での直接接続です。サーバーの身元は下のホストキー検証で確認します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "같은 네트워크 안 직접 연결이에요. 서버 신원은 아래 호스트 키 검증으로 확인합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta é uma conexão direta dentro da mesma rede. A identidade do servidor é verificada pela checagem da chave de host abaixo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это прямое подключение в пределах одной сети. Личность сервера подтверждается проверкой ключа хоста ниже."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这是同一网络内的直接连接。服务器身份通过下方的主机密钥验证来确认。"
          }
        }
      }
    },
