    "프로젝트에 저장돼 매 수집에 재사용돼요. 무엇을 어떻게 조사할지 적어두세요.": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "프로젝트에 저장돼 매 수집에 재사용돼요. 무엇을 어떻게 조사할지 적어두세요."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Saved per project and reused on every collection. Write down what to investigate and how."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プロジェクトに保存され、毎回の収集で再利用されます。何をどう調査するかを書いておきましょう。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按项目保存并在每次收集时重复使用。写下要调研什么、如何调研。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se guarda por proyecto y se reutiliza en cada recopilación. Anota qué investigar y cómo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Enregistrée par projet et réutilisée à chaque collecte. Notez quoi analyser et comment."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Salvo por projeto e reutilizado em cada coleta. Anote o que investigar e como."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сохраняется для проекта и используется при каждом сборе. Запишите, что и как исследовать."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تُحفظ لكل مشروع ويُعاد استخدامها في كل عملية جمع. دوّن ماذا تبحث وكيف."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रोजेक्ट में सहेजा जाता है और हर एकत्रण में पुनः उपयोग होता है। क्या और कैसे जाँचना है लिखें।"
          }
        }
      }
    },
