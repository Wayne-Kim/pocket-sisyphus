    "손가락으로 직접 화면을 만지는 게 아니라, 트랙패드처럼 커서를 움직여요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أنت لا تلمس الشاشة مباشرة، بل تحرّك المؤشر كما في لوحة التتبّع."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You don’t touch the screen directly — you move the cursor, like on a trackpad."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No tocas la pantalla directamente: mueves el cursor, como en un trackpad."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous ne touchez pas l’écran directement : vous déplacez le curseur, comme sur un trackpad."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आप स्क्रीन को सीधे नहीं छूते — ट्रैकपैड की तरह कर्सर हिलाते हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "画面を直接タッチするのではなく、トラックパッドのようにカーソルを動かします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "손가락으로 직접 화면을 만지는 게 아니라, 트랙패드처럼 커서를 움직여요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você não toca na tela diretamente — move o cursor, como num trackpad."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы не касаетесь экрана напрямую — вы двигаете курсор, как на трекпаде."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你不是直接触摸画面，而是像用触控板一样移动光标。"
          }
        }
      }
    },
    "손으로 규칙을 쓰지 않아도 돼요 — 에이전트가 이 레포의 디자인 토큰·i18n 카탈로그·디자인 문서를 읽어 규칙 초안을 제안해요. 승인하면 수집·리서치가 따르는 «강한 신호» 가 켜져요 (승인 전엔 적용 안 됨).": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لست مضطرًا لكتابة القواعد يدويًا — يقرأ الوكيل رموز التصميم وكتالوجات الترجمة (i18n) ومستندات التصميم في هذا المستودع ليقترح مسودة قواعد. اعتمدها لتفعيل الإشارة القوية التي يتبعها الجمع والبحث (لا يُطبَّق شيء قبل الاعتماد)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You don't have to write the rules by hand — the agent reads this repo's design tokens, i18n catalogs, and design docs to propose a rules draft. Approve it to turn on the strong signal that collection and research follow (nothing is applied before approval)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No tienes que escribir las reglas a mano: el agente lee los tokens de diseño, los catálogos i18n y los documentos de diseño de este repositorio para proponer un borrador de reglas. Apruébalo para activar la señal fuerte que siguen la recopilación y la investigación (no se aplica nada antes de aprobar)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous n'avez pas à écrire les règles à la main : l'agent lit les jetons de design, les catalogues i18n et les documents de design de ce dépôt pour proposer un brouillon de règles. Approuvez-le pour activer le signal fort que suivent la collecte et la recherche (rien n'est appliqué avant l'approbation)."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपको नियम हाथ से लिखने की ज़रूरत नहीं — एजेंट इस रिपॉज़िटरी के डिज़ाइन टोकन, i18n कैटलॉग और डिज़ाइन दस्तावेज़ पढ़कर नियमों का ड्राफ़्ट सुझाता है। इसे स्वीकृत करें ताकि वह «मज़बूत संकेत» चालू हो जो संग्रह और शोध अपनाते हैं (स्वीकृति से पहले कुछ लागू नहीं होता)।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ルールを手で書く必要はありません — エージェントがこのリポジトリのデザイントークン・i18n カタログ・デザイン文書を読み取ってルールの下書きを提案します。承認すると、収集・リサーチが従う「強いシグナル」が有効になります（承認前は適用されません）。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "손으로 규칙을 쓰지 않아도 돼요 — 에이전트가 이 레포의 디자인 토큰·i18n 카탈로그·디자인 문서를 읽어 규칙 초안을 제안해요. 승인하면 수집·리서치가 따르는 «강한 신호» 가 켜져요 (승인 전엔 적용 안 됨)."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você não precisa escrever as regras à mão — o agente lê os tokens de design, os catálogos i18n e os documentos de design deste repositório para propor um rascunho de regras. Aprove-o para ativar o sinal forte que a coleta e a pesquisa seguem (nada é aplicado antes da aprovação)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не нужно писать правила вручную — агент читает токены дизайна, каталоги i18n и документы по дизайну этого репозитория и предлагает черновик правил. Утвердите его, чтобы включить сильный сигнал, которому следуют сбор и исследование (до утверждения ничего не применяется)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你不必手写规则——代理会读取此仓库的设计令牌、i18n 目录和设计文档，提出规则草稿。批准后即可开启收集与调研所遵循的“强信号”（批准前不会应用）。"
          }
        }
      }
    },
