        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Montre quelles fonctionnalités lancées échouent le plus souvent selon l'effort, la perspective et le type de preuve."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "दिखाता है कि कौन सी लॉन्च की गई सुविधाएं प्रयास, दृष्टिकोण और साक्ष्य प्रकार के अनुसार अधिक बार चूकती हैं।"
          }
        },
        "ja": {
