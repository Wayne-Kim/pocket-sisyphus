    "레포 신호 수집": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "레포 신호 수집"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Collect repo signals"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リポジトリのシグナル収集"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "收集仓库信号"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Recopilar señales del repo"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Collecter les signaux du dépôt"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Coletar sinais do repo"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Собрать сигналы репозитория"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "جمع إشارات المستودع"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रिपो सिग्नल एकत्र करें"
          }
        }
      }
    },
    "레포 신호 수집 — 에이전트가 레포 안의 이슈·TODO·문서·변경 이력을 훑어 기회를 브리프로 모아 와요. «지금 수집» 한 번이면 끝이에요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "جمع إشارات المستودع — يتصفّح الوكيل مسائل المستودع وعناصر TODO والمستندات وسجلّ التغييرات ويجمع الفرص في موجزات. تكفي ضغطة واحدة على «اجمع الآن»."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Collect repo signals — the agent scans the repo’s issues, TODOs, docs, and change history and gathers opportunities into briefs. One tap of «Collect now» is all it takes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Recoger señales del repo — el agente revisa las incidencias, los TODO, los documentos y el historial de cambios del repo y reúne oportunidades en informes. Basta con tocar «Recoger ahora» una vez."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Collecter les signaux du dépôt — l’agent parcourt les tickets, TODO, documents et l’historique des changements du dépôt et rassemble les opportunités en briefs. Un seul appui sur «Collecter maintenant» suffit."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रेपो संकेत एकत्र करें — एजेंट रेपो के इश्यू, TODO, दस्तावेज़ और बदलाव इतिहास को खंगालकर अवसरों को ब्रीफ़ में इकट्ठा करता है। बस एक बार «अभी एकत्र करें» दबाना है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リポジトリのシグナル収集 — エージェントがリポジトリ内の Issue・TODO・ドキュメント・変更履歴を調べ、機会をブリーフとして集めてきます。«今すぐ収集» を一度押すだけです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "레포 신호 수집 — 에이전트가 레포 안의 이슈·TODO·문서·변경 이력을 훑어 기회를 브리프로 모아 와요. «지금 수집» 한 번이면 끝이에요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Coletar sinais do repo — o agente vasculha issues, TODOs, documentos e o histórico de mudanças do repo e reúne oportunidades em briefs. Basta um toque em «Coletar agora»."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сбор сигналов репозитория — агент просматривает задачи, TODO, документы и историю изменений репозитория и собирает возможности в брифы. Достаточно одного нажатия «Собрать сейчас»."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "收集仓库信号——智能体扫描仓库中的问题、TODO、文档和变更历史，把机会汇集成简报。点一下«立即收集»即可。"
          }
        }
      }
    },
