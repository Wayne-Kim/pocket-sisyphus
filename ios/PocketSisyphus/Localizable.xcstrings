    "출시됨 — 구현·출시는 끝났고 검증을 기다리는 단계예요 (파란 배지, 정보 신호).": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم الإصدار — اكتمل التنفيذ والإطلاق وهو بانتظار التحقّق (شارة زرقاء، إشارة معلومات)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shipped — implementation and release are done and it’s awaiting validation (blue badge, an info signal)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Publicado — la implementación y el lanzamiento están hechos y queda a la espera de validación (insignia azul, señal informativa)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Livré — l’implémentation et la publication sont terminées et c’est en attente de validation (badge bleu, signal d’information)."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रिलीज़ हुआ — क्रियान्वयन व रिलीज़ पूरा है और सत्यापन की प्रतीक्षा में है (नीला बैज, सूचना संकेत)।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "出荷済み — 実装・出荷は終わり、検証を待つ段階です(青いバッジ、情報のシグナル)。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "출시됨 — 구현·출시는 끝났고 검증을 기다리는 단계예요 (파란 배지, 정보 신호)."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Lançado — a implementação e o lançamento estão prontos e aguarda validação (selo azul, sinal informativo)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выпущено — реализация и релиз завершены, ожидается проверка (синий бейдж, информационный сигнал)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已发布——实现与发布已完成，正等待验证(蓝色徽章，信息信号)。"
          }
        }
      }
    },
    "출시됨 — 다음 신호 수집이 가설을 대조해요": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "출시됨 — 다음 신호 수집이 가설을 대조해요"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shipped — the next signal collection will check the hypothesis"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リリース済み — 次回のシグナル収集で仮説を照合します"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已上线 — 下次信号收集将核对假设"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lanzado — la próxima recolección de señales contrastará la hipótesis"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Livré — la prochaine collecte de signaux vérifiera l'hypothèse"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выпущено — следующий сбор сигналов сверит гипотезу"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Lançado — a próxima coleta de sinais checará a hipótese"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "शिप किया गया — अगला सिग्नल संग्रह परिकल्पना की जाँच करेगा"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم الإطلاق — سيقارن جمع الإشارات التالي الفرضية"
          }
        }
      }
    },
    "출시한 기능이 적중·빗나간 판정 사유예요.": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "출시한 기능이 적중·빗나간 판정 사유예요."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Why shipped features hit or missed."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リリースした機能が的中・外れた判定の理由です。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已发布功能命中或未命中的判定原因。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Por qué las funciones publicadas acertaron o fallaron."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pourquoi les fonctionnalités livrées ont réussi ou échoué."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Почему выпущенные функции попали в цель или промахнулись."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Por que os recursos lançados acertaram ou erraram."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जारी की गई सुविधाएँ क्यों सही रहीं या चूक गईं।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سبب إصابة الميزات المطلقة للهدف أو إخفاقها."
          }
        }
      }
    },
