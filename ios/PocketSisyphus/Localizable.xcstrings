    "브랜치를 전환할 수 없어요. 변경사항을 먼저 커밋하거나 정리해 주세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذّر تبديل الفرع. الرجاء الالتزام بالتغييرات أو تنظيفها أولًا."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Can’t switch branches. Commit or clean up your changes first."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se puede cambiar de rama. Confirma o limpia tus cambios primero."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de changer de branche. Validez ou nettoyez d’abord vos modifications."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ब्रांच स्विच नहीं हो सकी। पहले अपने बदलाव कमिट करें या साफ़ करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブランチを切り替えられません。先に変更をコミットするか整理してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "브랜치를 전환할 수 없어요. 변경사항을 먼저 커밋하거나 정리해 주세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não é possível trocar de branch. Faça commit ou limpe suas alterações primeiro."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удаётся переключить ветку. Сначала закоммитьте или уберите изменения."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法切换分支。请先提交或清理你的更改。"
          }
        }
      }
    },
