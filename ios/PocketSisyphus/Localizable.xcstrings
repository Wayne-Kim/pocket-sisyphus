    "수집/추적 없음": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بدون جمع أو تتبّع"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No collection, no tracking"
          }
        },
        "es": {
          "stringUnit": {
