    "직전 실행이 아직 진행 중이거나 제약에 걸렸어요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "التشغيل السابق ما زال جاريًا أو تم بلوغ حد."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The previous run is still going, or a limit was hit."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La ejecución anterior sigue en curso o se alcanzó un límite."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’exécution précédente est encore en cours, ou une limite a été atteinte."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पिछला रन अभी चल रहा है, या कोई सीमा लग गई।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "前回の実行がまだ進行中か、制約に達しました。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "직전 실행이 아직 진행 중이거나 제약에 걸렸어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A execução anterior ainda está em andamento ou um limite foi atingido."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Предыдущий запуск ещё идёт или достигнут лимит."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "上一次运行仍在进行，或触及了限制。"
          }
        }
      }
    },
    "직전 실행이 아직 진행 중이에요. 끝난 뒤 다시 실행해 주세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "التشغيل السابق لا يزال جاريًا. يُرجى التشغيل مرة أخرى بعد انتهائه."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The previous run is still in progress. Try again after it finishes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La ejecución anterior sigue en curso. Vuelve a intentarlo cuando termine."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’exécution précédente est encore en cours. Réessayez une fois terminée."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पिछला रन अभी भी चल रहा है। पूरा होने के बाद फिर से चलाएँ।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "前回の実行がまだ進行中です。終了してからもう一度実行してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "직전 실행이 아직 진행 중이에요. 끝난 뒤 다시 실행해 주세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A execução anterior ainda está em andamento. Tente novamente quando terminar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Предыдущий запуск ещё выполняется. Повторите попытку после его завершения."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "上一次运行仍在进行中。请在结束后重试。"
          }
        }
      }
    },
    "직접 SSH (1차) — iPhone Pocket Sisyphus → 디바이스 → 공유기 → Mac 의 임베디드 sshd (포트 22022) → Mac Pocket Sisyphus 데스크탑 앱 → 코드 에이전트 CLI → 각 에이전트의 모델 제공자 API.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "SSH المباشر (الأساسي) — iPhone Pocket Sisyphus → الجهاز → الموجّه → sshd المضمّن في Mac (المنفذ 22022) → تطبيق Pocket Sisyphus على Mac → CLI وكيل الكود → واجهة مزود نموذج كل وكيل."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Direct SSH (primary) — iPhone Pocket Sisyphus → device → router → Mac’s embedded sshd (port 22022) → Mac Pocket Sisyphus desktop app → code-agent CLI → each agent’s model-provider API."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "SSH directo (primario) — iPhone Pocket Sisyphus → dispositivo → router → sshd embebido del Mac (puerto 22022) → app de escritorio Pocket Sisyphus en Mac → CLI del agente de código → API del proveedor de modelo de cada agente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "SSH direct (principal) — iPhone Pocket Sisyphus → appareil → routeur → sshd embarqué du Mac (port 22022) → app de bureau Pocket Sisyphus sur Mac → CLI d’agent de code → API du fournisseur de modèle de chaque agent."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सीधा SSH (प्राथमिक) — iPhone Pocket Sisyphus → डिवाइस → राउटर → Mac का एम्बेडेड sshd (पोर्ट 22022) → Mac Pocket Sisyphus डेस्कटॉप ऐप → कोड-एजेंट CLI → हर एजेंट के मॉडल प्रदाता का API।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "直接 SSH (1 次) — iPhone Pocket Sisyphus → デバイス → ルーター → Mac の組み込み sshd (ポート 22022) → Mac Pocket Sisyphus デスクトップアプリ → コードエージェント CLI → 各エージェントのモデルプロバイダ API。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "SSH direto (primário) — iPhone Pocket Sisyphus → dispositivo → roteador → sshd embutido do Mac (porta 22022) → app de desktop Pocket Sisyphus no Mac → CLI de agente de código → API do provedor de modelo de cada agente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Прямой SSH (основной) — iPhone Pocket Sisyphus → устройство → роутер → встроенный sshd Mac (порт 22022) → десктоп-приложение Pocket Sisyphus на Mac → CLI код-агента → API провайдера модели каждого агента."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "直连 SSH（首选）— iPhone Pocket Sisyphus → 设备 → 路由器 → Mac 的内嵌 sshd（端口 22022）→ Mac Pocket Sisyphus 桌面应用 → 代码代理 CLI → 各代理对应的模型提供方 API。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "직접 SSH (1차) — iPhone Pocket Sisyphus → 디바이스 → 공유기 → Mac 의 임베디드 sshd (포트 22022) → Mac Pocket Sisyphus 데스크탑 앱 → 코드 에이전트 CLI → 각 에이전트의 모델 제공자 API."
          }
        }
      }
    },
