    "결재(승인·기각)가 5건 쌓이면 승인율을 보여드려요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سنعرض معدل الموافقة بعد 5 قرارات (موافقة/رفض)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The approval rate appears after 5 decisions (approve/reject)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La tasa de aprobación aparecerá tras 5 decisiones (aprobar/rechazar)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le taux d’approbation s’affiche après 5 décisions (approbation/rejet)."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "5 निर्णय (स्वीकृति/अस्वीकृति) होने पर स्वीकृति दर दिखाई देगी।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "決裁（承認・却下）が5件たまると承認率を表示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "결재(승인·기각)가 5건 쌓이면 승인율을 보여드려요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A taxa de aprovação aparece após 5 decisões (aprovar/rejeitar)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Доля одобрений появится после 5 решений (одобрить/отклонить)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "累计 5 条决策（批准/驳回）后将显示批准率。"
          }
        }
      }
    },
    "결제 시 App Store 계정에 청구됩니다. 환불은 Apple 정책을 따릅니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ستُحمَّل قيمة الشراء على حساب App Store الخاص بك. الاسترداد يخضع لسياسة Apple."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your App Store account will be charged at purchase. Refunds follow Apple’s policy."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se cargará a tu cuenta de App Store al comprar. Los reembolsos siguen la política de Apple."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre compte App Store sera débité à l’achat. Les remboursements suivent la politique d’Apple."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "खरीदारी पर आपके App Store खाते से शुल्क लिया जाएगा। रिफंड Apple की नीति के अनुसार होते हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "購入時に App Store アカウントへ請求されます。返金は Apple のポリシーに従います。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "결제 시 App Store 계정에 청구됩니다. 환불은 Apple 정책을 따릅니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sua conta da App Store será cobrada na compra. Reembolsos seguem a política da Apple."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сумма списывается со счёта App Store при покупке. Возврат — по правилам Apple."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "购买时将从你的 App Store 账户扣款。退款遵循 Apple 政策。"
          }
        }
      }
    },
