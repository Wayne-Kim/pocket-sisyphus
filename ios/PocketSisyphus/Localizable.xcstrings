          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Réexécuter"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फिर से चलाएँ"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "再実行"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "재실행"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Executar novamente"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Запустить снова"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "重新运行"
          }
        }
      }
    },
    "재실행하면 현재 워크플로우 정의로 새 실행이 시작돼요(과거 정의를 복제하지 않아요).": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تؤدي إعادة التشغيل إلى بدء تشغيل جديد باستخدام تعريف سير العمل الحالي (لا يتم نسخ التعريف السابق)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Re-running starts a new run with the current workflow definition (it doesn't copy the past definition)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Volver a ejecutar inicia una nueva ejecución con la definición actual del flujo de trabajo (no copia la definición anterior)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La réexécution démarre une nouvelle exécution avec la définition actuelle du flux de travail (elle ne copie pas l'ancienne définition)."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फिर से चलाने पर मौजूदा वर्कफ़्लो परिभाषा के साथ एक नया रन शुरू होता है (यह पुरानी परिभाषा की नकल नहीं करता)।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "再実行すると、現在のワークフロー定義で新しい実行が開始されます（過去の定義は複製しません）。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "재실행하면 현재 워크플로우 정의로 새 실행이 시작돼요(과거 정의를 복제하지 않아요)."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Executar novamente inicia uma nova execução com a definição atual do fluxo de trabalho (não copia a definição anterior)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Повторный запуск создаёт новый запуск с текущим определением рабочего процесса (прошлое определение не копируется)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
