          }
        }
      }
    },
    "우상단 + 로 캘린더·Gmail 같은 도구를 추가하면, 에이전트가 내 일정·메일을 읽고 도와줄 수 있어요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أضف أدوات مثل التقويم أو Gmail عبر زر + في الأعلى، ليتمكّن الوكيل من قراءة مواعيدك وبريدك ومساعدتك."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add tools like Calendar or Gmail with + at the top right, so the agent can read your schedule and email to help you."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade herramientas como Calendar o Gmail con + arriba a la derecha para que el agente lea tu agenda y correo y te ayude."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez des outils comme Agenda ou Gmail avec + en haut à droite ; l’agent pourra lire votre agenda et vos e-mails pour vous aider."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ऊपर दाईं ओर + से कैलेंडर या Gmail जैसे टूल जोड़ें, ताकि एजेंट आपका शेड्यूल और ईमेल पढ़कर मदद कर सके।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "右上の + でカレンダーや Gmail などのツールを追加すると、エージェントが予定やメールを読んで手伝えます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "우상단 + 로 캘린더·Gmail 같은 도구를 추가하면, 에이전트가 내 일정·메일을 읽고 도와줄 수 있어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione ferramentas como Agenda ou Gmail com + no canto superior direito para que o agente leia sua agenda e e-mails e ajude você."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавьте инструменты, например Календарь или Gmail, кнопкой + вверху справа — агент сможет читать ваше расписание и почту и помогать."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用右上角的 + 添加日历或 Gmail 等工具，智能体就能读取你的日程和邮件来帮你。"
          }
        }
      }
    },
    "연결된 도구는 에이전트 세션·워크플로우에서 메일·일정을 읽고 쓸 수 있어요. 토큰은 Mac 에만 안전하게 보관되고 휴대폰엔 저장되지 않아요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يمكن للأدوات المتّصلة قراءة وكتابة البريد والمواعيد في جلسات الوكيل وسير العمل. تُحفظ الرموز بأمان على الـ Mac فقط ولا تُخزَّن على الهاتف."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Connected tools can read and write your email and schedule in agent sessions and workflows. Tokens are kept securely on the Mac only and are never stored on your phone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las herramientas conectadas pueden leer y escribir tu correo y agenda en sesiones y flujos del agente. Los tokens se guardan de forma segura solo en el Mac y nunca en el teléfono."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les outils connectés peuvent lire et écrire vos e-mails et votre agenda dans les sessions et workflows de l’agent. Les jetons sont conservés en sécurité sur le Mac uniquement, jamais sur le téléphone."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कनेक्टेड टूल एजेंट सेशन और वर्कफ़्लो में आपके ईमेल और शेड्यूल को पढ़ और लिख सकते हैं। टोकन केवल Mac पर सुरक्षित रहते हैं और फ़ोन पर संग्रहीत नहीं होते।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "接続済みのツールは、エージェントのセッションやワークフローでメールや予定を読み書きできます。トークンは Mac にのみ安全に保管され、スマートフォンには保存されません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "연결된 도구는 에이전트 세션·워크플로우에서 메일·일정을 읽고 쓸 수 있어요. 토큰은 Mac 에만 안전하게 보관되고 휴대폰엔 저장되지 않아요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ferramentas conectadas podem ler e escrever seus e-mails e agenda em sessões e fluxos do agente. Os tokens ficam seguros apenas no Mac e nunca são armazenados no telefone."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подключённые инструменты могут читать и записывать вашу почту и расписание в сессиях и рабочих процессах агента. Токены надёжно хранятся только на Mac и никогда не сохраняются на телефоне."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已连接的工具可在智能体会话和工作流中读写你的邮件和日程。令牌仅安全保存在 Mac 上，绝不存储在手机中。"
          }
        }
      }
    },
    "에이전트가 이 폴더에서 도구를 쓸 수 있게 등록돼요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يُسجَّل لكي يتمكّن الوكيل من استخدام الأداة في هذا المجلد."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Registered so the agent can use the tool in this folder."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se registra para que el agente pueda usar la herramienta en esta carpeta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Enregistré pour que l’agent puisse utiliser l’outil dans ce dossier."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ताकि एजेंट इस फ़ोल्डर में टूल का उपयोग कर सके, इसे रजिस्टर किया जाता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "エージェントがこのフォルダでツールを使えるよう登録されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "에이전트가 이 폴더에서 도구를 쓸 수 있게 등록돼요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Registrado para que o agente possa usar a ferramenta nesta pasta."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Регистрируется, чтобы агент мог использовать инструмент в этой папке."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已注册，使智能体可以在此文件夹中使用该工具。"
          }
        }
      }
    },
    "이 에이전트의 세션에서 도구를 쓸 수 있게 등록돼요.": {
      "extractionState": "manual",
      "localizations": {
