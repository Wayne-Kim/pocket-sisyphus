    "끄기 전에 먼저 기기를 한 대만 남겨 두세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اترك جهازًا واحدًا فقط قبل إيقافه."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Leave only one device before turning it off."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Deja solo un dispositivo antes de desactivarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ne gardez qu'un seul appareil avant de le désactiver."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इसे बंद करने से पहले केवल एक डिवाइस रखें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
