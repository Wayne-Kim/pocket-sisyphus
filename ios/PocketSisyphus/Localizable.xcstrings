          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Enregistré pour pouvoir utiliser l’outil dans les sessions de cet agent."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ताकि इस एजेंट के सेशन में टूल का उपयोग किया जा सके, इसे रजिस्टर किया जाता है।"
          }
        },
        "ja": {
