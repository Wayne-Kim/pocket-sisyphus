    "세션 알림 음소거와 채팅 도구 모음 — 채팅 화면의 주황 버튼들.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "كتم إشعارات الجلسة ومجموعة أدوات الدردشة — الأزرار البرتقالية في شاشة الدردشة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Per-session notification mute and the chat tool set — the orange buttons on the chat screen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Silenciar notificaciones por sesión y el conjunto de herramientas del chat: los botones naranjas de la pantalla de chat."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le silence des notifications par session et la barre d'outils du chat — les boutons orange de l'écran de discussion."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रति-सत्र सूचना म्यूट और चैट टूल सेट — चैट स्क्रीन के नारंगी बटन।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "セッション単位の通知ミュートとチャットのツール群 — チャット画面のオレンジのボタン。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "세션 알림 음소거와 채팅 도구 모음 — 채팅 화면의 주황 버튼들."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Silenciar notificações por sessão e o conjunto de ferramentas do chat — os botões laranja na tela de chat."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отключение уведомлений для сессии и набор инструментов чата — оранжевые кнопки на экране чата."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按会话静音通知与聊天工具组——聊天界面上的橙色按钮。"
          }
        }
      }
    },
