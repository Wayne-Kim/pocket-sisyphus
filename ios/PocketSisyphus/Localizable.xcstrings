    "Tor 회로로 통신 중 — 직접 SSH 가 닿지 않아 fallback 채택 (느림)": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يجري التواصل عبر دائرة Tor — تعذّر الاتصال المباشر بـ SSH فاعتُمد البديل (أبطأ)"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Communicating via Tor circuit — direct SSH not reachable, fallback engaged (slower)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comunicación a través del circuito Tor — el SSH directo no está accesible, se usa el modo alternativo (más lento)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Communication via le circuit Tor — SSH direct indisponible, repli activé (plus lent)"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor सर्किट के माध्यम से संवाद — सीधा SSH उपलब्ध नहीं, fallback सक्रिय (धीमा)"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor サーキット経由で通信中 — 直接 SSH に到達できないため fallback を採用(低速)"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor 회로로 통신 중 — 직접 SSH 가 닿지 않아 fallback 채택 (느림)"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Comunicando via circuito Tor — SSH direto indisponível, fallback ativado (mais lento)"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Связь через цепь Tor — прямой SSH недоступен, задействован запасной канал (медленнее)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正在通过 Tor 线路通信 — 无法直接 SSH，已启用备用通道(较慢)"
          }
        }
      }
    },
    "Tor 회로를 새로 빌드하고 다시 연결합니다.": {
