    "거부": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "رفض"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Deny"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Denegar"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Refuser"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अस्वीकार"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "拒否"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "거부"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Negar"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отказать"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拒绝"
          }
        }
      }
    },
    "거부 — 이번 호출을 막습니다. 모델은 다른 방법을 모색하거나 사용자에게 다시 물어봅니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "رفض — منع هذا الاستدعاء. سيبحث النموذج عن طريق آخر أو يسألك مجددًا."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Deny — block this call. The model will try another approach or ask you again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Denegar — bloquea esta llamada. El modelo buscará otra vía o te volverá a preguntar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Refuser — bloque cet appel. Le modèle cherchera une autre voie ou vous redemandera."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अस्वीकार — इस कॉल को रोकें। मॉडल कोई और तरीका खोजेगा या फिर पूछेगा।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "拒否 — この呼び出しを阻止。モデルは別の方法を試すか、再度確認します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "거부 — 이번 호출을 막습니다. 모델은 다른 방법을 모색하거나 사용자에게 다시 물어봅니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Negar — bloqueia esta chamada. O modelo tenta outro caminho ou pergunta de novo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отказать — заблокировать вызов. Модель попробует другой путь или спросит снова."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拒绝 — 阻止本次调用。模型会尝试其他方式或再次询问你。"
          }
        }
      }
    },
    "거부됨": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مرفوض"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Denied"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Denegado"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Refusé"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अस्वीकृत"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "拒否済み"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "거부됨"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Negado"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отклонено"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已拒绝"
          }
        }
      }
    },
    "거부하면: 그 업데이트만 건너뜁니다 — 다음 업데이트 때 다시 시도됩니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند الرفض: يتم تخطي ذلك التحديث فقط — وسيُعاد المحاولة مع التحديث التالي."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If declined: only that update is skipped — it'll try again on the next update."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si lo rechazas: solo se omite esa actualización; se reintentará con la siguiente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si refusé : seule cette mise à jour est ignorée — nouvelle tentative à la prochaine mise à jour."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मना करने पर: केवल वह अपडेट छूट जाता है — अगले अपडेट पर फिर कोशिश होगी।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "拒否すると: そのアップデートだけスキップされ、次回のアップデート時に再試行されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "거부하면: 그 업데이트만 건너뜁니다 — 다음 업데이트 때 다시 시도됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Se recusar: apenas aquela atualização é pulada — tentará de novo na próxima."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "При отказе: пропускается только это обновление — попытка повторится при следующем."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拒绝后：仅跳过那次更新 — 下次更新时会再尝试。"
          }
        }
      }
    },
    "거부하면: 그 폴더 안 repo 세션이 파일을 읽지 못해 동작하지 않습니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند الرفض: لن تتمكن جلسات المستودعات داخل هذا المجلد من قراءة الملفات ولن تعمل."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If declined: sessions for repos inside that folder can't read their files and won't work."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si lo rechazas: las sesiones de repos dentro de esa carpeta no podrán leer sus archivos y no funcionarán."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si refusé : les sessions des repos de ce dossier ne pourront pas lire leurs fichiers et ne fonctionneront pas."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मना करने पर: उस फ़ोल्डर के repo सत्र फ़ाइलें नहीं पढ़ पाएँगे और काम नहीं करेंगे।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "拒否すると: そのフォルダ内 repo のセッションはファイルを読めず、動作しません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "거부하면: 그 폴더 안 repo 세션이 파일을 읽지 못해 동작하지 않습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Se recusar: as sessões de repos dentro dessa pasta não conseguirão ler os arquivos e não funcionarão."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "При отказе: сессии репозиториев в этой папке не смогут читать файлы и не будут работать."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拒绝后：该文件夹内 repo 的会话读不到文件，无法工作。"
          }
        }
      }
    },
    "거부하면: 외부망에서 직접 연결이 안 될 수 있고, 그 경우 Tor 로 자동 폴백합니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند الرفض: قد يتعذر الاتصال المباشر من الشبكات الخارجية، وعندها يتم التحويل تلقائياً إلى Tor."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If declined: direct connections from outside networks may fail; in that case it automatically falls back to Tor."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si lo rechazas: la conexión directa desde redes externas puede fallar; en ese caso se recurre automáticamente a Tor."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si refusé : la connexion directe depuis l'extérieur peut échouer ; dans ce cas, bascule automatique vers Tor."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मना करने पर: बाहरी नेटवर्क से सीधा कनेक्शन विफल हो सकता है; तब अपने आप Tor पर चला जाता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "拒否すると: 外部ネットワークからの直接接続ができない場合があり、その際は自動的に Tor にフォールバックします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "거부하면: 외부망에서 직접 연결이 안 될 수 있고, 그 경우 Tor 로 자동 폴백합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Se recusar: a conexão direta de redes externas pode falhar; nesse caso há fallback automático para o Tor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "При отказе: прямое подключение из внешних сетей может не работать — тогда автоматически используется Tor."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拒绝后：外网可能无法直连，此时会自动回退到 Tor。"
          }
        }
      }
    },
    "거부하면: 잔량 표시만 «조회 불가» 가 되고, 다른 기능에는 영향이 없습니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند الرفض: يصبح عرض الرصيد فقط «غير متاح» — ولا يتأثر أي شيء آخر."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If declined: only the usage display shows “unavailable” — nothing else is affected."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si lo rechazas: solo la indicación de uso pasa a «no disponible»; nada más se ve afectado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si refusé : seul l'affichage du quota devient « indisponible » — rien d'autre n'est affecté."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मना करने पर: केवल बैलेंस डिस्प्ले “अनुपलब्ध” हो जाएगा — बाकी किसी सुविधा पर असर नहीं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "拒否すると: 残量表示だけが「取得できません」になり、他の機能には影響しません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "거부하면: 잔량 표시만 «조회 불가» 가 되고, 다른 기능에는 영향이 없습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Se recusar: apenas a exibição de uso fica “indisponível” — nada mais é afetado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "При отказе: лишь показ остатка станет «недоступен» — остальное не пострадает."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拒绝后：只有余量显示变为“无法获取”，其他功能不受影响。"
          }
        }
      }
    },
    "거부하면: 직접 연결이 막혀 모든 통신이 Tor 우회로만 갑니다 — 동작은 하지만 눈에 띄게 느려집니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند الرفض: يُحظر الاتصال المباشر وتمر كل الاتصالات عبر Tor فقط — يعمل التطبيق لكن بشكل أبطأ بوضوح."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If declined: direct connections are blocked and all traffic falls back to Tor — it still works, but noticeably slower."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si lo rechazas: la conexión directa queda bloqueada y todo el tráfico pasa solo por Tor; funciona, pero notablemente más lento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si refusé : la connexion directe est bloquée et tout le trafic passe uniquement par Tor — ça fonctionne, mais nettement plus lentement."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मना करने पर: सीधा कनेक्शन रुक जाता है और सारा ट्रैफ़िक केवल Tor से जाता है — काम करता है, पर काफ़ी धीमा।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "拒否すると: 直接接続が遮断され、すべての通信が Tor 経由になります — 動作はしますが目に見えて遅くなります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "거부하면: 직접 연결이 막혀 모든 통신이 Tor 우회로만 갑니다 — 동작은 하지만 눈에 띄게 느려집니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Se recusar: a conexão direta é bloqueada e todo o tráfego passa só pelo Tor — funciona, mas visivelmente mais lento."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "При отказе: прямое соединение блокируется, и весь трафик идёт только через Tor — всё работает, но заметно медленнее."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拒绝后：直连被阻断，所有通信只能走 Tor — 仍可使用，但明显变慢。"
          }
        }
      }
    },
