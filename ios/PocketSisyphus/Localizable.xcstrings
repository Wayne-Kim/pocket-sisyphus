    "디스크 공간이 부족해 모델을 받을 수 없어요. 저장 공간을 확보한 뒤 다시 시도하세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا توجد مساحة كافية على القرص لتنزيل النموذج. حرّر بعض المساحة ثم أعد المحاولة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Not enough disk space to download the model. Free up some storage and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay suficiente espacio en disco para descargar el modelo. Libera espacio y vuelve a intentarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Espace disque insuffisant pour télécharger le modèle. Libérez de l'espace et réessayez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मॉडल डाउनलोड करने के लिए पर्याप्त डिस्क स्थान नहीं है। कुछ जगह खाली करके फिर कोशिश करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ディスク容量が足りずモデルをダウンロードできません。空き容量を確保してから再試行してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "디스크 공간이 부족해 모델을 받을 수 없어요. 저장 공간을 확보한 뒤 다시 시도하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Espaço em disco insuficiente para baixar o modelo. Libere espaço e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Недостаточно места на диске для загрузки модели. Освободите место и повторите попытку."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "磁盘空间不足，无法下载模型。请释放存储空间后重试。"
          }
        }
      }
    },
