    "지금 같은 Wi‑Fi 의 사설 주소로만 연결돼 있어요. 패킷이 사설망을 벗어나지 않아요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أنت الآن متصل فقط عبر العنوان الخاص على نفس شبكة Wi-Fi. لا تغادر الحزم الشبكة الخاصة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You're now connected only via the private address on the same Wi-Fi. Packets don't leave the private network."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ahora estás conectado solo por la dirección privada en la misma Wi-Fi. Los paquetes no salen de la red privada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous êtes désormais connecté uniquement via l'adresse privée sur le même Wi-Fi. Les paquets ne quittent pas le réseau privé."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अभी आप उसी Wi-Fi पर केवल निजी पते से कनेक्ट हैं। पैकेट निजी नेटवर्क से बाहर नहीं जाते।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在、同じWi-Fiのプライベートアドレスだけで接続しています。パケットはプライベートネットワークの外に出ません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "지금 같은 Wi‑Fi 의 사설 주소로만 연결돼 있어요. 패킷이 사설망을 벗어나지 않아요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você está conectado apenas pelo endereço privado na mesma Wi-Fi. Os pacotes não saem da rede privada."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сейчас вы подключены только по частному адресу в той же сети Wi-Fi. Пакеты не покидают частную сеть."
          }
        },
        "zh-Hans": {
