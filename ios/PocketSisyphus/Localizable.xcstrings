          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "예약 작업 켜기/끄기"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ativar/desativar tarefa agendada"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Включить или выключить задачу"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开关定时任务"
          }
        }
      }
    },
    "예약 작업은 사람이 없을 때 도니까 도구를 자동 승인하는 게 좋아요. 신뢰하는 폴더에서만 쓰세요. Mac 이 깨어 있어야 실행돼요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعمل المهام المجدولة دون إشراف، لذا يُنصح بالموافقة التلقائية على الأدوات. استخدمها فقط في المجلدات الموثوقة. ويجب أن يكون جهاز Mac قيد التشغيل لتنفيذها."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Scheduled tasks run unattended, so auto-approving tools is recommended. Use only in folders you trust. The Mac must be awake to run them."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las tareas programadas se ejecutan sin supervisión, así que conviene aprobar las herramientas automáticamente. Úsalo solo en carpetas de confianza. El Mac debe estar encendido para ejecutarlas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les tâches planifiées s’exécutent sans surveillance ; il est donc recommandé d’approuver automatiquement les outils. À utiliser uniquement dans des dossiers de confiance. Le Mac doit être allumé pour les exécuter."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अनुसूचित कार्य बिना निगरानी चलते हैं, इसलिए टूल को स्वतः स्वीकृत करना बेहतर है। केवल भरोसेमंद फ़ोल्डर में उपयोग करें। चलाने के लिए Mac जागृत होना चाहिए।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "予約タスクは無人で実行されるため、ツールの自動承認をおすすめします。信頼できるフォルダでのみ使用してください。実行には Mac が起動している必要があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "예약 작업은 사람이 없을 때 도니까 도구를 자동 승인하는 게 좋아요. 신뢰하는 폴더에서만 쓰세요. Mac 이 깨어 있어야 실행돼요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tarefas agendadas rodam sem supervisão, então é recomendável aprovar as ferramentas automaticamente. Use apenas em pastas confiáveis. O Mac precisa estar ligado para executá-las."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Запланированные задачи выполняются без присмотра, поэтому рекомендуется автоматически одобрять инструменты. Используйте только в доверенных папках. Для запуска Mac должен быть включён."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "定时任务无人值守运行，因此建议自动批准工具。请仅在受信任的目录中使用。需 Mac 处于唤醒状态才能运行。"
          }
        }
      }
    },
