    "화면 위에 손가락으로 표시하고, 무엇을 고칠지 한 줄로 적어 보내세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ضع علامة على الشاشة بإصبعك واكتب في سطر واحد ما يجب إصلاحه ثم أرسله."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Mark up the screen with your finger and write in one line what should be fixed."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Marca la pantalla con el dedo y escribe en una línea qué hay que corregir."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Annotez l'écran avec votre doigt et écrivez en une ligne ce qu'il faut corriger."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्क्रीन पर अपनी उंगली से निशान लगाएं और एक पंक्ति में लिखें कि क्या ठीक करना है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "画面を指でマークして、何を直すか一行で書いて送ってください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "화면 위에 손가락으로 표시하고, 무엇을 고칠지 한 줄로 적어 보내세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Marque a tela com o dedo e escreva em uma linha o que deve ser corrigido."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отметьте на экране пальцем и одной строкой напишите, что нужно исправить."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用手指在屏幕上标注，并用一行写明需要修改的地方。"
          }
        }
      }
