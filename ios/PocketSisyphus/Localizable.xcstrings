    "Tor 회복 불가 — %@\\n잠시 뒤 다시 시도해 주세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذّرت استعادة Tor — %@\nيرجى المحاولة مرة أخرى بعد قليل."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor recovery failed — %@\nPlease try again in a moment."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo recuperar Tor — %@\nInténtalo de nuevo en un momento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de récupérer Tor — %@\nVeuillez réessayer dans un instant."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor की रिकवरी नहीं हो सकी — %@\nकृपया थोड़ी देर बाद फिर कोशिश करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor を回復できません — %@\n少し時間をおいてから再度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor 회복 불가 — %@\\n잠시 뒤 다시 시도해 주세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível recuperar o Tor — %@\nTente novamente em instantes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось восстановить Tor — %@\nПопробуйте ещё раз чуть позже."
