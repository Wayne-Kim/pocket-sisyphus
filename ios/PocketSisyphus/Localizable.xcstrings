    "이름 변경: 세션 리스트에서 스와이프 → «이름 변경», 또는 채팅 화면 우상단 점 메뉴에서 «이름 변경».": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إعادة التسمية: مرّر الجلسة جانبيًا واختر «إعادة التسمية»، أو من قائمة النقاط أعلى يمين شاشة الدردشة اختر «إعادة التسمية»."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Rename: swipe a session in the list → “Rename”, or use the ellipsis menu at the top right of the chat screen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Renombrar: desliza una sesión en la lista → «Renombrar», o abre el menú de puntos arriba a la derecha en el chat."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Renommer : faites glisser une session dans la liste → « Renommer », ou utilisez le menu en haut à droite du chat."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नाम बदलें: सूची में सत्र को स्वाइप → «नाम बदलें», या चैट के दाईं ओर ऊपर बिंदु मेनू → «नाम बदलें»."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "名前変更: セッション一覧でスワイプ → 「名前を変更」、もしくはチャット画面右上のメニュー → 「名前を変更」。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이름 변경: 세션 리스트에서 스와이프 → «이름 변경», 또는 채팅 화면 우상단 점 메뉴에서 «이름 변경»."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Renomear: deslize a sessão na lista → «Renomear», ou no menu de pontos no canto superior direito do chat."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Переименование: смахните сессию в списке → «Переименовать», или меню «⋯» в правом верхнем углу чата."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "重命名:在列表中滑动会话 → 「重命名」,或在聊天页右上角的菜单 → 「重命名」。"
