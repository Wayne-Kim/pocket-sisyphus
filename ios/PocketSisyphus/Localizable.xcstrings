    "여러 에이전트 작업을 노드로 잇고 한 번에 자동 실행하는 작업 흐름입니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سير عمل يربط مهام عدة وكلاء كعُقد ويشغّلها تلقائيًا دفعة واحدة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A workflow that links multiple agent tasks as nodes and runs them automatically in one go."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un flujo de trabajo que conecta varias tareas de agentes como nodos y las ejecuta automáticamente de una vez."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un flux de travail qui relie plusieurs tâches d'agents sous forme de nœuds et les exécute automatiquement d'un seul coup."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक वर्कफ़्लो जो कई एजेंट कार्यों को नोड्स के रूप में जोड़ता है और उन्हें एक साथ स्वचालित रूप से चलाता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "複数のエージェント作業をノードでつなぎ、一度に自動実行するワークフローです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "여러 에이전트 작업을 노드로 잇고 한 번에 자동 실행하는 작업 흐름입니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Um fluxo de trabalho que conecta várias tarefas de agentes como nós e as executa automaticamente de uma vez."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Рабочий процесс, который связывает задачи нескольких агентов в виде узлов и выполняет их автоматически за один раз."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将多个智能体任务以节点连接、一次性自动执行的工作流。"
          }
        }
      }
    },
