    "QR 디코드 실패 — Mac 에서 새 QR 을 출력해 다시 스캔해 주세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فشل فك ترميز QR — يُرجى إخراج رمز QR جديد من Mac وإعادة المسح."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "QR decode failed — generate a new QR on Mac and scan again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Error al decodificar el QR — genera un nuevo QR en Mac y vuelve a escanear."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec du décodage du QR — générez un nouveau QR sur Mac et réessayez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "QR डिकोड विफल — कृपया Mac पर नया QR तैयार करें और फिर से स्कैन करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "QR のデコードに失敗 — Mac で新しい QR を出力して再スキャンしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "QR 디코드 실패 — Mac 에서 새 QR 을 출력해 다시 스캔해 주세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Falha ao decodificar o QR — gere um novo QR no Mac e escaneie novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось декодировать QR — сгенерируйте новый QR на Mac и отсканируйте снова."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "QR 解码失败 — 请在 Mac 上生成新的 QR 后重新扫描。"
          }
        }
      }
    },
    "QR 디코드 실패 — 수동 입력을 사용해주세요": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فشل فك ترميز QR — استخدم الإدخال اليدوي"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn’t decode the QR — please use manual entry"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo decodificar el QR — usa la entrada manual"
          }
        },
        "fr": {
