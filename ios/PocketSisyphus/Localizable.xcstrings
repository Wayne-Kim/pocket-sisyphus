    "설명을 읽고 노드를 설계하는 중이에요. 잠시 걸릴 수 있어요.": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "설명을 읽고 노드를 설계하는 중이에요. 잠시 걸릴 수 있어요."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reading your description and designing the nodes. This may take a moment."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "説明を読んでノードを設計しています。少し時間がかかることがあります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正在阅读你的描述并设计节点。可能需要一点时间。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Leyendo tu descripción y diseñando los nodos. Esto puede tardar un momento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lecture de votre description et conception des nœuds. Cela peut prendre un instant."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "نقرأ وصفك ونصمم العُقد. قد يستغرق ذلك لحظة."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
