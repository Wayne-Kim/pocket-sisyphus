    "Tor client-auth 키 — iPhone 의 Keychain (Tor 가 onion 회로를 짤 때 사용).": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مفتاح Tor client-auth — في Keychain على iPhone (يستخدمه Tor عند بناء دائرة onion)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor client-auth key — in the iPhone’s Keychain (used by Tor when building the onion circuit)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Clave Tor client-auth — en el Keychain del iPhone (la usa Tor al construir el circuito onion)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Clé Tor client-auth — dans le Keychain de l’iPhone (utilisée par Tor lors de la construction du circuit onion)."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor client-auth कुंजी — iPhone के Keychain में (onion सर्किट बनाते समय Tor इसका उपयोग करता है)।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor client-auth キー — iPhone の Keychain (Tor が onion 回路を組むときに使用)。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Chave Tor client-auth — no Keychain do iPhone (usada pelo Tor ao montar o circuito onion)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ключ Tor client-auth — в Keychain iPhone (используется Tor при построении onion-цепочки)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor client-auth 密钥 — 存于 iPhone 的 Keychain（Tor 构建 onion 电路时使用）。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor client-auth 키 — iPhone 의 Keychain (Tor 가 onion 회로를 짤 때 사용)."
          }
        }
      }
    },
    "Tor client-auth 키 — v3 클라이언트 인증 키. 이 키 없이는 onion 주소가 있어도 접근 불가.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مفتاح Tor client-auth — مفتاح مصادقة العميل v3. بدون هذا المفتاح لا يمكن الوصول حتى لو توفر عنوان onion."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor client-auth key — the v3 client authorization key. Without it, you cannot reach the onion address even if you have it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Clave Tor client-auth — clave de autorización de cliente v3. Sin esta clave no se puede acceder aunque se tenga la dirección onion."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Clé Tor client-auth — clé d’autorisation client v3. Sans elle, impossible d’accéder à l’adresse onion même en la connaissant."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor client-auth कुंजी — v3 क्लाइंट प्राधिकरण कुंजी। इस कुंजी के बिना onion पता होने पर भी पहुँच नहीं मिलती।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor client-auth キー — v3 クライアント認証キー。このキーがなければ onion アドレスがあってもアクセス不可。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Chave Tor client-auth — chave de autorização de cliente v3. Sem ela, mesmo tendo o endereço onion não é possível acessar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ключ Tor client-auth — ключ авторизации клиента v3. Без него onion-адрес неприступен, даже если он у вас есть."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor client-auth 密钥 — v3 客户端授权密钥。没有它，即使有 onion 地址也无法访问。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor client-auth 키 — v3 클라이언트 인증 키. 이 키 없이는 onion 주소가 있어도 접근 불가."
          }
        }
      }
    },
    "Tor control port 응답 없음": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
