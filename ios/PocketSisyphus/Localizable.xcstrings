    "잠금/백그라운드에서도 Tor 회로를 살려두기 위해 iOS 의 VPN 슬롯이 필요합니다. 매번 앱을 다시 켤 필요가 없습니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "نحتاج إلى خانة VPN في iOS لإبقاء دائرة Tor حيّة حتى مع القفل أو العمل في الخلفية. لا داعي لإعادة فتح التطبيق في كل مرة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We use the iOS VPN slot to keep the Tor circuit alive while the device is locked or backgrounded. You don’t have to reopen the app every time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Necesitamos la ranura VPN de iOS para mantener vivo el circuito Tor con la pantalla bloqueada o en segundo plano. No hace falta reabrir la app cada vez."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous utilisons le slot VPN d’iOS pour maintenir le circuit Tor actif même lorsque l’appareil est verrouillé ou en arrière-plan. Pas besoin de rouvrir l’app à chaque fois."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "लॉक/बैकग्राउंड में भी Tor सर्किट को ज़िंदा रखने के लिए iOS के VPN स्लॉट की ज़रूरत है। हर बार ऐप दोबारा खोलने की ज़रूरत नहीं पड़ेगी।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ロック中やバックグラウンドでも Tor 回路を維持するために、iOS の VPN スロットを使います。毎回アプリを開き直す必要はありません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "잠금/백그라운드에서도 Tor 회로를 살려두기 위해 iOS 의 VPN 슬롯이 필요합니다. 매번 앱을 다시 켤 필요가 없습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Precisamos do slot de VPN do iOS para manter o circuito Tor vivo com o aparelho bloqueado ou em segundo plano. Não é preciso reabrir o app toda hora."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Слот VPN в iOS нужен, чтобы цепь Tor оставалась живой при заблокированном экране и в фоне. Не придётся каждый раз открывать приложение заново."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "需要占用 iOS 的 VPN 槽位,以便在锁屏/后台也能让 Tor 线路保持活动。你不必每次都重新打开应用。"
          }
        }
      }
    },
    "잠시 후 다시 시도해 주세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يرجى المحاولة مرة أخرى بعد قليل."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please try again in a moment."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Inténtalo de nuevo en un momento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Veuillez réessayer dans un instant."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कृपया थोड़ी देर बाद फिर कोशिश करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "しばらくしてからもう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "잠시 후 다시 시도해 주세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tente novamente em instantes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Повторите попытку через мгновение."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请稍后重试。"
          }
        }
      }
    },
    "재시도": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "재시도"
          }
        },
