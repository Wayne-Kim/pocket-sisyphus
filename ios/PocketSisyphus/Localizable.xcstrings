    "위에서 레포 경로를 고르면, 데스크탑에서 진행 중이던 코드 에이전트 세션을 여기서 이어 받을 수 있어요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر مسار المستودع أعلاه لمتابعة جلسة وكيل البرمجة قيد التشغيل على سطح المكتب هنا."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pick a repo path above to resume an in-progress desktop coding-agent session here."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecciona arriba una ruta de repo para reanudar aquí una sesión de agente de programación en curso del escritorio."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez ci-dessus un chemin de repo pour reprendre ici une session d’agent de codage en cours sur le bureau."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ऊपर रेपो पथ चुनें ताकि डेस्कटॉप पर चल रहा कोडिंग एजेंट सत्र यहाँ जारी रखा जा सके।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "上でリポジトリのパスを選ぶと、デスクトップで進行中のコーディングエージェントのセッションをここで引き継げます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "위에서 레포 경로를 고르면, 데스크탑에서 진행 중이던 코드 에이전트 세션을 여기서 이어 받을 수 있어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha um caminho de repo acima para retomar aqui uma sessão de agente de programação em andamento no desktop."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите путь к репо выше, чтобы продолжить здесь сессию кодинг-агента, идущую на десктопе."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在上方选择仓库路径,即可在此接续桌面正在进行的编码 Agent 会话。"
          }
        }
      }
    },
