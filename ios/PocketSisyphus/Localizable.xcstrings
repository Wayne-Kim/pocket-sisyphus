        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रतिक्रिया का मुख्य भाग base64 या UTF-8 दोनों में डिकोड नहीं हो सका।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
