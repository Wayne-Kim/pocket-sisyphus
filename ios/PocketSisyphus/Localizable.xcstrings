    "맥에서 다른 빌드가 동시에 실행 중일 수 있어요": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قد يكون إصدار آخر قيد التشغيل على جهاز Mac"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Another build may be running on your Mac"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puede que haya otra compilación ejecutándose en tu Mac"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une autre version est peut-être en cours d’exécution sur votre Mac"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपके Mac पर शायद कोई दूसरा बिल्ड चल रहा है"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac で別のビルドが同時に起動している可能性があります"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "맥에서 다른 빌드가 동시에 실행 중일 수 있어요"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Outra versão do app pode estar em execução no seu Mac"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Возможно, на вашем Mac запущена другая сборка"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac 上可能同时运行着另一个版本"
          }
        }
      }
    },
    "맥에서 다른 빌드(dev·release)가 동시에 실행 중일 수 있어요 — 공유 포트가 충돌하면 폰이 데몬에 닿지 못해요. 맥에서 한쪽 앱만 켜고 다시 시도해 주세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قد يكون إصدار آخر (dev·release) قيد التشغيل في الوقت نفسه على جهاز Mac — وإذا تنازعا على المنفذ المشترك، فلن يتمكّن الهاتف من الوصول إلى الخفي (daemon). أغلق أحد التطبيقين على جهاز Mac وحاول مرة أخرى."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A different build (dev·release) may be running on your Mac at the same time — if they fight over the shared port, your phone can’t reach the daemon. Quit one of the apps on your Mac and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puede que en tu Mac se esté ejecutando otra compilación (dev·release) al mismo tiempo: si compiten por el puerto compartido, el teléfono no puede llegar al daemon. Cierra una de las apps en tu Mac y vuelve a intentarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une autre version (dev·release) est peut-être en cours d’exécution en même temps sur votre Mac — si elles se disputent le port partagé, le téléphone ne peut pas joindre le démon. Quittez l’une des applications sur votre Mac et réessayez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपके Mac पर एक साथ कोई दूसरा बिल्ड (dev·release) चल रहा हो सकता है — अगर वे साझा पोर्ट के लिए टकराते हैं, तो फ़ोन डीमन तक नहीं पहुँच पाता। अपने Mac पर किसी एक ऐप को बंद करें और फिर से प्रयास करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac で別のビルド（dev・release）が同時に起動している可能性があります — 共有ポートが競合すると、iPhone がデーモンに接続できません。Mac で片方のアプリだけを起動して、もう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "맥에서 다른 빌드(dev·release)가 동시에 실행 중일 수 있어요 — 공유 포트가 충돌하면 폰이 데몬에 닿지 못해요. 맥에서 한쪽 앱만 켜고 다시 시도해 주세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Outra versão (dev·release) pode estar em execução ao mesmo tempo no seu Mac — se elas disputarem a porta compartilhada, o telefone não consegue alcançar o daemon. Encerre um dos apps no seu Mac e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Возможно, на вашем Mac одновременно запущена другая сборка (dev·release) — если они конфликтуют за общий порт, телефон не может подключиться к демону. Закройте одно из приложений на Mac и повторите попытку."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac 上可能同时运行着另一个版本（dev·release）——如果它们争用共享端口，手机就无法连接到守护进程。请在 Mac 上只保留一个应用，然后重试。"
          }
        }
      }
    },
    "endpoint 는 응답했으나 모든 SSH/데몬 채널 연결 실패 — 다른 빌드와 포트 충돌 가능": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استجاب endpoint لكن فشلت جميع قنوات SSH/الخفي — احتمال تعارض منفذ مع إصدار آخر"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "endpoint responded but all SSH/daemon channels failed — possible port conflict with another build"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "el endpoint respondió pero fallaron todos los canales SSH/daemon — posible conflicto de puerto con otra compilación"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "l’endpoint a répondu mais tous les canaux SSH/démon ont échoué — conflit de port possible avec une autre version"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "endpoint ने जवाब दिया पर सभी SSH/डीमन चैनल विफल — किसी दूसरे बिल्ड से पोर्ट टकराव संभव"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "endpoint は応答しましたが、すべての SSH/デーモンチャネルの接続に失敗 — 別ビルドとのポート競合の可能性"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "endpoint 는 응답했으나 모든 SSH/데몬 채널 연결 실패 — 다른 빌드와 포트 충돌 가능"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "o endpoint respondeu, mas todos os canais SSH/daemon falharam — possível conflito de porta com outra versão"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "endpoint ответил, но все SSH/демон-каналы не подключились — возможен конфликт порта с другой сборкой"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "endpoint 已响应，但所有 SSH/守护进程通道连接失败——可能与另一个版本发生端口冲突"
          }
        }
      }
    },
