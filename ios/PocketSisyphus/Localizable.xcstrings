    "확대·축소 (정착하면 선명하게 다시 받아옴)": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تكبير أو تصغير (يُعاد جلبه بوضوح أعلى بعد الاستقرار)"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Zoom in or out (refetches it sharper once it settles)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Acercar o alejar (se vuelve a obtener más nítido al asentarse)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Zoomer ou dézoomer (récupéré plus net une fois stabilisé)"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ज़ूम इन या आउट (स्थिर होने पर अधिक स्पष्ट दोबारा लाया जाता है)"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "拡大・縮小（落ち着くと鮮明に取得し直します）"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "확대·축소 (정착하면 선명하게 다시 받아옴)"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ampliar ou reduzir (recarrega mais nítido ao estabilizar)"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Увеличение или уменьшение (после стабилизации подгружается чётче)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "放大或缩小（稳定后会重新获取更清晰的画面）"
          }
        }
      }
    },
