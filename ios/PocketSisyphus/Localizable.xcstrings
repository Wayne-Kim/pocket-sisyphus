    "세션 %lld건을 삭제하지 못했어요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذّر حذف %lld جلسة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn’t delete %lld sessions."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudieron eliminar %lld sesiones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de supprimer %lld sessions."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld सत्र हटाए नहीं जा सके।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "セッション%lld件を削除できませんでした。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "세션 %lld건을 삭제하지 못했어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível excluir %lld sessões."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось удалить %lld сессий."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法删除 %lld 个会话。"
          }
        }
      }
    },
    "세션 경로 폴더를 만들 수 없어요. 경로를 확인해 주세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذّر إنشاء مجلد مسار الجلسة. يرجى التحقق من المسار."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't create the session path folder. Please check the path."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo crear la carpeta de la ruta de la sesión. Comprueba la ruta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de créer le dossier du chemin de la session. Veuillez vérifier le chemin."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सेशन पथ फ़ोल्डर नहीं बनाया जा सका। कृपया पथ जाँचें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "セッションパスのフォルダを作成できませんでした。パスを確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "세션 경로 폴더를 만들 수 없어요. 경로를 확인해 주세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível criar a pasta do caminho da sessão. Verifique o caminho."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось создать папку для пути сессии. Проверьте путь."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法创建会话路径文件夹。请检查路径。"
          }
        }
      }
    },
    "세션 루트 기준 상대경로. 비우면 attachments 폴더에 저장됩니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مسار نسبي إلى جذر الجلسة. إذا تُرك فارغًا، يُحفظ في مجلد attachments."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Relative to the session root. Saved to the attachments folder if left empty."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Relativo a la raíz de la sesión. Si se deja vacío, se guarda en la carpeta attachments."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Relatif à la racine de la session. Enregistré dans le dossier attachments si vide."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सेशन रूट के सापेक्ष। खाली छोड़ने पर attachments फ़ोल्डर में सहेजा जाएगा।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "セッションのルートからの相対パス。空欄なら attachments フォルダに保存されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "세션 루트 기준 상대경로. 비우면 attachments 폴더에 저장됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Relativo à raiz da sessão. Se vazio, salvo na pasta attachments."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Относительно корня сессии. Если пусто — сохраняется в папку attachments."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "相对于会话根目录。留空则保存到 attachments 文件夹。"
          }
        }
      }
    },
