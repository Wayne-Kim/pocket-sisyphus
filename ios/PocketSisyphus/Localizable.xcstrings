        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 실행은 아직 격리 브랜치를 main 에 머지 요청하지 않았어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta execução ainda não solicitou o merge do seu branch de isolamento no main."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Этот запуск ещё не запросил слияние своей изолированной ветки в main."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
