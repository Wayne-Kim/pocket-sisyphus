    "기기 인증, 현재 채널의 신원 보장, 서버 호스트 키 검증 등급을 한 곳에서 확인할 수 있어요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تحقّق في مكان واحد من مصادقة الجهاز، وضمان هوية القناة الحالية، ودرجة التحقق من مفتاح مضيف الخادم."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Check device authentication, the current channel's identity guarantee, and the server host key verification grade all in one place."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Consulta en un solo lugar la autenticación del dispositivo, la garantía de identidad del canal actual y el nivel de verificación de la clave de host del servidor."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Consultez au même endroit l'authentification de l'appareil, la garantie d'identité du canal actuel et le niveau de vérification de la clé d'hôte du serveur."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डिवाइस प्रमाणीकरण, वर्तमान चैनल की पहचान गारंटी, और सर्वर होस्ट कुंजी सत्यापन ग्रेड को एक ही जगह देखें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバイス認証、現在のチャンネルの身元保証、サーバーのホストキー検証グレードを一か所で確認できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기기 인증, 현재 채널의 신원 보장, 서버 호스트 키 검증 등급을 한 곳에서 확인할 수 있어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Veja em um só lugar a autenticação do dispositivo, a garantia de identidade do canal atual e o nível de verificação da chave de host do servidor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "В одном месте проверяйте аутентификацию устройства, гарантию подлинности текущего канала и уровень проверки ключа хоста сервера."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在一个地方查看设备认证、当前通道的身份保证以及服务器主机密钥验证等级。"
          }
        }
      }
    },
    "기기 인증은 폰의 Secure Enclave에 묶인 추출 불가능한 키로, 매번 생체 인증으로 서명을 게이팅합니다. 페어링 QR이 유출돼도 이 기기 없이는 접근할 수 없어요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تستخدم مصادقة الجهاز مفتاحًا غير قابل للاستخراج مرتبطًا بـ Secure Enclave في الهاتف، وتحمي كل توقيع بالمصادقة الحيوية. وحتى لو تسرّب رمز QR للإقران، لا يمكن لأحد الاتصال بدون هذا الجهاز."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Device authentication uses a non-extractable key bound to the phone's Secure Enclave, gating each signature with biometrics. Even if the pairing QR leaks, no one can connect without this device."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La autenticación del dispositivo usa una clave no extraíble vinculada al Secure Enclave del teléfono y protege cada firma con biometría. Aunque se filtre el QR de emparejamiento, nadie puede conectarse sin este dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'authentification de l'appareil utilise une clé non extractible liée au Secure Enclave du téléphone et protège chaque signature par biométrie. Même si le QR d'appairage fuit, personne ne peut se connecter sans cet appareil."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डिवाइस प्रमाणीकरण फ़ोन के Secure Enclave से बंधी एक ऐसी कुंजी का उपयोग करता है जिसे निकाला नहीं जा सकता, और हर हस्ताक्षर को बायोमेट्रिक्स से सुरक्षित करता है। पेयरिंग QR लीक होने पर भी इस डिवाइस के बिना कोई कनेक्ट नहीं कर सकता।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバイス認証は、電話のSecure Enclaveに結び付けられた抽出不可能なキーを使い、署名のたびに生体認証で保護します。ペアリングQRが漏れても、このデバイスなしではアクセスできません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기기 인증은 폰의 Secure Enclave에 묶인 추출 불가능한 키로, 매번 생체 인증으로 서명을 게이팅합니다. 페어링 QR이 유출돼도 이 기기 없이는 접근할 수 없어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A autenticação do dispositivo usa uma chave não extraível vinculada ao Secure Enclave do telefone e protege cada assinatura com biometria. Mesmo que o QR de pareamento vaze, ninguém consegue se conectar sem este dispositivo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Аутентификация устройства использует неизвлекаемый ключ, привязанный к Secure Enclave телефона, и защищает каждую подпись биометрией. Даже если QR-код сопряжения утечёт, без этого устройства подключиться невозможно."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设备认证使用绑定到手机 Secure Enclave 的不可导出密钥，每次签名都通过生物识别进行门控。即使配对二维码泄露，没有此设备也无法访问。"
          }
        }
      }
    },
    "기기 정보를 불러오지 못했어요 — Mac 앱이 실행 중인지 확인하세요": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذّر تحميل معلومات الجهاز — تأكد من أن تطبيق Mac قيد التشغيل"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't load device info — check that the Mac app is running"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo cargar la información del dispositivo: comprueba que la app de Mac esté en ejecución"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de charger les informations de l'appareil — vérifiez que l'app Mac est en cours d'exécution"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डिवाइस जानकारी लोड नहीं हो सकी — जांचें कि Mac ऐप चल रहा है"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバイス情報を読み込めませんでした — Macアプリが実行中か確認してください"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기기 정보를 불러오지 못했어요 — Mac 앱이 실행 중인지 확인하세요"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível carregar as informações do dispositivo — verifique se o app do Mac está em execução"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось загрузить информацию об устройстве — убедитесь, что приложение Mac запущено"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法加载设备信息 — 请确认 Mac 应用正在运行"
          }
        }
      }
    },
