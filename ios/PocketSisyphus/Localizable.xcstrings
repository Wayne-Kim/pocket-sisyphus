    "bridge 로도 Tor 에 연결하지 못했어요. bridge 라인이 만료됐거나 막혔을 수 있어요 — 새 bridge 를 받아 다시 시도해 주세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذّر الوصول إلى Tor حتى عبر جسر. قد تكون أسطر الجسر منتهية الصلاحية أو محظورة — احصل على جسور جديدة وحاول مرة أخرى."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't reach Tor even through a bridge. The bridge lines may be expired or blocked — get new bridges and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo llegar a Tor ni a través de un puente. Las líneas de puente pueden estar caducadas o bloqueadas; obtén nuevos puentes e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible d'atteindre Tor même via un pont. Les lignes de pont sont peut-être expirées ou bloquées — obtenez de nouveaux ponts et réessayez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "bridge के ज़रिए भी Tor तक नहीं पहुँचा जा सका। bridge लाइनें समाप्त या अवरुद्ध हो सकती हैं — नए bridge प्राप्त करके फिर से प्रयास करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "bridge を使っても Tor に接続できませんでした。bridge ラインが期限切れか遮断されている可能性があります — 新しい bridge を取得して再試行してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "bridge 로도 Tor 에 연결하지 못했어요. bridge 라인이 만료됐거나 막혔을 수 있어요 — 새 bridge 를 받아 다시 시도해 주세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível alcançar o Tor nem por uma ponte. As linhas de ponte podem estar expiradas ou bloqueadas — obtenha novas pontes e tente de novo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось подключиться к Tor даже через мост. Возможно, строки моста устарели или заблокированы — получите новые мосты и попробуйте снова."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "即使通过 bridge 也无法连接到 Tor。bridge 行可能已过期或被屏蔽——请获取新的 bridge 后重试。"
          }
        }
      }
    },
