    "페어링 되지 않음": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "غير مُقترن"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Not paired"
          }
        },
        "es": {
          "stringUnit": {
