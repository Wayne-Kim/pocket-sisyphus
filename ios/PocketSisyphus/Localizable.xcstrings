    "%@가 여러 번 막히면 iPhone을 기기 암호로 잠금 해제한 뒤 다시 시도해 주세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إذا تم قفل %@ بعد عدة محاولات فاشلة، فألغِ قفل iPhone باستخدام رمز الدخول ثم أعد المحاولة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If %@ is locked after several failed attempts, unlock your iPhone with its passcode and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si %@ se bloquea tras varios intentos fallidos, desbloquea tu iPhone con su código y vuelve a intentarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si %@ est bloqué après plusieurs échecs, déverrouillez votre iPhone avec son code, puis réessayez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यदि कई असफल प्रयासों के बाद %@ लॉक हो जाए, तो अपने iPhone को उसके पासकोड से अनलॉक करें और फिर से प्रयास करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ が何度も失敗してロックされた場合は、iPhone をパスコードでロック解除してから再試行してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@가 여러 번 막히면 iPhone을 기기 암호로 잠금 해제한 뒤 다시 시도해 주세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Se o %@ for bloqueado após várias tentativas, desbloqueie o iPhone com o código e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если %@ заблокируется после нескольких неудачных попыток, разблокируйте iPhone с помощью код-пароля и повторите попытку."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果 %@ 多次失败被锁定，请用设备密码解锁 iPhone 后重试。"
          }
        }
      }
    },
