    "기각": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기각"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reject"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "却下"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "驳回"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Rechazar"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rejeter"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Rejeitar"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отклонить"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "رفض"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अस्वीकार"
          }
        }
      }
    },
    "기각 — 이 제안은 종결해요. 남은 TODO 주석·죽은 코드 같은 흔적을 함께 정리하게 할 수도 있어요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الرفض — أغلِق هذا الاقتراح. ويمكنك أيضًا أن تجعله ينظّف الآثار المتبقّية مثل تعليقات TODO أو الشيفرة الميتة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reject — close out this proposal. You can also have it clean up leftover traces such as TODO comments or dead code."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Rechazar — cierra esta propuesta. También puedes pedir que limpie los restos, como comentarios TODO o código muerto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rejeter — clôturez cette proposition. Vous pouvez aussi lui faire nettoyer les traces restantes, comme les commentaires TODO ou le code mort."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अस्वीकृत करें — इस पेशकश को समाप्त करें। आप बचे हुए TODO टिप्पणी या मृत कोड जैसे अवशेष भी साफ़ करवा सकते हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "却下 — この提案を終了します。残った TODO コメントやデッドコードなどの痕跡を、あわせて片づけさせることもできます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기각 — 이 제안은 종결해요. 남은 TODO 주석·죽은 코드 같은 흔적을 함께 정리하게 할 수도 있어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Rejeitar — encerre esta proposta. Você também pode fazê-lo limpar vestígios restantes, como comentários TODO ou código morto."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отклонить — закройте это предложение. Можно также поручить агенту убрать оставшиеся следы — комментарии TODO или мёртвый код."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "驳回——结束这条提议。你还可以让它一并清理遗留的 TODO 注释、死代码等痕迹。"
          }
        }
      }
    },
    "기각된 아이디어의 TODO 주석·죽은 코드가 남아 있으면 다음 신호 수집에서 같은 제안이 반복될 수 있어요. 에이전트가 근거를 따라 흔적만 정리해요 — 커밋은 하지 않아 세션에서 검토할 수 있어요.": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기각된 아이디어의 TODO 주석·죽은 코드가 남아 있으면 다음 신호 수집에서 같은 제안이 반복될 수 있어요. 에이전트가 근거를 따라 흔적만 정리해요 — 커밋은 하지 않아 세션에서 검토할 수 있어요."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If TODO comments and dead code from a rejected idea remain, the next signal collection may repeat the same proposal. The agent follows the evidence and only cleans up traces — nothing is committed, so you can review it in the session."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "却下されたアイデアの TODO コメントやデッドコードが残っていると、次の信号収集で同じ提案が繰り返される可能性があります。エージェントは根拠をたどって痕跡だけを整理します — コミットはしないため、セッションで確認できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果被驳回想法的 TODO 注释和死代码仍然残留，下次信号收集可能会重复相同的提案。智能体会沿着证据只清理痕迹 — 不会提交，你可以在会话中检查。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si quedan comentarios TODO y código muerto de una idea rechazada, la próxima recolección de señales podría repetir la misma propuesta. El agente sigue las evidencias y solo limpia los rastros — no hace commit, así que puedes revisarlo en la sesión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si des commentaires TODO et du code mort d'une idée rejetée subsistent, la prochaine collecte de signaux risque de reproposer la même chose. L'agent suit les preuves et ne nettoie que les traces — rien n'est commité, vous pouvez vérifier dans la session."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Se os comentários TODO e o código morto de uma ideia rejeitada permanecerem, a próxima coleta de sinais pode repetir a mesma proposta. O agente segue as evidências e limpa apenas os rastros — nada é commitado, então você pode revisar na sessão."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если комментарии TODO и мёртвый код отклонённой идеи останутся, следующий сбор сигналов может снова предложить то же самое. Агент идёт по уликам и убирает только следы — без коммитов, всё можно проверить в сессии."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إذا بقيت تعليقات TODO والكود الميت لفكرة مرفوضة، فقد يكرر جمع الإشارات التالي الاقتراح نفسه. يتتبع الوكيل الأدلة وينظّف الآثار فقط — دون إيداع، حتى تتمكن من المراجعة في الجلسة."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अगर अस्वीकृत आइडिया के TODO कमेंट और डेड कोड बचे रहें, तो अगला सिग्नल संग्रह वही प्रस्ताव दोहरा सकता है। एजेंट सबूतों के आधार पर केवल निशान साफ़ करता है — कमिट नहीं करता, इसलिए आप सेशन में जाँच सकते हैं।"
          }
        }
      }
    },
