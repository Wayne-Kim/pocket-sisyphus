    "되돌리기에 실패했어요. 충돌이 있으면 변경을 정리한 뒤 다시 시도해 주세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فشل التراجع. إذا كان هناك تعارض، فنظّف التغييرات ثم أعد المحاولة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Revert failed. If there’s a conflict, clean up the changes and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La reversión falló. Si hay un conflicto, organiza los cambios e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le retour a échoué. En cas de conflit, nettoyez les modifications et réessayez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वापस लाना विफल रहा। यदि कोई विरोध हो, तो बदलाव व्यवस्थित करके फिर से प्रयास करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "元に戻せませんでした。競合がある場合は変更を整理してから再試行してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "되돌리기에 실패했어요. 충돌이 있으면 변경을 정리한 뒤 다시 시도해 주세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Falha ao reverter. Se houver conflito, organize as alterações e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось откатить. При наличии конфликта очистите изменения и повторите попытку."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "还原失败。如有冲突，请整理更改后重试。"
          }
        }
      }
    },
