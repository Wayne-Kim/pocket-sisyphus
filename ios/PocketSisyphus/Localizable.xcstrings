    "컬럼 수를 직접 정합니다. 화면보다 넓으면 가로로 스크롤해서 봅니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حدّد عدد الأعمدة بنفسك. إذا تجاوز عرض الشاشة، يمكنك التمرير أفقيًا."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Set the column count yourself. If it's wider than the screen, scroll horizontally to view."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Define tú mismo el número de columnas. Si supera el ancho de la pantalla, desplázate horizontalmente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Définissez vous-même le nombre de colonnes. Si c'est plus large que l'écran, faites défiler horizontalement."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कॉलम की संख्या स्वयं तय करें. यदि स्क्रीन से चौड़ा हो, तो क्षैतिज रूप से स्क्रॉल करके देखें."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "列数を自分で指定します。画面より広い場合は横スクロールで表示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "컬럼 수를 직접 정합니다. 화면보다 넓으면 가로로 스크롤해서 봅니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Defina você mesmo o número de colunas. Se for mais largo que a tela, role horizontalmente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Задайте число столбцов вручную. Если шире экрана — прокручивайте по горизонтали."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自行设定列数。若超出屏幕宽度，可横向滚动查看。"
          }
        }
      }
    },
    "컬럼 줄이기": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تقليل الأعمدة"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fewer columns"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Menos columnas"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Moins de colonnes"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कम कॉलम"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "列を減らす"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "컬럼 줄이기"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Menos colunas"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Меньше столбцов"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "减少列数"
          }
        }
      }
    },
    "켜 두면 매일 이 시각에 에이전트가 신호를 수집해 새 브리프를 올려요 (Mac 시간대 기준). 결과는 알림으로 와요.": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "켜 두면 매일 이 시각에 에이전트가 신호를 수집해 새 브리프를 올려요 (Mac 시간대 기준). 결과는 알림으로 와요."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When on, the agent collects signals at this time every day and posts new briefs (Mac time zone). Results arrive as notifications."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オンにすると、毎日この時刻にエージェントがシグナルを収集して新しいブリーフを提案します（Macのタイムゾーン基準）。結果は通知で届きます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启后，代理每天在此时刻收集信号并提交新简报（以 Mac 时区为准）。结果会以通知送达。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si está activado, el agente recopila señales a esta hora cada día y publica nuevos briefs (zona horaria del Mac). Los resultados llegan como notificaciones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si activé, l'agent collecte les signaux chaque jour à cette heure et publie de nouveaux briefs (fuseau horaire du Mac). Les résultats arrivent par notification."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если включено, агент ежедневно в это время собирает сигналы и публикует новые брифы (часовой пояс Mac). Результаты приходят уведомлениями."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando ativado, o agente coleta sinais nesse horário todos os dias e publica novos briefs (fuso horário do Mac). Os resultados chegam como notificações."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चालू रहने पर एजेंट हर दिन इस समय सिग्नल इकट्ठा करके नए ब्रीफ़ प्रस्तावित करता है (Mac समय क्षेत्र)। परिणाम सूचना के रूप में आते हैं।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند التفعيل، يجمع الوكيل الإشارات في هذا الوقت يوميًا وينشر ملخصات جديدة (بتوقيت Mac). تصل النتائج كإشعارات."
          }
        }
      }
    },
    "켜 두면 수집할 때 이 앱의 최근 App Store 리뷰를 함께 읽어 사용자 불만·요청을 브리프 근거로 가져와요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند التفعيل، يقرأ التجميع أيضًا أحدث مراجعات App Store لهذا التطبيق ويجلب شكاوى المستخدمين وطلباتهم كأدلة في الموجزات."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When on, collection also reads this app's recent App Store reviews, bringing user complaints and requests into briefs as evidence."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si está activado, la recopilación también lee las reseñas recientes del App Store de esta app y aporta quejas y peticiones de los usuarios como evidencia de los informes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si activé, la collecte lit aussi les avis App Store récents de cette app et intègre les plaintes et demandes des utilisateurs comme preuves dans les brefs."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चालू रखने पर संग्रह इस ऐप की हालिया App Store समीक्षाएँ भी पढ़ता है और उपयोगकर्ता शिकायतों व अनुरोधों को ब्रीफ़ के साक्ष्य के रूप में लाता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オンにすると、収集時にこのアプリの最近の App Store レビューも読み取り、ユーザーの不満・要望をブリーフの根拠として取り込みます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "켜 두면 수집할 때 이 앱의 최근 App Store 리뷰를 함께 읽어 사용자 불만·요청을 브리프 근거로 가져와요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando ativado, a coleta também lê as avaliações recentes da App Store desta app, trazendo reclamações e pedidos dos usuários como evidência para os briefs."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Когда включено, при сборе также читаются недавние отзывы App Store этого приложения, а жалобы и запросы пользователей попадают в брифы как доказательства."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启后，收集时会一并读取此应用最近的 App Store 评论，把用户的不满和需求作为简报依据。"
          }
        }
      }
    },
    "켜면 그 방향에서 채팅·미러링 화면 구석에 버튼이 떠요. 눌러서 헤더와 컨트롤을 숨겨 화면을 넓게 보고, 다시 누르면 돌아옵니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند التفعيل، يظهر زر في زاوية شاشتَي الدردشة والعكس المرئي في هذا الاتجاه. اضغط عليه لإخفاء الرأس وعناصر التحكم لعرض أوسع، واضغط مرة أخرى لإعادتهما."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When on, a button appears in the corner of the chat and mirroring screens in that orientation. Tap it to hide the header and controls for a wider view, and tap again to bring them back."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando está activado, aparece un botón en la esquina de las pantallas de chat y duplicación en esa orientación. Tócalo para ocultar la cabecera y los controles y ver más amplio; tócalo de nuevo para restaurarlos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une fois activé, un bouton apparaît dans le coin des écrans de discussion et de recopie dans cette orientation. Touchez-le pour masquer l'en-tête et les commandes et agrandir l'affichage ; touchez-le à nouveau pour les rétablir."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चालू होने पर, उस ओरिएंटेशन में चैट और मिररिंग स्क्रीन के कोने में एक बटन दिखता है। हेडर और नियंत्रण छिपाकर व्यापक दृश्य पाने के लिए उसे दबाएँ, और वापस लाने के लिए फिर से दबाएँ।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オンにすると、その向きでチャット・ミラーリング画面の隅にボタンが表示されます。押すとヘッダーとコントロールを隠して画面を広く表示でき、もう一度押すと戻ります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "켜면 그 방향에서 채팅·미러링 화면 구석에 버튼이 떠요. 눌러서 헤더와 컨트롤을 숨겨 화면을 넓게 보고, 다시 누르면 돌아옵니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando ativado, um botão aparece no canto das telas de chat e espelhamento nessa orientação. Toque nele para ocultar o cabeçalho e os controles e ver em tela maior; toque novamente para restaurá-los."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Когда включено, в этой ориентации в углу экранов чата и зеркалирования появляется кнопка. Нажмите её, чтобы скрыть заголовок и элементы управления для более широкого обзора, и нажмите снова, чтобы вернуть их."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启后，在该方向的聊天和镜像界面角落会出现一个按钮。点按它可隐藏标题栏和控件以更大范围查看，再次点按即可恢复。"
          }
        }
      }
    },
    "켜면 기기를 최대 %lld대까지 연결할 수 있어요. 현재 %lld대 연결됨. 끄려면 먼저 기기를 한 대만 남겨 두세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند التفعيل، يمكنك توصيل ما يصل إلى %1$lld أجهزة. متصل الآن: %2$lld. لإيقافه، اترك جهازًا واحدًا فقط أولاً."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When on, you can connect up to %1$lld devices. %2$lld connected now. To turn it off, leave only one device first."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si está activado, puedes conectar hasta %1$lld dispositivos. %2$lld conectados ahora. Para desactivarlo, deja primero solo un dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une fois activé, vous pouvez connecter jusqu'à %1$lld appareils. %2$lld connecté(s) actuellement. Pour le désactiver, ne gardez d'abord qu'un seul appareil."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चालू होने पर आप अधिकतम %1$lld डिवाइस कनेक्ट कर सकते हैं। अभी %2$lld कनेक्टेड। इसे बंद करने के लिए, पहले केवल एक डिवाइस रखें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オンにすると最大%1$lld台のデバイスを接続できます。現在%2$lld台が接続中。オフにするには、まずデバイスを1台だけ残してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "켜면 기기를 최대 %lld대까지 연결할 수 있어요. 현재 %lld대 연결됨. 끄려면 먼저 기기를 한 대만 남겨 두세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando ativado, você pode conectar até %1$lld dispositivos. %2$lld conectado(s) agora. Para desativar, deixe primeiro apenas um dispositivo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Когда включено, можно подключить до %1$lld устройств. Сейчас подключено: %2$lld. Чтобы отключить, сначала оставьте только одно устройство."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启后最多可连接 %1$lld 台设备。当前已连接 %2$lld 台。要关闭，请先只保留一台设备。"
          }
        }
      }
    },
    "켜면 번들 추론 서버 대신 내가 직접 돌리는 OpenAI 호환 로컬 서버를 OpenCode 백엔드로 씁니다. 꺼져 있으면 번들 llama.cpp 를 사용해요.": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "켜면 번들 추론 서버 대신 내가 직접 돌리는 OpenAI 호환 로컬 서버를 OpenCode 백엔드로 씁니다. 꺼져 있으면 번들 llama.cpp 를 사용해요."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When on, OpenCode uses your own OpenAI-compatible local server as its backend instead of the bundled inference server. When off, it uses the bundled llama.cpp."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando está activado, OpenCode usa tu propio servidor local compatible con OpenAI como backend en vez del servidor de inferencia incluido. Cuando está desactivado, usa el llama.cpp incluido."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activé, OpenCode utilise votre propre serveur local compatible OpenAI comme backend au lieu du serveur d’inférence intégré. Désactivé, il utilise le llama.cpp intégré."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चालू होने पर OpenCode बंडल इनफरेंस सर्वर के बजाय आपके अपने OpenAI-संगत लोकल सर्वर को बैकएंड के रूप में उपयोग करता है। बंद होने पर बंडल llama.cpp का उपयोग करता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オンにすると、OpenCode はバンドルの推論サーバーの代わりに、自分で動かす OpenAI 互換ローカルサーバーをバックエンドとして使います。オフのときはバンドルの llama.cpp を使います。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando ativado, o OpenCode usa seu próprio servidor local compatível com OpenAI como backend, em vez do servidor de inferência incluído. Quando desativado, usa o llama.cpp incluído."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Когда включено, OpenCode использует ваш собственный совместимый с OpenAI локальный сервер в качестве бэкенда вместо встроенного сервера вывода. Когда выключено — встроенный llama.cpp."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启后，OpenCode 将使用你自己运行的 OpenAI 兼容本地服务器作为后端，而非捆绑的推理服务器。关闭时使用捆绑的 llama.cpp。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند التفعيل، يستخدم OpenCode خادمك المحلي المتوافق مع OpenAI كخلفية بدلاً من خادم الاستدلال المضمّن. وعند الإيقاف، يستخدم llama.cpp المضمّن."
          }
        }
      }
    },
    "켜면 에이전트의 마지막 응답 한두 줄이 알림 본문으로 Discord에 전송됩니다. 폰을 열지 않고도 무슨 응답·질문인지 미리 볼 수 있어요. 감지된 흔한 비밀 패턴(토큰·키 등)은 자동으로 가려지지만 완벽하지 않으니, 민감한 세션에서는 꺼두세요.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند التفعيل، يتم إرسال آخر سطر أو سطرين من رد الوكيل إلى Discord في نص الإشعار. يمكنك معرفة ما قاله أو سأل عنه دون فتح هاتفك. تُحجب تلقائيًا أنماط الأسرار الشائعة المكتشفة (الرموز والمفاتيح وغيرها)، لكن ذلك ليس مثاليًا، لذا أوقف الخيار في الجلسات الحساسة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When on, the last line or two of the agent's reply is sent to Discord in the notification body. You can tell what it said or asked without opening your phone. Detected common secret patterns (tokens, keys, etc.) are masked automatically, but this isn't perfect — turn it off for sensitive sessions."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si se activa, la última línea o dos de la respuesta del agente se envían a Discord en el cuerpo de la notificación. Podrás ver qué dijo o preguntó sin abrir el teléfono. Los patrones de secretos comunes detectados (tokens, claves, etc.) se ocultan automáticamente, pero no es perfecto: desactívalo en sesiones sensibles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une fois activé, la ou les dernières lignes de la réponse de l'agent sont envoyées à Discord dans le corps de la notification. Vous voyez ce qu'il a dit ou demandé sans ouvrir le téléphone. Les motifs de secrets courants détectés (jetons, clés, etc.) sont masqués automatiquement, mais ce n'est pas parfait : désactivez-le pour les sessions sensibles."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चालू करने पर, एजेंट के जवाब की आखिरी एक या दो पंक्तियां सूचना के मुख्य भाग में Discord पर भेजी जाती हैं। फ़ोन खोले बिना ही पता चल जाता है कि उसने क्या कहा या पूछा। पहचाने गए सामान्य गोपनीय पैटर्न (टोकन, कुंजियां आदि) स्वतः छिपा दिए जाते हैं, पर यह पूर्ण नहीं है — संवेदनशील सत्रों में इसे बंद रखें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オンにすると、エージェントの最後の応答の1〜2行が通知本文としてDiscordに送信されます。スマホを開かなくても、何を返答・質問したか把握できます。検出された一般的な秘密パターン（トークンやキーなど）は自動的に伏せられますが、完全ではないため、機微なセッションではオフにしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "켜면 에이전트의 마지막 응답 한두 줄이 알림 본문으로 Discord에 전송됩니다. 폰을 열지 않고도 무슨 응답·질문인지 미리 볼 수 있어요. 감지된 흔한 비밀 패턴(토큰·키 등)은 자동으로 가려지지만 완벽하지 않으니, 민감한 세션에서는 꺼두세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando ativado, a última linha ou duas da resposta do agente é enviada ao Discord no corpo da notificação. Você consegue ver o que ele disse ou perguntou sem abrir o telefone. Padrões comuns de segredos detectados (tokens, chaves etc.) são ocultados automaticamente, mas isso não é perfeito — desative em sessões sensíveis."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Когда включено, последняя строка или две из ответа агента отправляются в Discord в тексте уведомления. Вы поймёте, что он ответил или спросил, не открывая телефон. Обнаруженные распространённые шаблоны секретов (токены, ключи и т. п.) маскируются автоматически, но это не идеально — отключайте для конфиденциальных сессий."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启后，智能体回复的最后一两行会作为通知正文发送到 Discord。无需打开手机即可了解它说了什么或问了什么。检测到的常见密钥模式（令牌、密钥等）会被自动遮蔽，但并不完美——敏感会话请关闭此选项。"
          }
        }
      }
    },
    "켜면 이 노드는 실행 직전에 멈추고, 캔버스에서 승인해야 진행해요.": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "켜면 이 노드는 실행 직전에 멈추고, 캔버스에서 승인해야 진행해요."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When on, this node pauses just before running and proceeds only after you approve it on the canvas."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启后，此节点会在运行前暂停，需在画布上批准后才继续。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オンにすると、このノードは実行直前に停止し、キャンバスで承認すると進みます。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si está activado, este nodo se detiene justo antes de ejecutarse y continúa solo cuando lo apruebas en el lienzo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activé, ce nœud s’arrête juste avant l’exécution et ne continue qu’après votre approbation sur le canevas."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند التفعيل، تتوقّف هذه العقدة قبل التشغيل مباشرةً ولا تتابع إلا بعد موافقتك على اللوحة."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando ativado, este nó pausa logo antes de executar e só continua após você aprovar no canvas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если включено, узел останавливается прямо перед запуском и продолжает только после вашего одобрения на холсте."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चालू होने पर यह नोड चलने से ठीक पहले रुकता है और कैनवास पर स्वीकृति के बाद ही आगे बढ़ता है।"
          }
        }
      }
    },
    "켜면 채팅·미러링 화면 구석에 버튼이 떠요. 눌러서 헤더와 컨트롤을 숨겨 화면을 넓게 보고, 다시 누르면 돌아옵니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند التفعيل، يظهر زر في زاوية شاشتَي الدردشة والعرض المتطابق. اضغط عليه لإخفاء الرأس وعناصر التحكم لرؤية أوسع، واضغط مجددًا لإعادتها."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When on, a button appears in the corner of the chat and mirroring screens. Tap it to hide the header and controls for a wider view, and tap again to bring them back."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando está activado, aparece un botón en la esquina de las pantallas de chat y duplicación. Tócalo para ocultar la cabecera y los controles y ver con más amplitud; tócalo de nuevo para restaurarlos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorsque cette option est activée, un bouton apparaît dans le coin des écrans de discussion et de recopie. Touchez-le pour masquer l'en-tête et les commandes afin d'agrandir la vue, puis touchez-le à nouveau pour les rétablir."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चालू होने पर, चैट और मिररिंग स्क्रीन के कोने में एक बटन दिखता है। हेडर और नियंत्रण छिपाकर व्यापक दृश्य पाने के लिए उसे टैप करें, और वापस लाने के लिए फिर से टैप करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オンにすると、チャットとミラーリング画面の隅にボタンが表示されます。タップするとヘッダーとコントロールを隠して画面を広く使え、もう一度タップすると元に戻ります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "켜면 채팅·미러링 화면 구석에 버튼이 떠요. 눌러서 헤더와 컨트롤을 숨겨 화면을 넓게 보고, 다시 누르면 돌아옵니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando ativado, um botão aparece no canto das telas de chat e espelhamento. Toque nele para ocultar o cabeçalho e os controles e ver em tela cheia; toque novamente para restaurá-los."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Когда включено, в углу экранов чата и зеркалирования появляется кнопка. Нажмите её, чтобы скрыть заголовок и элементы управления для более широкого обзора, и нажмите ещё раз, чтобы вернуть их."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启后，聊天和镜像画面的角落会出现一个按钮。点按可隐藏标题栏和控件以更大范围查看，再次点按即可恢复。"
          }
        }
      }
    },
    "켜면 채팅·미러링 화면 구석에 버튼이 떠요. 눌러서 헤더와 컨트롤을 숨겨 화면을 넓게 보고, 다시 누르면 돌아옵니다. 자동 숨김을 켜면 해당 방향에서 컨트롤이 알아서 숨겨져요(버튼으로 다시 볼 수 있어요).": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند التفعيل، يظهر زر في زاوية شاشتَي الدردشة والعرض المتطابق. اضغط عليه لإخفاء الرأس وعناصر التحكم لرؤية أوسع، واضغط مجددًا لإعادتها. عند تفعيل الإخفاء التلقائي، تختفي عناصر التحكم تلقائيًا في ذلك الاتجاه (يمكنك إظهارها مجددًا بالزر)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When on, a button appears in the corner of the chat and mirroring screens. Tap it to hide the header and controls for a wider view, and tap again to bring them back. With auto-hide on, the controls hide themselves in that orientation (you can bring them back with the button)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando está activado, aparece un botón en la esquina de las pantallas de chat y duplicación. Tócalo para ocultar la cabecera y los controles y ver con más amplitud; tócalo de nuevo para restaurarlos. Con el ocultamiento automático activado, los controles se ocultan solos en esa orientación (puedes mostrarlos de nuevo con el botón)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorsque cette option est activée, un bouton apparaît dans le coin des écrans de discussion et de recopie. Touchez-le pour masquer l'en-tête et les commandes afin d'agrandir la vue, puis touchez-le à nouveau pour les rétablir. Avec le masquage automatique activé, les commandes se masquent d'elles-mêmes dans cette orientation (vous pouvez les rétablir avec le bouton)."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चालू होने पर, चैट और मिररिंग स्क्रीन के कोने में एक बटन दिखता है। हेडर और नियंत्रण छिपाकर व्यापक दृश्य पाने के लिए उसे टैप करें, और वापस लाने के लिए फिर से टैप करें। स्वतः छिपाना चालू होने पर, उस ओरिएंटेशन में नियंत्रण अपने आप छिप जाते हैं (आप उन्हें बटन से फिर ला सकते हैं)।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オンにすると、チャットとミラーリング画面の隅にボタンが表示されます。タップするとヘッダーとコントロールを隠して画面を広く使え、もう一度タップすると元に戻ります。自動的に隠すをオンにすると、その向きでコントロールが自動的に隠れます（ボタンで再表示できます）。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "켜면 채팅·미러링 화면 구석에 버튼이 떠요. 눌러서 헤더와 컨트롤을 숨겨 화면을 넓게 보고, 다시 누르면 돌아옵니다. 자동 숨김을 켜면 해당 방향에서 컨트롤이 알아서 숨겨져요(버튼으로 다시 볼 수 있어요)."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando ativado, um botão aparece no canto das telas de chat e espelhamento. Toque nele para ocultar o cabeçalho e os controles e ver em tela cheia; toque novamente para restaurá-los. Com a ocultação automática ativada, os controles se ocultam sozinhos nessa orientação (você pode mostrá-los novamente com o botão)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Когда включено, в углу экранов чата и зеркалирования появляется кнопка. Нажмите её, чтобы скрыть заголовок и элементы управления для более широкого обзора, и нажмите ещё раз, чтобы вернуть их. При включённом автоскрытии элементы управления скрываются сами в этой ориентации (их можно вернуть кнопкой)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启后，聊天和镜像画面的角落会出现一个按钮。点按可隐藏标题栏和控件以更大范围查看，再次点按即可恢复。开启自动隐藏后，在该方向下控件会自动隐藏（可用按钮重新显示）。"
          }
        }
      }
    },
    "켜면 평문 Tor 연결이 막혔을 때 아래 bridge 를 거쳐 자동으로 다시 시도해요. 평문 Tor 가 잘 되는 환경에선 bridge 를 쓰지 않습니다(평문 우선).": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند التفعيل، إذا تم حظر اتصال Tor العادي، تتم إعادة المحاولة تلقائيًا عبر الجسور أدناه. وحيث يعمل Tor العادي جيدًا، لا تُستخدم الجسور (Tor العادي أولًا)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When on, if a plain Tor connection is blocked, it automatically retries through the bridges below. Where plain Tor works fine, bridges aren't used (plain Tor first)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando está activado, si se bloquea una conexión Tor normal, vuelve a intentarlo automáticamente a través de los puentes de abajo. Donde Tor normal funciona bien, no se usan puentes (primero Tor normal)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activé, si une connexion Tor standard est bloquée, l'app réessaie automatiquement via les ponts ci-dessous. Là où Tor standard fonctionne, les ponts ne sont pas utilisés (Tor standard d'abord)."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चालू होने पर, यदि सामान्य Tor कनेक्शन अवरुद्ध हो, तो यह नीचे दिए गए bridge के ज़रिए स्वतः पुनः प्रयास करता है। जहाँ सामान्य Tor काम करता है वहाँ bridge का उपयोग नहीं होता (पहले सामान्य Tor)।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オンにすると、通常の Tor 接続が遮断されたときに下の bridge を経由して自動で再試行します。通常の Tor が使える環境では bridge を使いません(通常 Tor 優先)。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "켜면 평문 Tor 연결이 막혔을 때 아래 bridge 를 거쳐 자동으로 다시 시도해요. 평문 Tor 가 잘 되는 환경에선 bridge 를 쓰지 않습니다(평문 우선)."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando ativado, se uma conexão Tor comum for bloqueada, ele tenta novamente automaticamente pelas pontes abaixo. Onde o Tor comum funciona, as pontes não são usadas (Tor comum primeiro)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Когда включено, при блокировке обычного подключения Tor приложение автоматически повторяет попытку через мосты ниже. Там, где обычный Tor работает, мосты не используются (сначала обычный Tor)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启后,如果普通 Tor 连接被屏蔽,将自动通过下面的 bridge 重试。在普通 Tor 正常的网络中不会使用 bridge(优先普通 Tor)。"
          }
        }
      }
    },
    "켜면 한 손가락 드래그가 바로 «누른 채 끌기» — 텍스트 선택·창 이동, 커서 링이 보라로 바뀌어요": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند التفعيل، يبدأ السحب بإصبع واحد بالإمساك فورًا — لتحديد النص أو تحريك النوافذ، وتتحول حلقة المؤشر إلى اللون الأرجواني"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When on, a one-finger drag holds right away — select text or move windows; the cursor ring turns purple"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando está activado, arrastrar con un dedo sujeta de inmediato: seleccionar texto o mover ventanas; el anillo del cursor se vuelve morado"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activé, un glissement à un doigt maintient aussitôt le bouton — sélectionner du texte ou déplacer des fenêtres ; l’anneau du curseur devient violet"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चालू होने पर, एक उंगली से खींचना तुरंत «दबाकर खींचना» शुरू कर देता है — टेक्स्ट चुनें या विंडो मूव करें, कर्सर रिंग बैंगनी हो जाती है"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オンにすると、1本指のドラッグがそのまま「押したまま移動」に — テキスト選択やウインドウ移動、カーソルリングが紫に変わります"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "켜면 한 손가락 드래그가 바로 «누른 채 끌기» — 텍스트 선택·창 이동, 커서 링이 보라로 바뀌어요"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando ativado, arrastar com um dedo já segura o botão na hora — selecionar texto ou mover janelas; o anel do cursor fica roxo"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Когда включено, перетаскивание одним пальцем сразу удерживает кнопку — выделение текста или перемещение окон; кольцо курсора становится фиолетовым"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启后，单指拖动即可直接「按住拖动」——选择文本或移动窗口，光标环会变成紫色"
          }
        }
      }
    },
    "켜면 한 손가락 드래그로 스크롤해요 — 두 손가락 스크롤이 어려울 때": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند التشغيل، اسحب بإصبع واحد للتمرير — عندما يصعب التمرير بإصبعين"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When on, one-finger drag scrolls — for when two-finger scrolling is hard"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Al activarlo, arrastra con un dedo para desplazar — cuando con dos dedos cuesta"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une fois activé, glissez à un doigt pour faire défiler — quand deux doigts sont difficiles"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चालू होने पर एक उँगली से ड्रैग करके स्क्रॉल करें — जब दो उँगलियों से मुश्किल हो"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オンにすると1本指のドラッグでスクロール — 2本指スクロールが難しいときに"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "켜면 한 손가락 드래그로 스크롤해요 — 두 손가락 스크롤이 어려울 때"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando ativado, arraste com um dedo para rolar — quando rolar com dois dedos é difícil"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Когда включено, прокрутка одним пальцем — если двумя пальцами сложно"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启后单指拖动即可滚动 — 双指滚动不便时使用"
          }
        }
      }
    },
    "켜져 있어요. bash / Write / Edit 같은 파일·셸 도구가 매번 묻지 않고 곧바로 실행됩니다. 신뢰하는 레포에서만 사용하세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مُفعَّل. أدوات الملفات/الصدفة مثل bash / Write / Edit تُنفَّذ مباشرة دون سؤال. استخدمه فقط في مستودعات تثق بها."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "On. File/shell tools like bash / Write / Edit run immediately without prompting. Use only in repos you trust."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activado. Herramientas de archivo/shell como bash / Write / Edit se ejecutan al instante sin preguntar. Úsalo solo en repos de confianza."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activé. Les outils fichier/shell comme bash / Write / Edit s’exécutent immédiatement sans demande. À utiliser uniquement sur des dépôts de confiance."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चालू। bash / Write / Edit जैसे फ़ाइल/शेल टूल हर बार पूछे बिना तुरंत चलते हैं। केवल भरोसेमंद रेपो में उपयोग करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オン。bash / Write / Edit などのファイル・シェルツールが毎回確認なしで即座に実行されます。信頼できるリポでのみ使用してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "켜져 있어요. bash / Write / Edit 같은 파일·셸 도구가 매번 묻지 않고 곧바로 실행됩니다. 신뢰하는 레포에서만 사용하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ativado. Ferramentas de arquivo/shell como bash / Write / Edit executam sem perguntar. Use apenas em repos confiáveis."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Включено. Инструменты вроде bash / Write / Edit запускаются без подтверждений. Используйте только в доверенных репозиториях."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已开启。bash / Write / Edit 等文件/Shell 工具不再每次询问，会立即执行。仅在你信任的仓库中使用。"
          }
        }
      }
    },
