          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Antes de o agente gravar um arquivo ou rodar um comando, ele pergunta uma vez."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Прежде чем записать файл или выполнить команду, агент однажды спрашивает вас."
