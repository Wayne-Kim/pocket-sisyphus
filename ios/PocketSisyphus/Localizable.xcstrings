      }
    },
    "어떤 외부 서비스에도 의존하지 않고, 데이터가 어떻게 흐르는지.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بدون الاعتماد على أي خدمة خارجية، وكيف تتدفّق البيانات."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "How data flows — without relying on any external service."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sin depender de ningún servicio externo, así fluyen los datos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sans dépendance à un service externe — voici comment circulent les données."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बिना किसी बाहरी सेवा पर निर्भर हुए, डेटा कैसे प्रवाहित होता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "外部サービスに依存せず、データがどのように流れるか。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "어떤 외부 서비스에도 의존하지 않고, 데이터가 어떻게 흐르는지."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sem depender de nenhum serviço externo, como os dados fluem."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Без зависимости от внешних сервисов — как движутся данные."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在不依赖任何外部服务的前提下,数据如何流转。"
          }
        }
      }
    },
    "어떤 제안이 자주 거절되는지 보여줘요 — 다음 수집의 방향에 참고하세요.": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "어떤 제안이 자주 거절되는지 보여줘요 — 다음 수집의 방향에 참고하세요."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shows which proposals get rejected most — use it to steer the next collection."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "どの提案がよく却下されるかを示します — 次の収集の方向の参考にしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "显示哪类提案最常被拒绝 — 可作为下次收集方向的参考。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Muestra qué propuestas se rechazan más, para orientar la próxima recopilación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Montre quelles propositions sont les plus rejetées — pour orienter la prochaine collecte."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mostra quais propostas são mais rejeitadas — use para guiar a próxima coleta."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Показывает, какие предложения отклоняют чаще — ориентир для следующего сбора."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يوضّح أي المقترحات تُرفض أكثر — استعن به لتوجيه الجمع التالي."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "दिखाता है कौन-से प्रस्ताव सबसे अधिक अस्वीकृत होते हैं — अगले संग्रह की दिशा तय करने में मदद के लिए।"
          }
        }
      }
    },
