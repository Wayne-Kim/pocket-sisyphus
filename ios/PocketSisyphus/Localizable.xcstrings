          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo revocar: %@"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec de la révocation : %@"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हटाने में विफल: %@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "解除に失敗しました: %@"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
