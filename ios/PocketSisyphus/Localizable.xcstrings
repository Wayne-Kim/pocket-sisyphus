    "스마트폰 화면 폭에 맞춰 컬럼 수가 자동으로 맞춰집니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتم ضبط عدد الأعمدة تلقائيًا ليلائم عرض شاشة الهاتف."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The column count adjusts automatically to fit the phone's screen width."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El número de columnas se ajusta automáticamente al ancho de la pantalla del teléfono."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le nombre de colonnes s'ajuste automatiquement à la largeur de l'écran du téléphone."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कॉलम की संख्या फ़ोन की स्क्रीन चौड़ाई के अनुसार स्वतः समायोजित होती है."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "列数はスマートフォンの画面幅に合わせて自動調整されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "스마트폰 화면 폭에 맞춰 컬럼 수가 자동으로 맞춰집니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O número de colunas se ajusta automaticamente à largura da tela do telefone."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Число столбцов автоматически подстраивается под ширину экрана телефона."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "列数会根据手机屏幕宽度自动调整。"
          }
        }
      }
    },
