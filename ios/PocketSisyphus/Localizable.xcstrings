    "워크플로우는 프로(고급) 기능이라 주황으로 표시됩니다. 곧 유료로 전환될 예정이에요 — 자세한 건 «프로 기능» 안내를 보세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سير العمل ميزة احترافية (متقدّمة)، لذا يظهر باللون البرتقالي. سيتحوّل قريبًا إلى ميزة مدفوعة — راجع دليل «ميزات Pro» للتفاصيل."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Workflow is a Pro (advanced) feature, so it's shown in orange. It will soon become paid — see the «Pro features» guide for details."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El flujo de trabajo es una función Pro (avanzada), por eso aparece en naranja. Pronto pasará a ser de pago: consulta la guía «Funciones Pro» para más detalles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le flux de travail est une fonctionnalité Pro (avancée), donc affichée en orange. Elle deviendra bientôt payante — voir le guide « Fonctionnalités Pro » pour en savoir plus."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वर्कफ़्लो एक प्रो (उन्नत) सुविधा है, इसलिए यह नारंगी रंग में दिखती है। यह जल्द ही सशुल्क हो जाएगी — विवरण के लिए «प्रो सुविधाएँ» गाइड देखें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ワークフローはプロ(高度な)機能のためオレンジで表示されます。まもなく有料に切り替わる予定です — 詳しくは«プロ機能»の案内をご覧ください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "워크플로우는 프로(고급) 기능이라 주황으로 표시됩니다. 곧 유료로 전환될 예정이에요 — 자세한 건 «프로 기능» 안내를 보세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O fluxo de trabalho é um recurso Pro (avançado), por isso aparece em laranja. Em breve se tornará pago — veja o guia «Recursos Pro» para detalhes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Рабочий процесс — это функция Pro (расширенная), поэтому отображается оранжевым. Скоро она станет платной — подробности см. в разделе «Pro-функции»."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "工作流是专业版（高级）功能，因此以橙色显示。它即将转为付费——详情请参阅«专业版功能»说明。"
          }
        }
      }
    },
    "워크플로우는 프로(고급) 기능이에요. 멤버십이나 영구 이용권으로 잠금 해제하고, 처음이라면 무료 체험으로 써 볼 수 있어요 — 자세한 건 «프로 기능» 안내를 보세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تدفقات العمل ميزة Pro (متقدمة). افتحها عبر اشتراك أو ترخيص مدى الحياة، أو جرّبها أولًا بنسخة تجريبية مجانية — راجع دليل «ميزات Pro»."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Workflows are a Pro (advanced) feature. Unlock with a membership or lifetime license, or try it first with a free trial — see the «Pro features» guide."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los flujos de trabajo son una función Pro (avanzada). Desbloquéala con una membresía o licencia vitalicia, o pruébala primero con una prueba gratuita — consulta la guía «Funciones Pro»."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les workflows sont une fonctionnalité Pro (avancée). Débloquez-la avec un abonnement ou une licence à vie, ou essayez-la d’abord avec un essai gratuit — voir le guide « Fonctionnalités Pro »."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वर्कफ़्लो एक प्रो (एडवांस्ड) फ़ीचर है। मेंबरशिप या लाइफटाइम लाइसेंस से अनलॉक करें, या पहले मुफ़्त ट्रायल से आज़माएँ — विवरण के लिए «प्रो फ़ीचर्स» गाइड देखें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ワークフローはプロ（高度な）機能です。メンバーシップまたは買い切りライセンスでロック解除でき、初めてなら無料トライアルで試せます — 詳しくは «プロ機能» のガイドをご覧ください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "워크플로우는 프로(고급) 기능이에요. 멤버십이나 영구 이용권으로 잠금 해제하고, 처음이라면 무료 체험으로 써 볼 수 있어요 — 자세한 건 «프로 기능» 안내를 보세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os fluxos de trabalho são um recurso Pro (avançado). Desbloqueie com uma assinatura ou licença vitalícia, ou experimente primeiro com um teste gratuito — veja o guia «Recursos Pro»."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Рабочие процессы — это Pro-функция (расширенная). Разблокируйте подпиской или бессрочной лицензией либо сначала попробуйте бесплатно — см. раздел «Pro-функции»."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "工作流是专业（高级）功能。可通过会员或永久许可解锁，初次也可先用免费试用体验 — 详见«专业功能»说明。"
          }
        }
      }
    },
    "워크플로우로 구현 (자가검증 + 머지 승인)": {
      "extractionState": "manual",
      "localizations": {
