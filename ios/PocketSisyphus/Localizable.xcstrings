    "페어링·세션·연결·보안까지 모든 사용 안내를 한곳에서 볼 수 있어요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الإقران والجلسات والاتصال والأمان — كل أدلة الاستخدام في مكان واحد."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pairing, sessions, connection, security — every guide in one place."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Emparejamiento, sesiones, conexión y seguridad: todas las guías en un solo lugar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appairage, sessions, connexion, sécurité — tous les guides au même endroit."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पेयरिंग, सेशन, कनेक्शन और सुरक्षा — सभी गाइड एक ही जगह पर।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ペアリング・セッション・接続・セキュリティまで、すべての使い方を一か所で確認できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "페어링·세션·연결·보안까지 모든 사용 안내를 한곳에서 볼 수 있어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Emparelhamento, sessões, conexão e segurança — todos os guias em um só lugar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сопряжение, сессии, подключение, безопасность — все руководства в одном месте."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "配对、会话、连接、安全——所有使用指南都在一处。"
          }
        }
      }
    },
    "페어링은 Mac 메뉴바의 «페어링 QR 보기» 를 누른 뒤 iPhone 앱의 QR 스캐너로 한 번 비추면 끝납니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "للإقران اضغط «عرض رمز QR للإقران» من شريط قوائم Mac ثم وجّه ماسح QR في تطبيق iPhone نحوه مرة واحدة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "To pair, hit “Show pairing QR” in the Mac menu bar, then point the iPhone app’s QR scanner at it once."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Para emparejar, pulsa «Mostrar QR de emparejamiento» en la barra de menús del Mac y apunta una vez al QR con el escáner del iPhone."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pour appairer, cliquez sur « Afficher le QR d’appairage » dans la barre de menus du Mac, puis pointez le scanner QR de l’app iPhone dessus une fois."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पेयरिंग के लिए Mac मेनू बार में «पेयरिंग QR दिखाएँ» दबाएँ और iPhone ऐप के QR स्कैनर से एक बार उसकी ओर इंगित करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ペアリングするには Mac メニューバーの「ペアリング QR を表示」を押し、iPhone アプリの QR スキャナでそれを一度読み取ります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "페어링은 Mac 메뉴바의 «페어링 QR 보기» 를 누른 뒤 iPhone 앱의 QR 스캐너로 한 번 비추면 끝납니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Para parear, clique em «Mostrar QR de pareamento» na barra de menus do Mac e aponte o scanner QR do app iPhone para ele uma vez."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Чтобы сопрячь, нажмите «Показать QR сопряжения» в строке меню Mac, затем один раз наведите на него QR-сканер в приложении iPhone."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "配对方法:点击 Mac 菜单栏的「显示配对 QR」,然后用 iPhone 应用的 QR 扫描器对准一次即可。"
          }
        }
      }
    },
