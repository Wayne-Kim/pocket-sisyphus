    "우상단 + 로 예약을 만들면, Mac 이 정해진 시각에 에이전트를 실행해요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اضغط + في الأعلى يمينًا لإنشاء جدولة؛ وسيشغّل Mac الوكيل في الوقت المحدد."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap + at the top right to create a schedule; the Mac runs the agent at the set time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca + arriba a la derecha para crear una programación; el Mac ejecuta el agente a la hora fijada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Touchez + en haut à droite pour créer une planification ; le Mac exécute l’agent à l’heure définie."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ऊपर दाईं ओर + दबाकर अनुसूची बनाएँ; तय समय पर Mac एजेंट चलाएगा।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "右上の + で予約を作成すると、決まった時刻に Mac がエージェントを実行します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "우상단 + 로 예약을 만들면, Mac 이 정해진 시각에 에이전트를 실행해요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Toque em + no canto superior direito para criar um agendamento; o Mac executa o agente no horário definido."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нажмите + вверху справа, чтобы создать расписание; Mac запустит агента в заданное время."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点按右上角 + 创建预约，Mac 会在设定时间运行智能体。"
          }
        }
      }
    },
    "우상단 + 로 워크플로우를 만들면, 여러 에이전트가 순서대로 작업해요.": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "우상단 + 로 워크플로우를 만들면, 여러 에이전트가 순서대로 작업해요."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Create a workflow with + at the top right, and multiple agents work in sequence."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用右上角的 + 创建工作流，多个代理会按顺序工作。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "右上の + でワークフローを作成すると、複数のエージェントが順番に作業します。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Crea un flujo de trabajo con el + de la parte superior derecha y varios agentes trabajarán en orden."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Créez un flux de travail avec le + en haut à droite, et plusieurs agents travaillent dans l’ordre."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أنشئ سير عمل عبر + في الأعلى يمينًا، وستعمل عدة وكلاء بالترتيب."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Crie um fluxo de trabalho com o + no canto superior direito e vários agentes trabalham em sequência."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Создайте рабочий процесс кнопкой + вверху справа — и несколько агентов будут работать по очереди."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ऊपर दाईं ओर + से वर्कफ़्लो बनाएँ, और कई एजेंट क्रम से काम करते हैं।"
          }
        }
      }
    },
    "우상단 + 로 워크플로우를 만들면, 캔버스에서 노드를 그리고 선으로 이어요.": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "우상단 + 로 워크플로우를 만들면, 캔버스에서 노드를 그리고 선으로 이어요."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Create a workflow with + at the top right, then draw nodes and connect them with lines on the canvas."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用右上角的 + 创建工作流，然后在画布上绘制节点并用连线连接它们。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "右上の + でワークフローを作成し、キャンバスでノードを描いて線でつなぎます。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Crea un flujo de trabajo con el + de arriba a la derecha y luego dibuja nodos y conéctalos con líneas en el lienzo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Créez un flux de travail avec le + en haut à droite, puis dessinez des nœuds et reliez-les par des lignes sur le canevas."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أنشئ سير عمل عبر + في الأعلى يمينًا، ثم ارسم العقد وصِلها بخطوط على اللوحة."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Crie um fluxo de trabalho com o + no canto superior direito e depois desenhe nós e conecte-os com linhas no canvas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Создайте рабочий процесс кнопкой + вверху справа, затем рисуйте узлы и соединяйте их линиями на холсте."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ऊपर दाईं ओर + से वर्कफ़्लो बनाएँ, फिर कैनवास पर नोड बनाएँ और उन्हें लाइनों से जोड़ें।"
          }
        }
      }
    },
