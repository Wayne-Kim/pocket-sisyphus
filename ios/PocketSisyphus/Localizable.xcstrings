    "구독으로 모든 기능을 계속 사용하세요. 언제든 해지할 수 있어요.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اشترك لمواصلة استخدام جميع الميزات. يمكنك الإلغاء في أي وقت."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Subscribe to keep using all features. Cancel anytime."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Suscríbete para seguir usando todas las funciones. Cancela cuando quieras."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Abonnez-vous pour continuer à utiliser toutes les fonctionnalités. Annulez à tout moment."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सभी सुविधाओं का उपयोग जारी रखने के लिए सदस्यता लें। कभी भी रद्द करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サブスクリプションですべての機能を使い続けられます。いつでも解約できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "구독으로 모든 기능을 계속 사용하세요. 언제든 해지할 수 있어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Assine para continuar usando todos os recursos. Cancele quando quiser."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Оформите подписку, чтобы продолжать пользоваться всеми функциями. Отмена в любой момент."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "订阅以继续使用所有功能。随时可取消。"
          }
        }
      }
    },
