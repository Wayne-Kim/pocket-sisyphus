    "알 수 없는 이유로 연결에 실패했어요. 잠시 뒤 다시 시도해 주세요.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فشل الاتصال لسبب غير معروف. يُرجى إعادة المحاولة بعد قليل."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The connection failed for an unknown reason. Please try again in a moment."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La conexión falló por un motivo desconocido. Inténtalo de nuevo en un momento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La connexion a échoué pour une raison inconnue. Veuillez réessayer dans un instant."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "किसी अज्ञात कारण से कनेक्शन विफल रहा। कृपया थोड़ी देर बाद फिर कोशिश करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "不明な理由で接続に失敗しました。しばらくしてから再試行してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "알 수 없는 이유로 연결에 실패했어요. 잠시 뒤 다시 시도해 주세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A conexão falhou por um motivo desconhecido. Tente novamente em instantes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подключение не удалось по неизвестной причине. Повторите попытку через мгновение."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "因未知原因连接失败。请稍后重试。"
          }
        }
      }
    },
