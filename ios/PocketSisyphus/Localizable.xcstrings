    "상품이 아직 로드되지 않았습니다. 잠시 후 다시 시도해 주세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يتم تحميل المنتج بعد. يُرجى المحاولة مرّة أخرى بعد قليل."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Product hasn’t loaded yet. Please try again in a moment."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El producto aún no se ha cargado. Inténtalo de nuevo en un momento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le produit n’est pas encore chargé. Réessayez dans un instant."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "उत्पाद अभी लोड नहीं हुआ है। कृपया कुछ देर बाद पुनः प्रयास करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "商品がまだ読み込まれていません。少し経ってからもう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "상품이 아직 로드되지 않았습니다. 잠시 후 다시 시도해 주세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O produto ainda não foi carregado. Tente novamente em instantes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Продукт ещё не загружен. Повторите попытку чуть позже."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "商品尚未加载。请稍后重试。"
          }
