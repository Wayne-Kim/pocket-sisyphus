          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "напр.: Каждый день проверяй PR и оставляй сводку"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "उदा.: हर दिन PR की समीक्षा करें और सारांश छोड़ें"
          }
        }
      }
    },
    "예: 변경 요약과 파일 목록을 표로 정리해 담아라": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مثال: لخّص التغييرات واذكر الملفات في جدول"
          }
        },
        "en": {
