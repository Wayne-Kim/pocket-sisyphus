    "파일이 너무 크거나 (5MB 초과) 권한이 없을 수 있다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قد يكون الملف كبيرًا جدًا (أكبر من 5 ميغابايت) أو ليست لديك صلاحيات الوصول."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The file may be too large (over 5 MB) or you may lack permission."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El archivo puede ser demasiado grande (más de 5 MB) o no tienes permisos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le fichier est peut-être trop volumineux (plus de 5 Mo) ou vous n’avez pas les autorisations."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फ़ाइल बहुत बड़ी (5MB से अधिक) हो सकती है या आपके पास अनुमति नहीं हो सकती है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ファイルが大きすぎる(5MB 超)か、権限がない可能性があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "파일이 너무 크거나 (5MB 초과) 권한이 없을 수 있다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O arquivo pode ser muito grande (mais de 5 MB) ou você pode não ter permissão."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Файл может быть слишком большим (более 5 МБ) или у вас нет прав доступа."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "文件可能过大(超过 5MB)或您没有访问权限。"
          }
        }
      }
    },
