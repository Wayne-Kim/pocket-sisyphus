    "작업 노드(분홍) — 에이전트가 프롬프트를 수행하는 단계. 도구와 승인 여부를 노드마다 정합니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عقدة المهمة (وردية) — الخطوة التي ينفّذ فيها الوكيل الموجّه. حدّد الأداة وخيار الموافقة لكل عقدة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Task node (pink) — the step where the agent carries out the prompt. Set the tool and approval option per node."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Nodo de tarea (rosa): el paso donde el agente ejecuta el prompt. Define la herramienta y la opción de aprobación en cada nodo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nœud Tâche (rose) — l'étape où l'agent exécute le prompt. Définissez l'outil et l'option d'approbation pour chaque nœud."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कार्य नोड (गुलाबी) — वह चरण जहाँ एजेंट प्रॉम्प्ट को पूरा करता है। प्रत्येक नोड के लिए टूल और अनुमोदन विकल्प तय करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "作業ノード(ピンク) — エージェントがプロンプトを実行する段階。ツールと承認の有無をノードごとに設定します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "작업 노드(분홍) — 에이전트가 프롬프트를 수행하는 단계. 도구와 승인 여부를 노드마다 정합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Nó de tarefa (rosa) — a etapa em que o agente executa o prompt. Defina a ferramenta e a opção de aprovação em cada nó."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Узел задачи (розовый) — этап, на котором агент выполняет запрос. Инструмент и необходимость подтверждения задаются для каждого узла."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "任务节点（粉色）——智能体执行提示词的步骤。可为每个节点设置工具和是否需要审批。"
          }
        }
      }
    },
    "작업 중인 파일은 그대로 두고 브랜치만 바꿔요.": {
      "extractionState": "manual",
