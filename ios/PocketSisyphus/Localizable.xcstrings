    "폰에서 Mac 에 어떻게 연결할지 골라 주세요. 나중에 설정에서 바꿀 수 있어요.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose how your phone connects to your Mac. You can change this later in Settings."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر كيف يتصل هاتفك بجهاز Mac. يمكنك تغيير ذلك لاحقًا من الإعدادات."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige cómo se conecta tu teléfono a tu Mac. Puedes cambiarlo más tarde en Ajustes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez comment votre téléphone se connecte à votre Mac. Vous pourrez le modifier plus tard dans les Réglages."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चुनें कि आपका फ़ोन आपके Mac से कैसे कनेक्ट हो. आप इसे बाद में सेटिंग में बदल सकते हैं."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スマホから Mac への接続方法を選んでください。あとで設定で変更できます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha como o seu telefone se conecta ao seu Mac. Você pode mudar isso depois nos Ajustes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите, как телефон подключается к Mac. Это можно изменить позже в Настройках."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择手机如何连接到 Mac。稍后可在设置中更改。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "폰에서 Mac 에 어떻게 연결할지 골라 주세요. 나중에 설정에서 바꿀 수 있어요."
          }
        }
      }
    },
    "어디서나 연결": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Connect from anywhere"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الاتصال من أي مكان"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Conectar desde cualquier lugar"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Se connecter de partout"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कहीं से भी कनेक्ट करें"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "どこからでも接続"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Conectar de qualquer lugar"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подключаться откуда угодно"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "随时随地连接"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "어디서나 연결"
          }
        }
      }
    },
    "Tor 를 통해 어느 네트워크에서나 연결해요. 조금 느릴 수 있어요.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Connect from any network through Tor. It may be a little slower."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اتصل من أي شبكة عبر Tor. قد يكون أبطأ قليلًا."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Conéctate desde cualquier red a través de Tor. Puede ser un poco más lento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Connectez-vous depuis n'importe quel réseau via Tor. Cela peut être un peu plus lent."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor के ज़रिए किसी भी नेटवर्क से कनेक्ट करें. यह थोड़ा धीमा हो सकता है."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor を通じてどのネットワークからでも接続します。少し遅くなることがあります。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Conecte-se de qualquer rede pelo Tor. Pode ser um pouco mais lento."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подключайтесь из любой сети через Tor. Может быть немного медленнее."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通过 Tor 从任何网络连接。可能会稍慢一些。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Tor 를 통해 어느 네트워크에서나 연결해요. 조금 느릴 수 있어요."
          }
        }
      }
    },
    "같은 Wi‑Fi 전용": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Same Wi‑Fi only"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "شبكة Wi‑Fi نفسها فقط"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo la misma Wi‑Fi"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Même Wi‑Fi uniquement"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "केवल वही Wi‑Fi"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "同じ Wi‑Fi のみ"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Somente o mesmo Wi‑Fi"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Только та же сеть Wi‑Fi"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅同一 Wi‑Fi"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "같은 Wi‑Fi 전용"
          }
        }
      }
    },
    "폰과 Mac 이 같은 Wi‑Fi 에 있을 때만 사설 주소로 직접 연결해요. 더 빠르지만 외부 네트워크에선 연결이 차단돼요.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Connect directly via a private address only when your phone and Mac are on the same Wi‑Fi. Faster, but connections are blocked on outside networks."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اتصل مباشرةً عبر عنوان خاص فقط عندما يكون هاتفك وجهاز Mac على شبكة Wi‑Fi نفسها. أسرع، لكن يتم حظر الاتصالات على الشبكات الخارجية."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Conéctate directamente mediante una dirección privada solo cuando tu teléfono y tu Mac estén en la misma Wi‑Fi. Más rápido, pero las conexiones se bloquean en redes externas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Connectez-vous directement via une adresse privée uniquement lorsque votre téléphone et votre Mac sont sur le même Wi‑Fi. Plus rapide, mais les connexions sont bloquées sur les réseaux externes."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपने फ़ोन और Mac के एक ही Wi‑Fi पर होने पर ही निजी पते से सीधे कनेक्ट करें. तेज़, लेकिन बाहरी नेटवर्क पर कनेक्शन ब्लॉक रहते हैं."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スマホと Mac が同じ Wi‑Fi にあるときだけ、プライベートアドレスで直接接続します。高速ですが、外部ネットワークでは接続がブロックされます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Conecte-se diretamente por um endereço privado apenas quando o seu telefone e o seu Mac estiverem no mesmo Wi‑Fi. Mais rápido, mas as conexões são bloqueadas em redes externas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подключаться напрямую по частному адресу только когда телефон и Mac в одной сети Wi‑Fi. Быстрее, но во внешних сетях подключение блокируется."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅当手机与 Mac 处于同一 Wi‑Fi 时，通过私有地址直接连接。更快，但在外部网络中连接会被阻止。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "폰과 Mac 이 같은 Wi‑Fi 에 있을 때만 사설 주소로 직접 연결해요. 더 빠르지만 외부 네트워크에선 연결이 차단돼요."
          }
        }
      }
    },
    "이 세션을 삭제할까요?": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هل تريد حذف هذه الجلسة؟"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Delete this session?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Eliminar esta sesión?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprimer cette session ?"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस सत्र को हटाएँ?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このセッションを削除しますか？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 세션을 삭제할까요?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Excluir esta sessão?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удалить эту сессию?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "删除此会话？"
          }
        }
      }
    },
    "이 세션과 대화 기록이 영구히 삭제되고 세션 목록에서도 사라집니다. 되돌릴 수 없어요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيتم حذف هذه الجلسة وسجل المحادثة نهائيًا وستختفي من قائمة الجلسات. لا يمكن التراجع عن ذلك."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This session and its conversation history will be permanently deleted and removed from the session list. This can't be undone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta sesión y su historial de conversación se eliminarán permanentemente y desaparecerán de la lista de sesiones. No se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette session et son historique de conversation seront définitivement supprimés et disparaîtront de la liste des sessions. Cette action est irréversible."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह सत्र और इसका वार्तालाप इतिहास स्थायी रूप से हटा दिया जाएगा और सत्र सूची से भी गायब हो जाएगा। इसे पूर्ववत नहीं किया जा सकता।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このセッションと会話履歴は完全に削除され、セッション一覧からも消えます。元に戻せません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 세션과 대화 기록이 영구히 삭제되고 세션 목록에서도 사라집니다. 되돌릴 수 없어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta sessão e seu histórico de conversa serão excluídos permanentemente e desaparecerão da lista de sessões. Isso não pode ser desfeito."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Эта сессия и её история переписки будут безвозвратно удалены и исчезнут из списка сессий. Это нельзя отменить."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此会话及其对话记录将被永久删除，并从会话列表中消失。此操作无法撤销。"
          }
        }
      }
    },
    "실행 중 세션 %lld건. 탭하면 실행 중 세션만 봅니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld جلسة قيد التشغيل. اضغط لعرض الجلسات قيد التشغيل فقط."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld sessions running. Tap to show only running sessions."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld sesiones en ejecución. Toca para mostrar solo las sesiones en ejecución."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld sessions en cours. Touchez pour n’afficher que les sessions en cours."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld सत्र चल रहे हैं। केवल चल रहे सत्र दिखाने के लिए टैप करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "実行中のセッション%lld件。タップすると実行中のセッションのみ表示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "실행 중 세션 %lld건. 탭하면 실행 중 세션만 봅니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld sessões em execução. Toque para mostrar apenas as sessões em execução."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld сессий выполняется. Нажмите, чтобы показать только выполняющиеся сессии."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 个会话运行中。点按仅显示运行中的会话。"
          }
        }
      }
    },
    "완료 세션 %lld건. 탭하면 완료 세션만 봅니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
