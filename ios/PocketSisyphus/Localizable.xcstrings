    "이번 수집에만 적용돼요. 조사 방식보다 우선해요.": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이번 수집에만 적용돼요. 조사 방식보다 우선해요."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Applies to this collection only. Takes priority over the research method."
          }
        },
        "ja": {
