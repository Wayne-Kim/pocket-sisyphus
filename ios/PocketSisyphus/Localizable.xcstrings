    "정해진 시각에 쉘 스크립트 파일을 실행해요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يشغّل ملف سكربت Shell في الوقت المحدد."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Runs a shell script file at the scheduled time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ejecuta un archivo de script de shell a la hora programada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Exécute un fichier de script shell à l’heure planifiée."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "निर्धारित समय पर एक शेल स्क्रिप्ट फ़ाइल चलाता है।"
          }
        },
        "ja": {
