    "새 세션 만들기": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إنشاء جلسة جديدة"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Create new session"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Crear nueva sesión"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Créer une nouvelle session"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नया सत्र बनाएँ"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "新しいセッションを作成"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "새 세션 만들기"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Criar nova sessão"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Создать новую сессию"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "新建会话"
          }
        }
      }
    },
    "새 세션 만들기: 우상단 + 버튼. 제목은 비워둬도 됩니다(나중에 바꿀 수 있어요). 레포 경로는 Mac 의 최근 사용 프로젝트에서 고르거나 «경로 직접 입력» 으로 적습니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إنشاء جلسة جديدة: زر + في الأعلى يمينًا. يمكن ترك العنوان فارغًا (يمكن تغييره لاحقًا). اختر مسار المستودع من المشاريع الأخيرة على Mac أو اكتبه يدويًا عبر «إدخال المسار يدويًا»."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Create: tap + at the top right. You can leave the title blank (you can rename later). Pick the repo path from your Mac’s recent projects, or type it via “Type path manually”."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Crear: pulsa + arriba a la derecha. Puedes dejar el título vacío (luego se puede renombrar). Escoge la ruta del repo entre los proyectos recientes del Mac, o escríbela con «Escribir ruta manualmente»."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Créer : touchez + en haut à droite. Le titre peut rester vide (renommable plus tard). Choisissez le chemin du dépôt parmi les projets récents du Mac, ou saisissez-le via « Saisir le chemin manuellement »."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नया सत्र बनाएँ: दाईं ओर ऊपर + बटन। शीर्षक खाली छोड़ सकते हैं (बाद में बदला जा सकता है)। रेपो पथ Mac के हाल के प्रोजेक्ट से चुनें, या «पथ मैन्युअल टाइप करें» से लिखें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "新規セッションの作成: 右上の + ボタン。タイトルは空欄でも OK（あとで変更可能）。リポジトリのパスは Mac の最近使ったプロジェクトから選ぶか、「パスを手動入力」で入力します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "새 세션 만들기: 우상단 + 버튼. 제목은 비워둬도 됩니다(나중에 바꿀 수 있어요). 레포 경로는 Mac 의 최근 사용 프로젝트에서 고르거나 «경로 직접 입력» 으로 적습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Criar: toque em + no canto superior direito. O título pode ficar em branco (renomeável depois). Escolha o caminho do repo entre os projetos recentes do Mac ou digite via «Digitar caminho manualmente»."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Создать: + в правом верхнем углу. Заголовок можно оставить пустым (потом переименуете). Путь к репозиторию — из недавних проектов Mac или вручную через «Ввести путь вручную»."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "新建:右上角的 + 按钮。标题可留空(以后可改名)。仓库路径从 Mac 最近项目中选,或通过「手动输入路径」键入。"
          }
        }
      }
    },
    "새 세션 시작": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ابدأ جلسة جديدة"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start a new session"
          }
        },
        "es": {
          "stringUnit": {
