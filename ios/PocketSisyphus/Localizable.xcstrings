    "예: 매일 PR 을 리뷰하고 요약을 남겨줘": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "예: 매일 PR 을 리뷰하고 요약을 남겨줘"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "e.g. Review new PRs every day and leave a summary"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "例: 毎日 PR をレビューして要約を残して"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "例如：每天审查 PR 并留下摘要"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "p. ej.: Revisa los PR cada día y deja un resumen"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "ex. : Passe en revue les PR chaque jour et laisse un résumé"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مثال: راجع طلبات السحب يوميًا واترك ملخصًا"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
