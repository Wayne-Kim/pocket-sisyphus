          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rechercher par nom ou dépôt"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नाम या रेपो से खोजें"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "名前・リポジトリで検索"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이름·레포로 검색"
          }
        },
        "pt-BR": {
