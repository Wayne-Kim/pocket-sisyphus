    "연결이 준비되지 않았습니다 — 잠시 후 다시 시도하세요": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الاتصال غير جاهز — حاول مرة أخرى بعد قليل."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The connection isn’t ready — try again in a moment."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La conexión no está lista: inténtalo de nuevo en un momento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La connexion n’est pas prête — réessayez dans un instant."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कनेक्शन तैयार नहीं है — थोड़ी देर में फिर प्रयास करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "接続の準備ができていません — しばらくしてからもう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "연결이 준비되지 않았습니다 — 잠시 후 다시 시도하세요"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A conexão não está pronta — tente novamente em instantes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Соединение не готово — повторите попытку чуть позже."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "连接尚未就绪 — 请稍后重试。"
          }
        }
      }
    },
    "연결이 회복되면 다시 시도된다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ستُعاد المحاولة عند استعادة الاتصال."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Will retry when the connection recovers."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se reintentará cuando se restablezca la conexión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nouvelle tentative dès que la connexion sera rétablie."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कनेक्शन ठीक होने पर पुनः प्रयास किया जाएगा।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "接続が回復したら再試行されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "연결이 회복되면 다시 시도된다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Nova tentativa quando a conexão for restabelecida."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Повторим, как только восстановится соединение."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "连接恢复后将自动重试。"
          }
        }
      }
    },
