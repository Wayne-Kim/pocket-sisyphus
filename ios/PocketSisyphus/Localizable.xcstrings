    "이미 구매하셨다면 «이전 구매 복원» 을 눌러 주세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إن كنت قد اشتريت سابقًا، فاضغط «استعادة المشتريات السابقة»."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Already purchased? Tap “Restore previous purchase”."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Ya lo compraste? Pulsa «Restaurar compra anterior»."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Déjà acheté ? Appuyez sur « Restaurer un achat précédent »."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पहले से खरीदा है? «पिछली खरीदारी पुनर्स्थापित करें» पर टैप करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すでに購入済みの場合は「以前の購入を復元」を押してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이미 구매하셨다면 «이전 구매 복원» 을 눌러 주세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Já comprou? Toque em “Restaurar compra anterior”."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Уже покупали? Нажмите «Восстановить покупку»."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已经购买?请点按「恢复以前的购买」。"
          }
        }
