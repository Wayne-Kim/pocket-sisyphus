          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activer/désactiver la tâche planifiée"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अनुसूचित कार्य चालू/बंद करें"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
