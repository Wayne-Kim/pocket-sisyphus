    "오래된 QR 입니다 — Mac daemon 을 업데이트한 뒤 새 QR 을 출력하세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "رمز QR قديم — قم بتحديث Mac daemon ثم اعرض رمزًا جديدًا."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Outdated QR — update the Mac daemon and show a fresh QR."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "QR obsoleto — actualiza el daemon de Mac y muestra un QR nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "QR obsolète — mettez à jour le daemon Mac et affichez un nouveau QR."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पुराना QR — Mac daemon अपडेट करें और नया QR दिखाएँ।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "古い QR です — Mac daemon を更新して新しい QR を表示してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오래된 QR 입니다 — Mac daemon 을 업데이트한 뒤 새 QR 을 출력하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "QR desatualizado — atualize o daemon do Mac e gere um QR novo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Устаревший QR — обновите Mac-демон и покажите новый."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "QR 已过期 — 请更新 Mac daemon 并生成新的 QR。"
          }
        }
      }
    },
    "오래된 QR 입니다 — Mac 앱을 최신 버전으로 업데이트한 뒤 새 QR 을 출력하세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذا رمز QR قديم — حدّث تطبيق Mac إلى أحدث إصدار ثم اعرض رمز QR جديدًا."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This QR is outdated — update the Mac app to the latest version and generate a new QR."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El QR está desactualizado — actualiza la app de Mac y genera un QR nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "QR obsolète — mettez à jour l’app Mac vers la dernière version et générez un nouveau QR."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह QR पुराना है — Mac ऐप को नवीनतम संस्करण में अपडेट करें और नया QR तैयार करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "古い QR です — Mac アプリを最新版に更新してから新しい QR を出力してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오래된 QR 입니다 — Mac 앱을 최신 버전으로 업데이트한 뒤 새 QR 을 출력하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "QR desatualizado — atualize o app do Mac para a versão mais recente e gere um novo QR."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Этот QR устарел — обновите Mac-приложение и сгенерируйте новый QR."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此 QR 已过时 — 请将 Mac 应用更新到最新版本，然后生成新的 QR。"
          }
        }
      }
    },
