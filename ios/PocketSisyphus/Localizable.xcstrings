    "세션이 없습니다. 우상단 + 로 만들 수 있어요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا توجد جلسات. أنشئ واحدة عبر + في الأعلى يمينًا."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No sessions yet. Tap + at the top right to create one."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no hay sesiones. Toca + arriba a la derecha para crear una."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucune session. Touchez + en haut à droite pour en créer une."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अभी कोई सत्र नहीं है। दाईं ओर ऊपर + दबाकर बनाएँ।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "セッションはまだありません。右上の + で作成できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "세션이 없습니다. 우상단 + 로 만들 수 있어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sem sessões ainda. Toque em + no canto superior direito para criar uma."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сессий пока нет. Нажмите + в правом верхнем углу, чтобы создать."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "尚无会话。轻触右上角 + 创建一个。"
          }
        }
      }
    },
