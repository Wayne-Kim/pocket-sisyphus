    "%@ — Claude 가 도구 사용 승인을 요청합니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — يطلب Claude الموافقة على استخدام أداة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — Claude is requesting approval to use a tool."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — Claude solicita aprobación para usar una herramienta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — Claude demande l’approbation pour utiliser un outil."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — Claude टूल इस्तेमाल की अनुमति माँग रहा है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — Claude がツール使用の承認を要求しています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — Claude 가 도구 사용 승인을 요청합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — Claude está pedindo aprovação para usar uma ferramenta."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — Claude запрашивает разрешение на использование инструмента."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — Claude 正在请求使用工具的批准。"
          }
        }
      }
    },
    "%@ — Claude 가 응답을 보냈습니다. 탭해서 열기.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — أرسل Claude ردًا. اضغط لفتح."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — Claude sent a reply. Tap to open."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — Claude envió una respuesta. Toca para abrir."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — Claude a envoyé une réponse. Touchez pour ouvrir."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — Claude ने जवाब भेजा है। खोलने के लिए टैप करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — Claude が返答を送りました。タップで開く。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — Claude 가 응답을 보냈습니다. 탭해서 열기."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — Claude enviou uma resposta. Toque para abrir."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — Claude отправил ответ. Нажмите, чтобы открыть."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — Claude 发送了回复。点击打开。"
          }
        }
      }
    },
    "%@ — Claude 가 질문을 보냈습니다. 탭해서 답하기.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — أرسل Claude سؤالًا. اضغط للرد."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — Claude asked a question. Tap to answer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — Claude hizo una pregunta. Toca para responder."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — Claude a posé une question. Touchez pour répondre."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — Claude ने सवाल पूछा है। जवाब देने के लिए टैप करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — Claude が質問を送りました。タップで回答。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — Claude 가 질문을 보냈습니다. 탭해서 답하기."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — Claude fez uma pergunta. Toque para responder."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — Claude задал вопрос. Нажмите, чтобы ответить."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — Claude 提出了问题。点击回答。"
          }
        }
      }
    },
    "%@ — 탭해서 자세히 보기.": {
