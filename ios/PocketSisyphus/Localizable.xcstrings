    },
    "이 세션에서 항상 승인 — 이 세션이 끝날 때까지 같은 도구는 자동 승인. 세션 범위만이라 다른 세션에는 영향이 없습니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "السماح دائمًا في هذه الجلسة — تُوافَق الاستدعاءات على نفس الأداة تلقائيًا حتى انتهاء الجلسة. ينطبق على هذه الجلسة فقط ولا يؤثر على الجلسات الأخرى."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Always allow in this session — same tool gets auto-approved until the session ends. Scoped to this session only; other sessions are unaffected."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Permitir siempre en esta sesión — se aprueba automáticamente la misma herramienta hasta que termine la sesión. Sólo afecta a esta sesión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Toujours autoriser dans cette session — le même outil est auto-autorisé jusqu’à la fin de la session. Limité à cette session uniquement."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस सत्र में हमेशा अनुमति — सत्र समाप्त होने तक उसी टूल को स्वत: स्वीकृति। केवल इसी सत्र पर लागू, अन्य सत्रों पर असर नहीं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このセッションで常に許可 — セッション終了まで同じツールを自動承認。このセッション内のみで、他のセッションには影響しません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 세션에서 항상 승인 — 이 세션이 끝날 때까지 같은 도구는 자동 승인. 세션 범위만이라 다른 세션에는 영향이 없습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sempre permitir nesta sessão — a mesma ferramenta é aprovada automaticamente até a sessão acabar. Vale só para esta sessão."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Всегда разрешать в этой сессии — тот же инструмент авто-разрешается до конца сессии. Только в рамках этой сессии."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本会话始终允许 — 直到会话结束,相同工具自动批准。仅限本会话,不影响其他会话。"
          }
        }
      }
    },
    "이 세션의 내용을 모두 비울까요?": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هل تريد مسح كل محتوى هذه الجلسة؟"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clear all contents of this session?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Vaciar todo el contenido de esta sesión?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vider tout le contenu de cette session ?"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "क्या इस सत्र की सारी सामग्री साफ़ करें?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このセッションの内容をすべて消去しますか？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 세션의 내용을 모두 비울까요?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Apagar todo o conteúdo desta sessão?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Очистить всё содержимое этой сессии?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "要清空本会话的全部内容吗?"
          }
        }
      }
    },
    "이 세션의 보낸 이력을 모두 지울까요?": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هل تريد مسح كامل سجل الإرسال لهذه الجلسة؟"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clear all sent history for this session?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Borrar todo el historial de envíos de esta sesión?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Effacer tout l’historique envoyé de cette session ?"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "क्या इस सत्र का सारा भेजा हुआ इतिहास मिटा दें?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このセッションの送信履歴をすべて消去しますか?"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 세션의 보낸 이력을 모두 지울까요?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Apagar todo o histórico enviado desta sessão?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Очистить всю историю отправленных сообщений в этой сессии?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "要清空本会话的全部发送历史吗?"
          }
