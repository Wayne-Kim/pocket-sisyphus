    "예약 작업 켜기/끄기": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تفعيل/تعطيل المهمة المجدولة"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Toggle scheduled task"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
