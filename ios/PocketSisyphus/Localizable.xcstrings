    "데스크탑에 연결하지 못했어요. 네트워크 상태를 확인하고 다시 시도해 주세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذّر الاتصال بجهازك المكتبي. تحقّق من اتصال الشبكة وحاول مرة أخرى."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn’t connect to your desktop. Check your network and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo conectar con tu escritorio. Comprueba tu red e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de se connecter à votre ordinateur. Vérifiez votre réseau et réessayez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपके डेस्कटॉप से कनेक्ट नहीं हो सका. अपना नेटवर्क जांचें और फिर से प्रयास करें."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デスクトップに接続できませんでした。ネットワークを確認してもう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "데스크탑에 연결하지 못했어요. 네트워크 상태를 확인하고 다시 시도해 주세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível conectar ao seu desktop. Verifique sua rede e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось подключиться к компьютеру. Проверьте сеть и повторите попытку."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法连接到你的桌面设备。请检查网络后重试。"
          }
        }
      }
    },
