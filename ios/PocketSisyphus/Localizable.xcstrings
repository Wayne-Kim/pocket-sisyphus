    "선택한 %lld건을 기각해요. 처리됨으로 옮겨가요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "رفض %lld عنصرًا محددًا؟ ستنتقل إلى «تمت المعالجة»."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reject %lld selected? They move to Resolved."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Rechazar %lld seleccionados? Pasan a Resueltas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rejeter les %lld éléments sélectionnés ? Ils passent dans Traitées."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld चयनित अस्वीकार करें? वे «निपटाए गए» में चले जाएंगे।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択した %lld件を却下しますか？「処理済み」に移ります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택한 %lld건을 기각해요. 처리됨으로 옮겨가요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Rejeitar %lld selecionados? Vão para Resolvidas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отклонить выбранные %lld? Перейдут в «Обработанные»."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拒绝所选 %lld 项？将移至「已处理」。"
          }
        }
      }
    },
    "선택한 모델이 아직 다운로드되지 않았어요. 아래 「로컬 LLM 모델」 에서 모델을 받아 주세요.": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택한 모델이 아직 다운로드되지 않았어요. 아래 「로컬 LLM 모델」 에서 모델을 받아 주세요."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The selected model hasn’t been downloaded yet. Download it under “Local LLM Models” below."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El modelo seleccionado aún no se ha descargado. Descárgalo en «Modelos de LLM local» más abajo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le modèle sélectionné n'a pas encore été téléchargé. Téléchargez-le sous « Modèles de LLM local » ci-dessous."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चयनित मॉडल अभी डाउनलोड नहीं हुआ है। इसे नीचे “लोकल LLM मॉडल” में डाउनलोड करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択したモデルはまだダウンロードされていません。下の「ローカル LLM モデル」からダウンロードしてください。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O modelo selecionado ainda não foi baixado. Baixe-o em “Modelos de LLM local” abaixo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выбранная модель ещё не загружена. Загрузите её в разделе «Локальные модели LLM» ниже."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "所选模型尚未下载。请在下方“本地 LLM 模型”中下载。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "النموذج المحدد لم يُنزَّل بعد. نزّله من «نماذج LLM المحلية» أدناه."
          }
        }
      }
    },
    "선택한 언어가 앱 재시작 후에 적용됩니다.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ستظهر اللغة المختارة بعد إعادة تشغيل التطبيق."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The selected language will take effect after the app restarts."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El idioma elegido se aplicará al reiniciar la app."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La langue choisie sera appliquée après le redémarrage de l’app."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चुनी हुई भाषा ऐप पुनः आरंभ करने के बाद लागू होगी।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択した言語はアプリの再起動後に適用されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택한 언어가 앱 재시작 후에 적용됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O idioma selecionado será aplicado após reiniciar o app."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выбранный язык применится после перезапуска приложения."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "所选语言将在重启应用后生效。"
          }
        }
      }
    },
    "선택한 언어는 앱을 완전히 닫고 다시 열면 적용됩니다. 홈에서 위로 스와이프 → Pocket Sisyphus 카드를 위로 밀어 종료한 뒤 아이콘을 다시 탭하세요.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تُطبَّق اللغة المختارة بعد إغلاق التطبيق تمامًا وإعادة فتحه. اسحب لأعلى من الشاشة الرئيسية ← مرّر بطاقة Pocket Sisyphus لأعلى لإغلاقها، ثم انقر الأيقونة من جديد."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The selected language takes effect after you fully close and reopen the app. Swipe up from the home screen → push the Pocket Sisyphus card up to quit, then tap the icon again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El idioma elegido se aplica al cerrar la app por completo y volver a abrirla. Desliza hacia arriba desde la pantalla de inicio → empuja la tarjeta de Pocket Sisyphus hacia arriba para cerrar y toca de nuevo el icono."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La langue choisie est appliquée après une fermeture complète et une réouverture de l’app. Glissez vers le haut depuis l’écran d’accueil → poussez la fiche Pocket Sisyphus vers le haut pour quitter, puis touchez à nouveau l’icône."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चुनी हुई भाषा तभी लागू होती है जब आप ऐप पूरी तरह बंद करके दोबारा खोलें। होम स्क्रीन से ऊपर स्वाइप करें → Pocket Sisyphus कार्ड को ऊपर खींचकर बंद करें, फिर आइकन पर दोबारा टैप करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択した言語はアプリを完全に終了して再度開くと反映されます。ホーム画面で上にスワイプ → Pocket Sisyphus のカードを上に押し出して終了し、もう一度アイコンをタップしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택한 언어는 앱을 완전히 닫고 다시 열면 적용됩니다. 홈에서 위로 스와이프 → Pocket Sisyphus 카드를 위로 밀어 종료한 뒤 아이콘을 다시 탭하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O idioma escolhido só vale depois que você fechar o app por completo e abrir de novo. Deslize para cima na tela inicial → empurre o cartão do Pocket Sisyphus para cima para encerrar e toque no ícone outra vez."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выбранный язык применяется после полного закрытия и повторного запуска приложения. Свайпните вверх с главного экрана → сдвиньте карточку Pocket Sisyphus вверх, чтобы закрыть, и снова коснитесь иконки."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "所选语言会在完全关闭并重新打开应用后生效。从主屏幕向上轻扫 → 将 Pocket Sisyphus 卡片向上推走以结束应用,然后再次点击图标。"
          }
        }
      }
    },
    "선택한 음성 모델을 준비하지 못해 이전 모델로 되돌렸어요. 네트워크와 저장공간을 확인해 주세요.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذّر تجهيز نموذج الصوت المحدد، لذا تمت العودة إلى النموذج السابق. تحقق من الشبكة ومساحة التخزين."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't prepare the selected speech model, so we reverted to the previous one. Check your network and storage."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo preparar el modelo de voz seleccionado, así que volvimos al anterior. Comprueba tu red y almacenamiento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de préparer le modèle vocal sélectionné ; nous sommes revenus au précédent. Vérifiez votre réseau et votre stockage."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चयनित वाक् मॉडल तैयार नहीं हो सका, इसलिए पिछले मॉडल पर लौट आए। अपना नेटवर्क और संग्रहण जाँचें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択した音声モデルを準備できなかったため、以前のモデルに戻しました。ネットワークとストレージをご確認ください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택한 음성 모델을 준비하지 못해 이전 모델로 되돌렸어요. 네트워크와 저장공간을 확인해 주세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível preparar o modelo de voz selecionado, então voltamos ao anterior. Verifique sua rede e armazenamento."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось подготовить выбранную модель распознавания речи, поэтому мы вернулись к предыдущей. Проверьте сеть и хранилище."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法准备所选语音模型，已恢复为上一个模型。请检查网络和存储空间。"
          }
        }
      }
    },
