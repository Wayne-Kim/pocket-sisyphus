            "value": "무슨 일이 있었나요? (증상과 재현 절차를 적어 주세요)"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What happened? (Describe the symptoms and steps to reproduce)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Qué ocurrió? (Describe los síntomas y los pasos para reproducirlo)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Que s'est-il passé ? (Décrivez les symptômes et les étapes pour reproduire)"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ماذا حدث؟ (صف الأعراض وخطوات إعادة الإنتاج)"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "क्या हुआ? (लक्षण और दोहराने के चरण लिखें)"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "何が起きましたか？（症状と再現手順を書いてください）"
